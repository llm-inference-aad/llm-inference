import torch
from torch import optim as optimizers
from torch.optim import Optimizer
from torch.nn import Module, Parameter
from typing import List, Dict, Any

def get_optimizer(model: Module, lr: float, weight_decay: float = 0, nesterov: bool = True) -> Optimizer:
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for module in model.modules():
            if hasattr(module, 'bias') and isinstance(module.bias, Parameter):
                g2.append(module.bias)
            if isinstance(module, (torch.nn.BatchNorm2d, torch.nn.LayerNorm)):
                g0.append(module.weight)
            elif hasattr(module, 'weight') and isinstance(module.weight, Parameter):
                g1.append(module.weight)
        opt = optimizers.SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = optimizers.SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt

