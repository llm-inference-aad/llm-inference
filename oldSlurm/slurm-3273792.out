```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using max pooling on negated input to simulate min pooling
        return -F.max_pool2d(-x, self.kernel_size, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super(FCT, self).__init__()
        # Depth-wise convolution with adjusted kernel size and padding
        self.dw = nn.Conv2d(cin, cin, kernel_size=3, stride=2, padding=1,
                            groups=cin, bias=False)
        # Modified max pool with different kernel size
        self.maxpool = nn.MaxPool2d(kernel_size=3, ceil_mode=True)
        # Using our custom MinPool2d
        self.minpool = MinPool2d(kernel_size=2, ceil_mode=True)
        # Point-wise convolution with increased output channels
        self.pw = nn.Conv2d(3 * cin, cout, kernel_size=1, stride=1, bias=False)
        # Batch normalization
        self.bn = nn.BatchNorm2d(cout)
        # Adding ReLU activation
        self.relu = nn.ReLU(inplace=True)

    def forward(self, x):
        # Applying depth-wise convolution and pooling operations
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_dw = self.dw(x)
        # Concatenating along the channel dimension
        x_concat = torch.cat((x_max, x_min, x_dw), dim=1)
        # Point-wise convolution and batch norm
        x_pw = self.pw(x_concat)
        x_bn = self.bn(x_pw)
        # Applying activation
        x_out = self.relu(x_bn)
        return x_out
```

