import torch
import torch.nn as nn
from torch.nn.utils.fusion import fuse_conv_bn_eval

def pad_num_y(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DepthwiseConvBlock(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin)
        self.bn = nn.BatchNorm2d(cin)
        self.act = nn.Hardswish()
        
        # Fuse Conv and BatchNorm during initialization if possible
        if hasattr(torch.nn, 'fuse_conv_bn'):
            self.fuse_modules()

    def fuse_modules(self):
        try:
            self.dw, self.bn = torch.nn.utils.fusion.fuse_conv_bn_eval(self.dw, self.bn)
        except Exception as e:
            print(f"Failed to fuse modules: {e}")

    def forward(self, x):
        x = self.dw(x)
        x = self.bn(x) if hasattr(self, 'bn') else x
        x = self.act(x)
        return x

# Optional: Create a helper function to create and fuse layers
def create_fused_depthwise_layer(cin, kernel_size):
    layer = DepthwiseConvBlock(cin, kernel_size)
    layer.eval()  # Ensure in evaluation mode for fusion
    layer.fuse_modules()
    return layer

