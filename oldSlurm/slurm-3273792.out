import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return F.avg_pool2d(x, self.ks, ceil_mode=self.ceil_mode)  # Changed from max-based min pool

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout, momentum=0.99, eps=1e-5)  # Adjusted BN params
        self.relu = nn.ReLU(inplace=True)  # Added activation

    def forward(self, x):
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_cat = torch.cat((x_max, x_min), 1)
