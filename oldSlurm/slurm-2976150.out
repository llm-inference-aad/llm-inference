import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin, reduction_ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin // reduction_ratio, bias=False)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(cin // reduction_ratio, cin, bias=False)
        self.sigmoid = nn.Sigmoid()
        self.ln = nn.LayerNorm(cin)
    
    def forward(self, x):
        b, c, _, _ = x.size()
        y = x

        # Squeeze
        w = self.gavg(x).view(b, c)

        # Excitation
        w = self.fc1(w)
        w = self.relu(w)
        w = self.fc2(w)
        w = self.sigmoid(w)

        # Apply scaling
        w = self.ln(w) # Layer Norm applied after excitation
        w = w.view(b, c, 1, 1)
        return x * w

