            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)
        
        opt = SGD(g0, lr, momentum=0.0, nesterov=nesterov) # reduced momentum for g0
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
        opt.add_param_group({'params': g2, 'lr': lr * 0.1, 'momentum': 0.0, 'weight_decay': 0.0})  # add g2 (biases) with smaller lr, and no weight decay
    else:
        opt = SGD(model.parameters(), lr, momentum=0.9, nesterov=nesterov)
    return opt
```

