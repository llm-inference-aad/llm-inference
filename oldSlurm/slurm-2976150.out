import torch
import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout, reduction_factor=4):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)  # Keep original pooling for simplicity
        self.reduction_dim = max(1, cin // reduction_factor) #Ensure reduction_dim is at least 1
        self.pw_reduce = nn.Conv2d(cin, self.reduction_dim, 1, 1, bias=False)
        self.pw_expand = nn.Conv2d(self.reduction_dim, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.relu = nn.ReLU(inplace=True)


    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw_reduce(x)
        x = self.relu(x)
        x = self.pw_expand(x)
        x = self.bn(x)
        return x

