import torch
import torch.nn as nn
import torch.nn.functional as F


class SE_LN(nn.Module):
    def __init__(self, cin, reduction_ratio=16, use_batchnorm=False):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.use_batchnorm = use_batchnorm

        if use_batchnorm:
            self.ln = nn.BatchNorm1d(cin)
        else:
            self.ln = nn.LayerNorm(cin)

        self.linear1 = nn.Linear(cin, cin // reduction_ratio)
        self.act1 = nn.SiLU()  # Swish / SiLU activation
        self.linear2 = nn.Linear(cin // reduction_ratio, cin)
        self.act2 = nn.Sigmoid() # Or nn.SiLU, experiment!

        # Initialize the linear layers (important for training stability)
        nn.init.kaiming_normal_(self.linear1.weight, nonlinearity='relu') # Or 'linear', if you remove the activation from after it
        nn.init.zeros_(self.linear1.bias)
        nn.init.kaiming_normal_(self.linear2.weight, nonlinearity='sigmoid')
        nn.init.zeros_(self.linear2.bias)


    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))

        if self.use_batchnorm:
           x = self.ln(x)
        else:
           x = self.ln(x)

        x = self.linear1(x)
        x = self.act1(x)
        x = self.linear2(x)
        x = self.act2(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x*y

