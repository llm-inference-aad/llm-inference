class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.conv1 = nn.Conv2d(cin, cin // ratio, kernel_size=1, bias=False)
        self.act1 = nn.ReLU()
        self.conv2 = nn.Conv2d(cin // ratio, cin, kernel_size=1, bias=False)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        w = self.gavg(x) # global average pooling
        w = self.conv1(w) # reduce channels
        w = self.act1(w)  # nonlinearity
        w = self.conv2(w) # restore channels
        w = self.act2(w)  # sigmoid
        return x * w

