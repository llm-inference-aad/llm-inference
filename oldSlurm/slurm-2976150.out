import torch
import torch.nn as nn
import torch.fft as fft

def sparse_aware_maxpool(x, kernel_size=2, stride=2, ceil_mode=True, threshold=1e-6):
    """
    A custom max pooling operation that leverages sparsity.
    """
    padding = 0
    if ceil_mode:
        padding = (kernel_size - (x.size(-2) % stride)) % stride

    if padding > 0:
        x = torch.nn.functional.pad(x, (0, 0, 0, padding))

    output_height = (x.size(-2) - kernel_size) // stride + 1

    output = torch.zeros((x.size(0), x.size(1), output_height, x.size(-1) // stride), device=x.device)
    for i in range(output_height):
        for j in range(output.size(-1)):
            start_i = i * stride
            end_i = start_i + kernel_size
            start_j = j * stride
            end_j = start_j + kernel_size

            patch = x[:, :, start_i:end_i, start_j:end_j]
            # Identify near-zero activations (sparsity)
            mask = torch.abs(patch) > threshold
            if torch.any(mask):
                # Max over non-zero values
                output[:, :, i, j] = torch.max(patch * mask, dim=(-1, -2))[0]  # Fixed indexing here
            else:
                # If all values are near-zero, set output to zero
                output[:, :, i, j] = torch.zeros_like(output[0,0,i,j])
    return output

def freq_domain_conv2d(x, weight):
    """
    Performs 2D convolution in the frequency domain.
    """
    N, C, H, W = x.shape
    cout, cin, kh, kw = weight.shape

    # Pad input and weight to the same size
    pad_h = (H + kh - 1) // 2
    pad_w = (W + kw - 1) // 2

    padded_x = torch.nn.functional.pad(x, (pad_w, pad_w, pad_h, pad_h))
    padded_weight = torch.nn.functional.pad(weight, (pad_w, pad_w, pad_h, pad_h))

    # FFT
    x_fft = fft.fft2(padded_x)
    weight_fft = fft.fft2(padded_weight)

    # Convolution in frequency domain
    out_fft = x_fft * weight_fft

    # Inverse FFT
    out = fft.ifft2(out_fft).real

    # Crop to original size
    out = out[:, :, :H, :W]

    return out

class QuantAwareBatchNorm2d(nn.Module):
    def __init__(self, num_features, eps=1e-5, momentum=0.1, quant_bits=8):
        super().__init__()
        self.num_features = num_features
        self.eps = eps
        self.momentum = momentum
        self.quant_bits = quant_bits
        self.weight = nn.Parameter(torch.ones(num_features))
        self.bias = nn.Parameter(torch.zeros(num_features))
        self.register_buffer('running_mean', torch.zeros(num_features))
        self.register_buffer('running_var', torch.ones(num_features))

    def quantize(self, x):
        scale = (2**self.quant_bits - 1) / (x.max() - x.min())
        x_quant = torch.round(x * scale) / scale
        return x_quant

    def forward(self, x):
        if self.training:
            batch_mean = torch.mean(x, dim=[0, 2, 3])
            batch_var = torch.var(x, dim=[0, 2, 3], unbiased=False)

            with torch.no_grad():
                self.running_mean.mul_(1 - self.momentum).add_(batch_mean, alpha=self.momentum)
                self.running_var.mul_(1 - self.momentum).add_(batch_var, alpha=self.momentum)

            x = (x - batch_mean[None, :, None, None]) / torch.sqrt(batch_var[None, :, None, None] + self.eps)
        else:
            x = (x - self.running_mean[None, :, None, None]) / torch.sqrt(self.running_var[None, :, None, None] + self.eps)

        x = self.weight[None, :, None, None] * x + self.bias[None, :, None, None]
        x = self.quantize(x) # Quantize the output
        return x

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = sparse_aware_maxpool
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = QuantAwareBatchNorm2d(cout)

    def forward(self, x):
        x = self.maxpool(x)
        x = freq_domain_conv2d(x, self.pw.weight)
        x = self.bn(x)
        return x

