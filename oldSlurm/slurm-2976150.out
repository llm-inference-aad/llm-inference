import torch
import torch.nn as nn
import torch.nn.functional as F

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.se = SEBlock(cout) # Squeeze-and-Excitation
        self.gate = nn.Parameter(torch.zeros(1))  # Learnable gate
        self.dropout = nn.Dropout(0.1)

    def forward(self, x):
        original_x = x # Store original input to allow for branching or identity mappings

        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = self.se(x)
        x = F.relu(x)

        # Gated skip connection.  The gate learns how much of the processed feature map should be added to the original feature map.
        if original_x.shape[1] == x.shape[1] and original_x.shape[2] == x.shape[2] and original_x.shape[3] == x.shape[3]: # check same feature map count
          x = self.gate * x + original_x  # Assuming original_x is also processed/scaled if necessary.
        else:
           x = x

        x = self.dropout(x)
        return x


class SEBlock(nn.Module):
    def __init__(self, ch, r=16):
        super().__init__()
        self.se = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(ch, ch//r, kernel_size=1, stride=1, padding=0, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(ch//r, ch, kernel_size=1, stride=1, padding=0, bias=False),
            nn.Sigmoid(),
        )

    def forward(self, x):
        return x * self.se(x)

