        self.channel_scale2 = nn.Parameter(torch.ones(48)) #Learnable scaling of channels after EVE
        self.channel_scale3 = nn.Parameter(torch.ones(96)) #Learnable scaling of channels after ME3
        self.channel_scale4 = nn.Parameter(torch.ones(192)) #Learnable scaling of channels after ME4
        self.channel_scale5 = nn.Parameter(torch.ones(384)) #Learnable scaling of channels after ME5
        self.feature_noise_std = 0.01 # Small noise added before the final classification
        self.feature_noise = torch.distributions.Normal(0, self.feature_noise_std)

    def forward(self, x):
        x = self.FCT(x)
        x = x * self.channel_scale1.view(1, -1, 1, 1) # Scale channels
        x = self.DFSEB1(x)
        x = self.EVE(x)
        x = x * self.channel_scale2.view(1, -1, 1, 1) # Scale channels
        x = self.DFSEB2(x)
        x = self.ME3(x)
        x = x * self.channel_scale3.view(1, -1, 1, 1) # Scale channels
        x = self.DFSEB3(x)
        x = self.ME4(x)
        x = x * self.channel_scale4.view(1, -1, 1, 1) # Scale channels
        x = self.DFSEB4(x)
        x = self.ME5(x)
        x = x * self.channel_scale5.view(1, -1, 1, 1) # Scale channels
        x = self.DFSEB5(x)
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))

        #Add a little noise for robustness
        if self.training:
            x = x + self.feature_noise.sample(x.shape).to(x.device)

        x = self.fc(x)
        return x

