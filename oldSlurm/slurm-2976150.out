import torch.nn as nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True, momentum=0.9):  
    """
    Configures and returns an SGD optimizer with parameter grouping and optional weight decay.

    Args:
        model: The PyTorch model whose parameters need to be optimized.
        lr: The learning rate for the optimizer.
        weight_decay: L2 regularization strength. Defaults to 0.
        nesterov: Enables Nesterov momentum. Defaults to True.
        momentum: Momentum factor. Defaults to 0.9.

    Returns:
        A PyTorch SGD optimizer.
    """
    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)
        
        opt = SGD(g0, lr, momentum=momentum, nesterov=nesterov)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
        opt.add_param_group({'params': g2})  # add g2 (biases)
    else:
        opt = SGD(model.parameters(), lr, momentum=momentum, nesterov=nesterov)
    return opt

