import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)


class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)

        # Attention mechanism for maxpool output
        self.maxpool_attention = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(cin, cin // 8, 1, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(cin // 8, cin, 1, bias=False),
            nn.Sigmoid()
        )

        # Attention mechanism for minpool output
        self.minpool_attention = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(cin, cin // 8, 1, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(cin // 8, cin, 1, bias=False),
            nn.Sigmoid()
        )


        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.relu = nn.ReLU(inplace=True) # Add ReLU activation

        # Learnable scaling factors for maxpool and minpool outputs
        self.maxpool_scale = nn.Parameter(torch.ones(1))
        self.minpool_scale = nn.Parameter(torch.ones(1))


    def forward(self, x):
        maxpool_out = self.maxpool(x)
        minpool_out = self.minpool(x)


        # Apply attention to maxpool output
        maxpool_attention = self.maxpool_attention(maxpool_out)
        maxpool_out = maxpool_out * maxpool_attention

        # Apply attention to minpool output
        minpool_attention = self.minpool_attention(minpool_out)
        minpool_out = minpool_out * minpool_attention

        # Scale maxpool and minpool outputs
        maxpool_out = maxpool_out * self.maxpool_scale
        minpool_out = minpool_out * self.minpool_scale

        x = torch.cat((
            maxpool_out,
            minpool_out
        ), 1)


        x = self.pw(x)
        x = self.bn(x)
        x = self.relu(x) # Apply ReLU after batch norm

        return x

