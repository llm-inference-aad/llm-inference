import torch
import torch.nn as nn
import torch.nn.functional as F

def calculate_padding(kernel_size, dilation=1):
    """Calculates padding based on kernel size and dilation for 'same' padding."""
    padding = (kernel_size - 1) // 2 * dilation
    return padding

class DW(nn.Module):
    def __init__(self, cin, dw_s, expansion_ratio=1, se_ratio=0.25):
        super().__init__()

        self.expansion_ratio = expansion_ratio
        self.expanded_channels = int(cin * expansion_ratio)
        self.use_se = se_ratio is not None and se_ratio > 0

        # Expansion (Pointwise Convolution)
        self.expand_conv = nn.Conv2d(cin, self.expanded_channels, kernel_size=1, bias=False) if expansion_ratio > 1 else nn.Identity()
        self.bn1 = nn.BatchNorm2d(self.expanded_channels) if expansion_ratio > 1 else nn.Identity()

        # Depthwise Convolution
        padding = calculate_padding(dw_s) # Using helper function
        self.dw = nn.Conv2d(self.expanded_channels, self.expanded_channels, dw_s, stride=1, padding=padding, groups=self.expanded_channels, bias=False)
        self.bn2 = nn.BatchNorm2d(self.expanded_channels)

        # Squeeze-and-Excitation
        if self.use_se:
            num_squeezed_channels = max(1, int(cin * se_ratio))
            self.se_reduce = nn.Conv2d(self.expanded_channels, num_squeezed_channels, 1)
            self.se_expand = nn.Conv2d(num_squeezed_channels, self.expanded_channels, 1)

        # Projection (Pointwise Convolution)
        self.project_conv = nn.Conv2d(self.expanded_channels, cin, kernel_size=1, bias=False)
        self.bn3 = nn.BatchNorm2d(cin)

        self.act = nn.Hardswish()


    def forward(self, x):
        identity = x

        # Expand
        if self.expansion_ratio > 1:
            x = self.expand_conv(x)
            x = self.bn1(x)
            x = self.act(x)

        # Depthwise
        x = self.dw(x)
        x = self.bn2(x)
        x = self.act(x)

        # Squeeze and Excitation
        if self.use_se:
            se = x.mean((2, 3), keepdim=True)
            se = F.relu(self.se_reduce(se))
            se = torch.sigmoid(self.se_expand(se))
            x = x * se

        # Project
        x = self.project_conv(x)
        x = self.bn3(x)


        # Skip connection (assumes input and output have the same size)
        x = x + identity

        return x

