import torch
import torch.nn as nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True, momentum=0.9, bias_decay=False):  
    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                if bias_decay:
                    g1.append(v.bias) # treat bias like weights w/ decay
                else:
                    g2.append(v.bias) # Standard Bias treatment
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)
        
        opt = SGD(g0, lr, momentum=momentum, nesterov=nesterov)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
        opt.add_param_group({'params': g2})  # add g2 (biases)
    else:
        opt = SGD(model.parameters(), lr, momentum=momentum, nesterov=nesterov)
    return opt

