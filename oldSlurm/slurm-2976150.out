import torch
import torch.nn as nn
import math

def pad_num_y(k_s):
    pad_per_side = int(torch.sin(torch.tensor((k_s-1)*0.5))*1.0000001)
    return pad_per_side
    
class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin)
        self.act = nn.Hardswish()

    def forward(self, x):
        x = self.dw(x)
        x = self.act(x)
        return x

