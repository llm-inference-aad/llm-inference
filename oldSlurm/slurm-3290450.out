import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.gmax = nn.AdaptiveMaxPool2d((1,1))
        self.ln = nn.LayerNorm(2 * cin)
        self.act = nn.Sigmoid()

    def forward(self, x):
        y = x
        x_avg = self.gavg(x)
        x_max = self.gmax(x)
        x = torch.cat([x_avg, x_max], dim=1)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1)//2, 1, 1)
        return x*y

