import torch
import torch.nn as nn
from torch.nn import functional as F

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        
        # Enhanced Stem with BatchNorm and Depth-wise Separable Conv
        self.stem = nn.Sequential(
            nn.Conv2d(img_channels, 16, kernel_size=3, padding=1, bias=False),
            nn.BatchNorm2d(16),
            nn.ReLU(inplace=True),
            nn.Conv2d(16, 16, kernel_size=3, padding=1, groups=16, bias=False),
            nn.BatchNorm2d(16),
            nn.ReLU(inplace=True),
            nn.Conv2d(16, 12, kernel_size=1, bias=False),
            nn.BatchNorm2d(12)
        )
        
        # Modified Blocks with Residual Connections and Attention
        self.block1 = nn.Sequential(
            FCT(12, 12),
            DFSEBV2(12, 3, True),
            nn.BatchNorm2d(12),
            nn.Sequential(
                nn.Conv2d(12, 12, kernel_size=1),
                nn.Sigmoid()
            )  # Channel-wise Attention
        )
        
        self.eve_block = nn.Sequential(
            EVE(12, 48),
            DFSEBV2(48, 3, True),
            nn.BatchNorm2d(48),
            nn.Sequential(
                nn.Conv2d(48, 48, kernel_size=1),
                nn.Sigmoid()
            ),
            nn.Conv2d(48, 48, kernel_size=3, padding=1),
            nn.BatchNorm2d(48)
        )
        
        # Progressive Feature Expansion with Skip Connections
        self.block3 = nn.Sequential(
            ME(48, 96),
            DFSEBV2(96, 3, True),
            nn.BatchNorm2d(96),
            nn.Sequential(
                nn.Conv2d(96, 96, kernel_size=1),
                nn.Sigmoid()
            )
        )
        
        self.block4 = nn.Sequential(
            ME(96, 192),
            DFSEBV2(192, 3, True),
            nn.BatchNorm2d(192),
            nn.Sequential(
                nn.Conv2d(192, 192, kernel_size=1),
                nn.Sigmoid()
            )
        )
        
        self.block5 = nn.Sequential(
            ME(192, 384),
            DFSEBV2(384, 3, True),
            nn.BatchNorm2d(384),
            nn.Sequential(
                nn.Conv2d(384, 384, kernel_size=1),
                nn.Sigmoid()
            )
        )
        
        # Final Processing with Reduced Dropout
        self.dw = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d

