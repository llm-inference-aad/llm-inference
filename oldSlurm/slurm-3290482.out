import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=False)  # Changed ceil_mode to False
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=True)  # Added bias to pw
        self.bn = nn.BatchNorm2d(cout, momentum=0.01)     # Reduced momentum from 0.1 to 0.01
        self.dropout = nn.Dropout(0.2)                    # Added dropout
        
        # Initialize weights using He normal initialization
        for m in [self.pw]:
            if isinstance(m, nn.Conv2d):
                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = self.dropout(x)
        return x

