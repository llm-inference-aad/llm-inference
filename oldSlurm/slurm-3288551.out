```python
import torch
from torch import optim
from torch.optim import Optimizer
from typing import List, Dict, Any

class CustomSGD(optim.SGD):
    def __init__(self, params, lr, momentum=0, dampening=0,
                 weight_decay=0, nesterov=False):
        super().__init__(params, lr, momentum, dampening,
                         weight_decay, nesterov)

    @torch.no_grad()
    def step(self, closure=None):
        loss = None
        if closure is not None:
            with torch.enable_grad():
                loss = closure()
        for group in self.param_groups:
            params_with_grad = []
            d_p_list = []
            for p in group['params']:
                if p.grad is not None:
                    params_with_grad.append(p)
                    d_p_list.append(p.grad)
            if len(params_with_grad) == 0:
                continue
            grads = torch.stack(d_p_list)
            mean_grad = grads.mean(dim=0)
            std_grad = grads.std(dim=0)
            normalized_grads = (grads - mean_grad) / (std_grad + 1e-8)
            for i, p in enumerate(params_with_grad):
                d_p = normalized_grads[i]
                if group['weight_decay']!= 0:
                    d_p = d_p.add(p, alpha=group['weight_decay'])
                if group['momentum']!= 0:
                    buf = self.state[p].get('momentum_buffer', torch.zeros_like(d_p))
                    buf.mul_(group['momentum']).add_(d_p)
                    d_p = buf
                p.sub_(d_p * group['lr'])
        return loss

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, torch.nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (torch.nn.BatchNorm2d, torch.nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, torch.nn.Parameter):
                g1.append(v.weight)
        opt = CustomSGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = CustomSGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt
```

