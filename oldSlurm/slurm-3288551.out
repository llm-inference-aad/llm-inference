import torch.nn as nn
from torch.nn import functional as F

def pad_num_x(k_s):
    pad_per_side = int((k_s-1)*0.5)
    return pad_per_side
    
class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.expansion = 2
        cexp = cin * self.expansion
        self.pw1 = nn.Conv2d(cin, cexp, 1, 1, bias=False)
        self.gn1 = nn.GroupNorm(32, cexp)
        self.act1 = nn.Mish()
        self.dw1 = nn.Conv2d(cexp, cexp, dw_s, 1, pad_num_x(dw_s), groups=cexp)
        if is_LN:
            self.seln = SE_LN(cexp)
        else:
            self.seln = SE(cexp,3)
            
        self.pw2 = nn.Conv2d(cexp, cin, 1, 1, bias=False)
        self.gn2 = nn.GroupNorm(32, cin)
        self.act2 = nn.Mish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)

    def forward(self, x):
        y = x
        x = self.pw1(x)
        x = self.gn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += y
        
        x = self.pw2(x)       
        x = self.gn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        return x 
