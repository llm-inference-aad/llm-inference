```python
import torch
import torch.nn as nn
from torch import Tensor

def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DFSEBV2(nn.Module):
    def __init__(self, cin: int, dw_s: int, is_LN: bool):
        super(DFSEBV2, self).__init__()
        self.pw1 = nn.Conv2d(cin, cin, kernel_size=1, stride=1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU(inplace=True)
        
        self.dw1 = nn.Conv2d(
            cin, cin, kernel_size=dw_s, 
            stride=1, padding=pad_num_x(dw_s),
            groups=cin, bias=False
        )
        
        self.seln = SE_LN(cin) if is_LN else SE(cin, 3)
        
        self.pw2 = nn.Conv2d(cin, cin, kernel_size=1, stride=1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish(inplace=True)
        
        self.dw2 = nn.Conv2d(
            cin, cin, kernel_size=dw_s,
            stride=1, padding=pad_num_x(dw_s),
            groups=cin, bias=False
        )

    def forward(self, x: Tensor) -> Tensor:
        identity = x.clone()
        
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += identity
        
        x = self.pw2(x)
        x = self.bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += identity
        
        return x
```

