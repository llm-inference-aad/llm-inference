class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 24)  # Increased initial channels
        self.DFSEB1 = DFSEBV2(24, [1,2,4], True)  # Changed dilations
        self.EVE = EVE(24, 96)  
        self.DFSEB2 = DFSEBV2(96, [1,2,4], True)  # Changed dilations
