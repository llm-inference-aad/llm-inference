import torch.nn as nn
from torch import Tensor

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool_pw_bn = nn.Sequential(
            nn.MaxPool2d(2, ceil_mode=True),
            nn.Conv2d(cin, cout, 1, 1, bias=False),
            nn.BatchNorm2d(cout)
        )

