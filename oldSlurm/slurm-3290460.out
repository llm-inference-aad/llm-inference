import torch
import torch.nn as nn
from torch.nn import functional as F

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.avgpool = nn.AvgPool2d(2, ceil_mode=True)
        
        # Main pathway with depth-wise separable convolutions
        self.dw = nn.Conv2d(cin, cin, 3, padding=1, groups=cin, bias=False)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        
        #残差连接
        self.residual = nn.Sequential(
            nn.Conv2d(cin, cout, 1, stride=1),
            nn.BatchNorm2d(cout)
        )
        
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout2d(0.2)
        self.activation = nn.ReLU(inplace=True)
    
    def forward(self, x):
        # Pooling with learned combination
        max_pooled = self.maxpool(x)
        avg_pooled = self.avgpool(x)
        pooled = torch.cat([max_pooled, avg_pooled], dim=1)
        
        # Depth-wise separable convolution
        x = self.dw(pooled)
        x = self.pw(x)
        
        # Add residual connection
        residual = self.residual(pooled[:, :x.size(1),...])
        x += residual

