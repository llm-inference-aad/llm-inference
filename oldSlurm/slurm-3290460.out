import torch
import torch.nn as nn
from torch.utils.checkpoint import checkpoint

def create_conv(in_ch, out_ch, kernel_size=3, stride=1, padding=1):
    return nn.Conv2d(in_ch, out_ch, kernel_size, stride, padding)

def efficient_forward(module, x):
    return checkpoint(module, x)

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)
        
        # Add memory-efficient layers
        self.conv_skip = create_conv(img_channels, 384)
        self.norm = nn.BatchNorm2d(384)
        self.act = nn.ReLU(inplace=True)
        
    def forward(self, x):
        x = efficient_forward(self.FCT, x)
        x = efficient_forward(self.DFSEB1, x)
        x = efficient_forward(self.EVE, x)
        x = efficient_forward(self.DFSEB2, x)
        x = efficient_forward(self.ME3, x)
        x = efficient_forward(self.DFSEB3, x)
        x = efficient_forward(self.ME4, x)
        x = efficient_forward(self.DFSEB4, x)
        x = efficient_forward(self.ME5, x)
        x = efficient_forward(self.DFSEB5, x)
        x = efficient_forward(self.DW, x)
        
        # Add skip connection for stability
        shortcut = self.conv_skip(x)
        x = self.norm(x + shortcut)
        x = self.act(x)
        
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x
