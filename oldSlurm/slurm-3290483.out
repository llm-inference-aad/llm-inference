```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to extract patches and then apply min
        *other_shape, h, w = x.shape
        x_unfolded = x.unfold(2, self.ks, self.ks).unfold(3, self.ks, self.ks)
        x_min = x_unfolded.min(dim=-1)[0].min(dim=-1)[0]
        if self.ceil_mode:
            pad_h = (h + self.ks - 1) // self.ks * self.ks - h
            pad_w = (w + self.ks - 1) // self.ks * self.ks - w
            if pad_h > 0 or pad_w > 0:
                x_min = F.pad(x_min, (pad_w//2, pad_w - pad_w//2, pad_h//2, pad_h - pad_h//2))
        return x_min

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_dw = self.dw(x)
        x_concat = torch.cat((x_max, x_min, x_dw), dim=1)
        x_pw = self.pw(x_concat)
        x_bn = self.bn(x_pw)
        return x_bn
```

