```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to extract patches and then apply min
        *other_dims, h, w = x.shape
        k = self.ks
        pad_h = (k - 1) // 2 if self.ceil_mode else 0
        pad_w = (k - 1) // 2 if self.ceil_mode else 0
        x_padded = F.pad(x, (pad_w, pad_w, pad_h, pad_h))
        
        patches = x_padded.unfold(2, k, 1).unfold(3, k, 1)
        min_vals, _ = patches.view(*other_dims, h, w, k*k).min(dim=-1)
        return min_vals

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        # Compute both pools in parallel
        mp = self.maxpool(x)
        mip = self.minpool(x)
        x = torch.cat((mp, mip), dim=1)
        x = self.pw(x)
        x = self.bn(x)
        return x
```

