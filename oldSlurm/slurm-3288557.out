class SE_LN(nn.Module):
    def __init__(self, cin, reduction_ratio=16):
        super().__init__()
        self.reduction = cin // reduction_ratio
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, self.reduction)
        self.fc2 = nn.Linear(self.reduction, cin)
        self.ln = nn.LayerNorm(cin)
        self.relu = nn.ReLU(inplace=True)
        self.sigmoid = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.ln(x)
        x = self.sigmoid(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

