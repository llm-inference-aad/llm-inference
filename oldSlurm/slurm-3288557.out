import torch
import torch.nn as nn
from torch.nn import functional as F

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout2d(p=0.2)
        self.act = nn.Hardswish(inplace=True)
        
        # Initialize weights using He initialization for ReLU (approximation for Hardswish)
        nn.init.kaiming_normal_(self.pw.weight, mode='fan_out', nonlinearity='relu')
        if self.bn is not None:
            nn.init.constant_(self.bn.weight, 1)
            nn.init.constant_(self.bn.bias, 0)

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = self.dropout(x)  # Added dropout for regularization
        x = self.act(x)      # Added activation function
        return x
```

