        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return F.avg_pool2d(x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, padding=0, groups=2, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout2d(p=0.2)
        self.relu = nn.ReLU(inplace=True)

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x)
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        x = self.dropout(x)
        x = self.relu(x)
