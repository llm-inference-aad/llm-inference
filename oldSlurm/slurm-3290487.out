import torch
import torch.nn as nn
import math

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        # Added a learnable linear layer
        self.fc = nn.Linear(cin, cin)
        self.ln = nn.LayerNorm(cin)
        # Changed activation from Sigmoid to Hardsigmoid
        self.act = nn.Hardsigmoid()
        
        # Initialize the new linear layer with He initialization
        nn.init.kaiming_normal_(self.fc.weight, mode='fan_in', nonlinearity='leaky_relu')
        if self.fc.bias is not None:
            fan_in = self.fc.weight.size(1)
            bound = 1 / math.sqrt(fan_in)
            nn.init.uniform_(self.fc.bias, -bound, bound)
    
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)  # Apply the learnable transformation
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

