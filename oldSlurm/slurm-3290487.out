import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode
        self.avgpool = nn.AvgPool2d(ks, ceil_mode=ceil_mode)

    def forward(self, x):
        min_pool = -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)
        avg_pool = self.avgpool(x)
        return torch.where(min_pool > avg_pool, min_pool, avg_pool)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout2d(p=0.1)
        self.activation = nn.ReLU(inplace=True)

    def forward(self, x):
        max_out = self.maxpool(x)
        min_out = self.minpool(x)
        dw_out = self.dw(x)
        
        concatenated = torch.cat((max_out, min_out, dw_out), dim=1)
        concatenated = self.dropout(concatenated)
        
        out = self.pw(concatenated)
        out = self.bn(out)
        out = self.activation(out)
        return out
```

