import torch
import torch.nn as nn
from torch.nn import functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.cin = cin
        self.ratio = ratio
        
        # Create adaptive average pooling layer
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        
        # Define fully connected layers with batch normalization
        self.fc1 = nn.Linear(cin, int(cin / ratio), bias=False)
        self.bn1 = nn.BatchNorm1d(int(cin / ratio))
        self.act1 = nn.ReLU(inplace=True)
        
        self.fc2 = nn.Linear(int(cin / ratio), cin, bias=False)
        self.bn2 = nn.BatchNorm1d(cin)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        # Store input for later multiplication
        y = x
        
        # Global average pooling
        x = self.gavg(x)
        
        # Flatten the spatial dimensions
        x = x.view(-1, self.cin)
        
        # First fully connected layer with BN and activation
        x = self.fc1(x)
        x = self.bn1(x)
        x = self.act1(x)
        
        # Second fully connected layer with BN and activation
        x = self.fc2(x)
        x = self.bn2(x)
        x = self.act2(x)
        
        # Reshape for element-wise multiplication
        x = x.view(-1, self.cin, 1, 1)
        
        # Channel-wise attention
        return x * y

