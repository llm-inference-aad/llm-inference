def get_optimizer(model, lr, weight_decay=0.0001, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
