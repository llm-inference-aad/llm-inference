import torch
import torch.nn as nn
from torch.utils.checkpoint import checkpoint

def create_conv(in_ch, out_ch, kernel_size=3, stride=1, padding=1):
    return nn.Conv2d(in_ch, out_ch, kernel_size, stride, padding)

def efficient_forward(module, x):
    if module.training and torch.is_grad_enabled():
        return checkpoint(module, x)
    return module(x)

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)
        
        # Add gradient checkpointing for memory efficiency
        self.use_checkpointing = False
        
    def enable_checkpointing(self):
        self.use_checkpointing = True
        
    def disable_checkpointing(self):
        self.use_checkpointing = False
        
    def _forward_block(self, x, modules):
        for module in modules:
            x = efficient_forward(module, x)
        return x
    
    def forward(self, x):
        x = self._forward_block(x, [self.FCT, self.DFSEB1])
        x = self._forward_block(x, [self.EVE, self.DFSEB2])
        x = self._forward_block(x, [self.ME3, self.DFSEB3])
        x = self._forward_block(x, [self.ME4, self.DFSEB4])
        x = self._forward_block(x, [self.ME5, self.DFSEB5])
        x = self._forward_block(x, [self.DW])
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x
