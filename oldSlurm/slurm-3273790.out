import torch
from torch import optim as optim
import torch.nn as nn
from torch.optim.optimizer import Optimizer
from typing import Any, Callable, Dict, List, Optional, Tuple, Union

class Lookahead(Optimizer):
    def __init__(self, base_optimizer, alpha=0.5, k=6):
        self.base_optimizer = base_optimizer
        self.param_groups = self.base_optimizer.param_groups
        self.alpha = alpha
        self.k = k
        self.step_counter = 0
        super().__init__(self.param_groups)

    @torch.no_grad()
    def step(self, closure=None):
        loss = None
        if closure is not None:
            loss = closure()

        self.base_optimizer.step(closure)
        self.step_counter += 1

        if self.step_counter % self.k == 0:
            for group in self.param_groups:
                for p in group['params']:
                    param_state = self.state[p]
                    if 'lookahead_params' not in param_state:
                        param_state['lookahead_params'] = torch.zeros_like(p.data)
                    param_state['lookahead_params'].mul_(1 - self.alpha).add_(self.alpha * p.data)
                    p.data.copy_(param_state['lookahead_params'])

        return loss

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        
        base_opt = optim.SGD(g0, lr, 0.9, nesterov=nesterov)
        base_opt.add_param_group({'params': g1, 'weight_decay': weight_decay})
        base_opt.add_param_group({'params': g2})

        opt = Lookahead(base_opt, alpha=0.5, k=6)
    else:
        base_opt = optim.SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
        opt = Lookahead(base_opt, alpha=0.5, k=6)
    return opt
```

