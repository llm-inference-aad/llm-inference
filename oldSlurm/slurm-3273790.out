import torch
from torch import nn
from torch.optim import SGD
from torch.optim.lr_scheduler import CosineAnnealingLR
from torch.nn.utils import clip_grad_norm_
from functools import partial

class OptimizerWrapper:
    def __init__(self, optimizer, max_norm=None):
        self.optimizer = optimizer
        self.max_norm = max_norm
        
    def step(self, closure=None):
        if self.max_norm is not None:
            clip_grad_norm_(self.optimizer.param_groups[0]['params'], self.max_norm)
        self.optimizer.step(closure)
    
    def zero_grad(self, set_to_none=False):
        self.optimizer.zero_grad(set_to_none)

def get_optimizer(model, lr, weight_decay=0, nesterov=True, max_norm=None, scheduler_params=None):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        
        opt = SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], 
                  lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    
    opt = OptimizerWrapper(opt, max_norm=max_norm)
    
    if scheduler_params:
        scheduler = CosineAnnealingLR(opt.optimizer, **scheduler_params)
        opt.scheduler = scheduler
    
    return opt
