        padding = pad_num_y(dw_s)
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, padding, groups=cin)
        self.act = nn.Hardswish()
        self.dropout = nn.Dropout2d(p=0.1)

    def forward(self, x):
        x = self.dw(x)
        x = self.act(x)
        x = self.dropout(x)
        return x
