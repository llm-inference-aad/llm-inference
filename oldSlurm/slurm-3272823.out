def pad_num_y(k_s):
    pad_per_side = (k_s - 1) // 2 if k_s % 2 == 1 else (k_s // 2 - 1, k_s // 2)
    return pad_per_side if isinstance(pad_per_side, tuple) else pad_per_side
    
class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        padding = pad_num_y(dw_s)
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, padding, groups=cin)
        self.act = nn.Hardswish()
        self.dropout = nn.Dropout2d(p=0.1)

    def forward(self, x):
        x = self.dw(x)
        x = self.act(x)
        x = self.dropout(x)
        return x

