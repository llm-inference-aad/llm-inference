        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        self.dropout = nn.Dropout(0.2)
        self.mish = nn.Mish()
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.sigmoid = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.dropout(x)
        x = self.mish(x)
        x = self.fc2(x)
        x = self.sigmoid(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
```

************************************************************
*                      CODE FROM LLM                       *
************************************************************
import torch.nn as nn
import torch

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        self.dropout = nn.Dropout(0.2)
        self.mish = nn.Mish()
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.sigmoid = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.dropout(x)
        x = self.mish(x)
        x = self.fc2(x)
        x = self.sigmoid(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y

