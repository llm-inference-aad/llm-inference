import math
import torch.nn as nn

def pad_num_y(k_s):
    pad_total = k_s - 1
    pad_left = int(math.floor(pad_total / 2))
    pad_right = pad_total - pad_left
    return (pad_left, pad_right)

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s)[0], groups=cin)
        self.bn = nn.BatchNorm2d(cin)
        self.act = nn.Mish(inplace=True)

    def forward(self, x):
        x = self.dw(x)
        x = self.bn(x)
        x = self.act(x)
        return x
```

This modified version includes:
1. A more precise padding calculation
2. Added BatchNorm for stability
3. Replaced Hardswish with Mish activation
4. Maintained original interface and functionality
5. Works with default settings without additional configuration

