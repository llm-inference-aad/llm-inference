import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))  
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y 

# Example usage:
if __name__ == "__main__":
    model = SE_LN(cin=64)
    input_tensor = torch.randn(1, 64, 32, 32)  # batch_size=1, channels=64, height=32, width=32
    output = model(input_tensor)
    print(output.shape)  # Should be [1, 64, 32, 32]
```

