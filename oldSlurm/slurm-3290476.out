```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using kthvalue to find minimum directly
        unfold = x.unfold(2, self.kernel_size, self.kernel_size).unfold(3, self.kernel_size, self.kernel_size)
        min_vals, _ = unfold.flatten(-2, -1).min(dim=-1)
        return min_vals.view(*x.size()[:2], (x.size(2)-self.kernel_size+1)//1, (x.size(3)-self.kernel_size+1)//1)

class FCT_Optimized(nn.Module):
    def __init__(self, cin, cout):
        super(FCT_Optimized, self).__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(3 * cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Initialize weights for better convergence
        for m in self.modules():
            if isinstance(m, nn.Conv2d):
                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')
            elif isinstance(m, nn.BatchNorm2d):
                nn.init.constant_(m.weight, 1)
                nn.init.constant_(m.bias, 0)

    def forward(self, x):
        # Parallel execution of maxpool and dw
        maxpool_out = self.maxpool(x)
        dw_out = self.dw(x)
        
        # Execute minpool
        minpool_out = self.minpool(x)
        
        # Concatenate along channels
        concatenated = torch.cat([maxpool_out, minpool_out, dw_out], dim=1)
        
        # Pointwise convolution and batchnorm
        out = self.pw(concatenated)
        out = self.bn(out)
        
        return out


