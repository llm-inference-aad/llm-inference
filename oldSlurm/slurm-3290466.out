def get_optimizer(model, lr, weight_decay=0.01, nesterov=False):
    opt = torch.optim.AdamW(model.parameters(), lr=lr, betas=(0.9, 0.999), eps=1e-8,
                            weight_decay=weight_decay, amsgrad=False)
    return opt
