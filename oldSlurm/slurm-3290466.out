import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode, stride=2, padding=0):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode
        self.stride = stride
        self.padding = padding

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, self.stride, self.padding, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout, dw_kernel_size=3, dw_stride=1, dw_padding=1,
                 pool_kernel_size=2, bn_momentum=0.1):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_kernel_size, dw_stride, dw_padding, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(pool_kernel_size, ceil_mode=True)
        self.minpool = MinPool2d_y(pool_kernel_size, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout, momentum=bn_momentum)

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x),
            self.dw(x),
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        return x

