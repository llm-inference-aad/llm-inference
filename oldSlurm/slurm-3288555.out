```python
import torch.nn as nn
import math

class SE(nn.Module):
    def __init__(self, cin, ratio=8):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        # Initialize using He initialization
        nn.init.kaiming_normal_(self.fc1.weight.data)
        self.act1 = nn.SiLU()  # Using SiLU instead of ReLU
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        nn.init.kaiming_normal_(self.fc2.weight.data)
        self.dropout = nn.Dropout(0.2)  # Adding dropout for regularization
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout(x)  # Applying dropout
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
```

