import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        # Add a learnable parameter to scale the maxpool output
        self.scale = nn.Parameter(torch.ones(1))
        
    def forward(self, x):
        identity = x  # Keep a copy of the original input
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        # Inject scaled identity into the transformed features
        x += self.scale * identity[:, :, ::2, ::2]
        return x

