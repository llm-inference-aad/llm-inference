def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    param_groups = [
        {'params': [p for p in model.parameters() if p.dim() == 1], 'weight_decay': 0},  # biases
        {'params': [p for p in model.parameters() if p.dim() > 1 and not isinstance(p, (nn.BatchNorm2d, nn.LayerNorm)).weight], 'weight_decay': weight_decay},
        {'params': [p for p in model.parameters() if isinstance(p, (nn.BatchNorm2d, nn.LayerNorm)).weight], 'weight_decay': 0}
    ]
    opt = SGD([g['params'] for g in param_groups], lr, 0.9, nesterov=nesterov)
    return opt
