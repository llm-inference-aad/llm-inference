import torch
import torch.nn as nn
from einops import rearrange

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Adding depth-wise separable convolution
        self.depthwise = nn.Conv2d(cin, cin, 3, padding=1, groups=cin, bias=False)
        self.pointwise = nn.Conv2d(cin, cout, 1, bias=False)
        
        # Adding attention mechanism
        self.attention = nn.Sequential(
            nn.Conv2d(cin, cin//8, 1),
            nn.ReLU(),
            nn.Conv2d(cin//8, cin, 1),
            nn.Sigmoid()
        )
        
        # Adding residual connection
        self.residual = nn.Conv2d(cin, cout, 1, bias=False) if cin!= cout else nn.Identity()

    def forward(self, x):
        # Original path
        orig_x = x
        
        # Depth-wise separable convolution
        x = self.depthwise(x)
        x = self.pointwise(x)
        
        # Attention mechanism
        attn = self.attention(x)
        x = x * attn
        
        # Max pooling
        x_pooled = self.maxpool(x)
        
        # Point-wise convolution and batch norm
        x_pw = self.pw(x_pooled)
        x_bn = self.bn(x_pw)
        
        # Residual connection
        res = self.residual(orig_x)
        res = F.interpolate(res, size=x_bn.size()[2:], mode='bilinear', align_corners=False)
        
        # Combine paths
        x_final = x_bn + res
        
        return x_final
```

