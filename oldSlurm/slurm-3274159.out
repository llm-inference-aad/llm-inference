import torch.optim as optim

def get_optimizer(model, lr, weight_decay=0.01, nesterov=False):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, torch.nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (torch.nn.BatchNorm2d, torch.nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, torch.nn.Parameter):
                g1.append(v.weight)
        opt = optim.SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], 
                        lr=lr, momentum=0.9, nesterov=nesterov, weight_decay=0)
    else:
        opt = optim.SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt
