import torch
import torch.nn as nn

class SE_LN_Optimized(nn.Module):
    def __init__(self, cin):
        super(SE_LN_Optimized, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Sigmoid()

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.squeeze(2).squeeze(2)  # Remove spatial dimensions directly
        x = self.ln(x)
        x = self.act(x)
        x = x.unsqueeze(2).unsqueeze(2)  # Add back spatial dimensions
        return x * y

