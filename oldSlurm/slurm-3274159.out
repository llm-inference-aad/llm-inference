        self.ME5 = ME(96, 192)  
        self.DFSEB5 = DFSEBV2(192, 3, True)
        self.DW = DW(192, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(192, class_num)
                        
    def forward(self, x):
