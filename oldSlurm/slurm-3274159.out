import torch
import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super(SE, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d(1)  # Simplified from (1,1)
        self.fc1 = nn.Linear(cin, int(cin / ratio), bias=False)
        self.act1 = nn.ReLU(inplace=True)  # In-place ReLU for memory efficiency
        self.fc2 = nn.Linear(int(cin / ratio), cin, bias=False)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x).squeeze(3).squeeze(2)  # Efficient view operation
        x = self.fc1(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.unsqueeze(2).unsqueeze(3)  # Efficient view operation
        return x * y

