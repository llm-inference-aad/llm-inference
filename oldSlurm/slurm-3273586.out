import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super().__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode
        
    def forward(self, x):
        # Use unfold to get patches, then take min
        *dims, h, w = x.shape
        kh, kw = self.kernel_size, self.kernel_size
        stride_h, stride_w = 1, 1
        
        # Calculate output dimensions
        out_h = (h - kh) // stride_h + 1
        out_w = (w - kw) // stride_w + 1
        
        if self.ceil_mode:
            pad_h = max((kh - h % kh) % kh, 0)
            pad_w = max((kw - w % kw) % kw, 0)
            x = F.pad(x, (pad_w//2, pad_w - pad_w//2, pad_h//2, pad_h - pad_h//2))
            
        # Unfold and reshape
        x_unf = x.unfold(2, kh, stride_h).unfold(3, kw, stride_w)
        x_unf = x_unf.contiguous().view(*dims, h, w, kh, kw)
        
        # Take min over kernel dimensions
        min_vals, _ = x_unf.min(dim=(-1,-2))
        return min_vals

class DepthWiseSeparableConv2d(nn.Module):
    def __init__(self, in_channels, out_channels, kernel_size=1, stride=1,
                 padding=0, dilation=1, groups=None, bias=False):


