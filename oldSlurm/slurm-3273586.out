        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.bn(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.ln(x)
        x = self.sigmoid(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
