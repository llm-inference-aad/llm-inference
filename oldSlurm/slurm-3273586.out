        self.ME3 = ME(64, 128)           # Increased from 96 to 128
        self.DFSEB3 = DFSEBV2(128, 3, True)
        self.ME4 = ME(128, 256)          # Increased from 192 to 256
        self.DFSEB4 = DFSEBV2(256, 3, True)
        self.ME5 = ME(256, 512)          # Increased from 384 to 512
        self.DFSEB5 = DFSEBV2(512, 3, True)
        self.DW = DW(512, 3)             # Increased from 384 to 512
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.4)       # Decreased from 0.5 to 0.4
        self.fc = nn.Linear(512, class_num)
                        
    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x)
        x = self.EVE(x)
        x = self.DFSEB2(x)
        x = self.ME3(x)
        x = self.DFSEB3(x)
        x = self.ME4(x)
        x = self.DFSEB4(x)
        x = self.ME5(x)
        x = self.DFSEB5(x)
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)

