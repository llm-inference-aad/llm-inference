```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode, return_indices=False)[0]

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_cat = torch.cat((x_max, x_min), dim=1)
        x_pw = self.pw(x_cat)
        x_bn = self.bn(x_pw)
        return x_bn
