import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.squeeze = nn.AdaptiveAvgPool2d(1)
        self.excite = nn.Sequential(
            nn.Conv2d(cin, cin//ratio, 1),
            nn.ReLU(),
            nn.Conv2d(cin//ratio, cin, 1),
            nn.Sigmoid()
        )
    
    def forward(self, x):
        y = self.squeeze(x)
        y = self.excite(y)
        return x * y
```

