```python
import torch
from torch import nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    def group_parameters(module, weight_decay, no_decay_names=None):
        if no_decay_names is None:
            no_decay_names = {'bn', 'ln', 'bias'}
        decay_params = []
        no_decay_params = []
        for name, param in module.named_parameters():
            if not param.requires_grad:
                continue
            if any(nd in name.lower() for nd in no_decay_names):
                no_decay_params.append(param)
            else:
                decay_params.append(param)
        return [{'params': decay_params, 'weight_decay': weight_decay},
                {'params': no_decay_params, 'weight_decay': 0.0}]
    
    if weight_decay!= 0:
        param_groups = group_parameters(model, weight_decay)
        opt = SGD(param_groups, lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt
