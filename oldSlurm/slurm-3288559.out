import torch
from torch import nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    def group_parameters(module):
        params = {'g0': [], 'g1': [], 'g2': []}
        for v in module.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                params['g2'].append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                params['g0'].append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                params['g1'].append(v.weight)
        return params
    
    if weight_decay!= 0:
        grouped_params = group_parameters(model)
        opt = SGD(grouped_params['g0'], lr, 0.9, nesterov=nesterov)
        opt.add_param_group({'params': grouped_params['g1'], 'weight_decay': weight_decay})
        opt.add_param_group({'params': grouped_params['g2']})
    else:
        opt = SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
    return opt

