def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        # Using SE_LN or SE based on is_LN flag
        self.seln = SE_LN(cin) if is_LN else SE(cin, 3)
        
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        # Adding depth-wise separable convolution for better feature extraction
        self.extra_dw = nn.Sequential(
            nn.Conv2d(cin, cin, 3, 1, 1, groups=cin),
            nn.BatchNorm2d(cin),
            nn.ReLU(),
            nn.Conv2d(cin, cin, 1, 1)
        )
        
        # Introducing attention mechanism for improved context awareness
        self.attention = nn.MultiheadAttention(embed_dim=cin, num_heads=4, batch_first=True)
        
        # DropPath for regularization
        self.drop_path = nn.Dropout(0.1)

    def forward(self, x):
        y = x
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += y
        
        # Additional processing branch
        z = self.extra_dw(y)
        
        # Combining features using attention
        B, C, H, W = x.shape
        x_reshaped = x.view(B, C, H*W).permute(0, 2, 1)
        z_reshaped = z.view(B, C, H*W).permute(0, 2, 1)
        attn_out, _ = self.attention(x_reshaped, z_reshaped, z_reshaped)
        attn_out = attn_out.permute(0, 2, 1).view(B, C, H, W)
        
        x = x + self.drop_path(attn_out)
        
        x = self.pw2(x)
        x = self.bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        return x

