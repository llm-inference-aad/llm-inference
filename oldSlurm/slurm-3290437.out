import torch
from torch import nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for module in model.modules():
            if hasattr(module, 'bias') and isinstance(module.bias, nn.Parameter):
                g2.append(module.bias)
            if isinstance(module, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(module.weight)
            elif hasattr(module, 'weight') and isinstance(module.weight, nn.Parameter):
                g1.append(module.weight)
        
        opt = SGD([{'params': g0}], lr, 0.9, nesterov=nesterov)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})
        opt.add_param_group({'params': g2})
    else:
        opt = SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
    return opt

