import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.depthwise_conv = nn.Conv2d(cin, cin, kernel_size=3, padding=1, groups=cin, bias=False)
        self.pointwise_conv1 = nn.Conv2d(cin, int(cin/ratio), kernel_size=1, bias=False)
        self.act1 = nn.SiLU()  # Using SiLU (Swish) activation
        self.pointwise_conv2 = nn.Conv2d(int(cin/ratio), cin, kernel_size=1, bias=False)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = self.depthwise_conv(x)
        x = self.pointwise_conv1(x)
        x = self.act1(x)
        x = self.pointwise_conv2(x)
        x = self.act2(x)
        x = x * y
        return x
```

