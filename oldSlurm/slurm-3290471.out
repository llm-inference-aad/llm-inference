import torch
import torch.nn as nn
from torch.nn import functional as F

def pad_num_y(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DepthwiseConv(nn.Module):
    def __init__(self, cin, kernel_size):
        super(DepthwiseConv, self).__init__()
        self.conv = nn.Conv2d(
            in_channels=cin,
            out_channels=cin,
            kernel_size=kernel_size,
            stride=1,
            padding=pad_num_y(kernel_size),
            groups=cin,
            bias=False
        )
        self.bn = nn.BatchNorm2d(cin)
        self.act = nn.Hardswish(inplace=True)

    def forward(self, x):
        x = self.conv(x)
        x = self.bn(x)
        x = self.act(x)
        return x

class EfficientDepthwiseBlock(nn.Module):
    def __init__(self, cin, kernel_size, expansion_ratio=1.0):
        super(EfficientDepthwiseBlock, self).__init__()
        self.expansion = int(cin * expansion_ratio)
        
        self.depthwise = DepthwiseConv(self.expansion, kernel_size)
        
        self.pointwise = nn.Sequential(
            nn.Conv2d(self.expansion, cin, 1, 1, 0, bias=False),
            nn.BatchNorm2d(cin)
        )

    def forward(self, x):
        identity = x
        x = F.hardswish(self.depthwise(x))
        x = self.pointwise(x)
        x += identity
        return x

class ImprovedDW(nn.Module):
    def __init__(self, cin, dw_s):
        super(ImprovedDW, self).__init__()
        self.block = EfficientDepthwiseBlock(cin, dw_s, expansion_ratio=1.2)

    def forward(self, x):
        return self.block(x)

