```python
import torch.nn as nn
import torch.nn.init as init

class SE(nn.Module):
    def __init__(self, cin, ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin//ratio), bias=False)
        self.act1 = nn.GELU()
        self.dropout1 = nn.Dropout(0.2)
        self.fc2 = nn.Linear(int(cin//ratio), cin, bias=False)
        self.dropout2 = nn.Dropout(0.2)
        self.act2 = nn.Sigmoid()
        
        # Initialize weights using He initialization
        init.kaiming_normal_(self.fc1.weight, mode='fan_in', nonlinearity='gelu')
        init.kaiming_normal_(self.fc2.weight, mode='fan_in', nonlinearity='sigmoid')
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout1(x)
        x = self.fc2(x)
        x = self.dropout2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
