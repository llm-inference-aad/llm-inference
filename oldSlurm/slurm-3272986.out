import torch
import torch.nn as nn
from torch.nn import functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio=16):
        super(SE, self).__init__()
        self.cin = cin
        self.ratio = ratio
        
        # Global average pooling layer
        self.gap = nn.AdaptiveAvgPool2d(1)
        
        # Two fully connected layers with ReLU activation
        self.fc1 = nn.Linear(cin, max(1, cin // ratio), bias=True)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(max(1, cin // ratio), cin, bias=True)
        
        # Sigmoid activation for attention weights
        self.sigmoid = nn.Sigmoid()
    
    def forward(self, x):
        # Original input tensor
        n, c, h, w = x.size()
        
        # Global average pooling
        y = self.gap(x).view(n, c)
        
        # First fully connected layer with ReLU
        y = self.fc1(y)
        y = self.relu(y)
        
        # Second fully connected layer with sigmoid
        y = self.fc2(y)
        y = self.sigmoid(y)
        
        # Reshape attention weights and apply to input
        y = y.view(n, c, 1, 1)
        out = x * y.expand_as(x)
        
        return out
    
    def _initialize_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.kaiming_normal_(m.weight.data, mode='fan_out', nonlinearity='relu')
                if m.bias is not None:
                    m.bias.data.zero_()
            elif isinstance(m, nn.Conv2d):
                nn.init.kaiming_normal_(m.weight.data, mode='fan_out', nonlinearity='relu')
                if m.bias is not None:
                    m.bias.data.zero_()
            elif isinstance(m, nn.BatchNorm2d):
                m.weight.data.fill_(1)
                m.bias.data.zero_()

