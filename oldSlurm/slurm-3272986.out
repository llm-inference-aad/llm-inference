import torch.nn as nn
import torch.nn.functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super(SE, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        self.bn1 = nn.BatchNorm1d(int(cin/ratio))
        self.act1 = nn.SiLU()  # Improved activation
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.bn2 = nn.BatchNorm1d(cin)
        self.act2 = nn.Sigmoid()
        self.dropout = nn.Dropout(0.2)
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.bn2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y + y  # Residual connection added
```

