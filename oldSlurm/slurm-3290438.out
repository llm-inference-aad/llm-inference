import torch
import torch.nn as nn
import torch.nn.functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super(SE, self).__init__()
        self.cin = cin
        self.ratio = ratio
        
        # Global average pooling layer
        self.gavg = nn.AdaptiveAvgPool2d((1, 1))
        
        # First fully connected layer
        self.fc1 = nn.Linear(cin, int(cin / ratio), bias=False)
        self.bn1 = nn.BatchNorm1d(int(cin / ratio))  # Added batch normalization
        self.act1 = nn.ReLU(inplace=True)
        
        # Second fully connected layer
        self.fc2 = nn.Linear(int(cin / ratio), cin, bias=False)
        self.bn2 = nn.BatchNorm1d(cin)  # Added batch normalization
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        # Store input tensor for later multiplication
        y = x
        
        # Apply global average pooling
        x = self.gavg(x)
        
        # Flatten the tensor
        x = x.view(-1, self.cin)
        
        # First fully connected layer with activation
        x = self.fc1(x)
        x = self.bn1(x)  # Batch normalization after FC1
        x = self.act1(x)
        
        # Second fully connected layer with activation
        x = self.fc2(x)
        x = self.bn2(x)  # Batch normalization after FC2
        x = self.act2(x)
        
        # Reshape and multiply with input tensor
        x = x.view(-1, self.cin, 1, 1)
        return x * y
```

