import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Use max pooling on negated input and then negate back
        return -F.max_pool2d(-x, self.kernel_size, ceil_mode=self.ceil_mode)

class MaxMinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MaxMinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        max_pooled = F.max_pool2d(x, self.kernel_size, ceil_mode=self.ceil_mode)
        min_pooled = -F.max_pool2d(-x, self.kernel_size, ceil_mode=self.ceil_mode)
        return torch.cat((max_pooled, min_pooled), dim=1)

class OptimizedEVE(nn.Module):
    def __init__(self, cin, cout):
        super(OptimizedEVE, self).__init__()
        self.combined_pool = MaxMinPool2d(2, ceil_mode=True)
        self.depthwise_conv = nn.Conv2d(cin, 2*cin, 3, padding=1, groups=cin, bias=False)
        self.pointwise_conv = nn.Conv2d(2*cin, cout, 1, bias=False)
        self.batch_norm = nn.BatchNorm2d(cout)

    def forward(self, x):
        x = self.depthwise_conv(x)
        x = self.combined_pool(x)
        x = self.pointwise_conv(x)
        x = self.batch_norm(x)
        return x

