import torch
import torch.nn as nn
from torch.utils.checkpoint import checkpoint

class GradientCheckpointModule(nn.Module):
    def __init__(self, module):
        super().__init__()
        self.module = module
        
    def forward(self, x):
        return checkpoint(self.module, x)

class AttentionBlock(nn.Module):
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.qkv = nn.Conv2d(in_channels, out_channels * 3, kernel_size=1)
        self.softmax = nn.Softmax(dim=-1)
        
    def forward(self, x):
        B, C, H, W = x.shape
        qkv = self.qkv(x).view(B, 3, C, -1)
        q, k, v = qkv[0], qkv[1], qkv[2]
        attn = (q @ k.transpose(-2, -1)) * (C ** -0.5)
        attn = self.softmax(attn)
        out = (attn @ v).view(B, C, H, W)
        return out

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = GradientCheckpointModule(DFSEBV2(12, 3, True))
        self.EVE = EVE(12, 48)
        self.DFSEB2 = GradientCheckpointModule(DFSEBV2(48, 3, True))
        self.ME3 = ME(48, 96)
        self.DFSEB3 = GradientCheckpointModule(DFSEBV2(96, 3, True))
        self.ME4 = ME(96, 192)
        self.DFSEB4 = GradientCheckpointModule(DFSEBV2(192, 3, True))
        self.ME5 = ME(192, 384)
        self.DFSEB5 = GradientCheckpointModule(DFSEBV2(384, 3, True))
        self.DW = DW(384, 3)
        self.attn = AttentionBlock(384, 384)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.norm = nn.LayerNorm(384)
       

