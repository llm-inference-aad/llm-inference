import torch
import torch.nn as nn
from torch.utils.checkpoint import checkpoint

class GradientCheckpointModule(nn.Module):
    def __init__(self, module):
        super().__init__()
        self.module = module
        
    def forward(self, x):
        return checkpoint(self.module, x)

class AttentionBlock(nn.Module):
    def __init__(self, in_channels, out_channels):
        super().__init__()
        self.qkv = nn.Conv2d(in_channels, out_channels * 3, kernel_size=1)
        self.softmax = nn.Softmax(dim=-1)
        
    def forward(self, x):
        B, C, H, W = x.shape
        qkv = self.qkv(x).view(B, 3, C, -1)
        q, k, v = qkv[0], qkv[1], qkv[2]
        attn = (q @ k.transpose(-2, -1)) * (C ** -0.5)
        attn = self.softmax(attn)
        out = (attn @ v).view(B, C, H, W)
        return out

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
