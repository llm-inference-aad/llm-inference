import torch
import torch.nn as nn
import torch.nn.functional as F

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.conv1 = nn.Conv2d(cin, cin//2, kernel_size=1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin//2)
        self.conv2 = nn.Conv2d(cin//2, cin, kernel_size=1, bias=False)
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Sequential(
            nn.ReLU(inplace=True),
            nn.Sigmoid()
        )
    
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = self.conv1(x)
        x = self.bn1(x)
        x = self.conv2(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y + y

