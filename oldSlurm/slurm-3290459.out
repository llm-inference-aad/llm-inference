```python
def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    param_groups = []
    
    # Group parameters using dictionary comprehension for efficiency
    groups = {
        'g0': [v.weight for v in model.modules() 
               if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm))],
        'g1': [v.weight for v in model.modules()
               if hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter) 
               and not isinstance(v, (nn.BatchNorm2d, nn.LayerNorm))],
        'g2': [v.bias for v in model.modules()
               if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter)]
    }
    
    # Create optimizer with grouped parameters
    if weight_decay!= 0:
        opt = SGD(groups['g0'], lr, 0.9, nesterov=nesterov)
        opt.add_param_group({'params': groups['g1'], 'weight_decay': weight_decay})
        opt.add_param_group({'params': groups['g2']})
    else:
        opt = SGD([p for group in groups.values() for p in group], lr, 0.9, nesterov=nesterov)
    
    return opt
```

