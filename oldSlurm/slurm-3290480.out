import torch
import torch.nn as nn
from torch.nn import functional as F

class MultiScalePool(nn.Module):
    def __init__(self, kernel_sizes=[(1,1),(3,3)]):
        super().__init__()
        self.pools = [nn.AdaptiveAvgPool2d(k) for k in kernel_sizes]
        self.conv = nn.Conv2d(len(kernel_sizes)*cin, cin, 1, bias=False)

    def forward(self, x):
        pools = []
        for pool in self.pools:
            pools.append(pool(x).view(x.size(0), -1))
        x = torch.cat(pools, dim=1)
        x = self.conv(x.view(x.size(0), -1, 1, 1))
        return x

class DepthWiseSeparableConv(nn.Module):
    def __init__(self, channels, kernel_size=3, stride=1):
        super().__init__()
        self.depthwise = nn.Conv2d(channels, channels, kernel_size,
                                   stride=stride, padding=kernel_size//2,
                                   groups=channels, bias=False)
        self.pointwise = nn.Conv2d(channels, channels, 1, bias=False)
        self.norm = nn.BatchNorm2d(channels)
        self.act = nn.ReLU()

    def forward(self, x):
        x = self.depthwise(x)
        x = self.pointwise(x)
        x = self.norm(x)
        x = self.act(x)
        return x

class ImprovedSE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.mspool = MultiScalePool()
        self.fc1 = nn.Linear(cin*2, int(cin/ratio), bias=False)
        self.attention = nn.MultiheadAttention(int(cin/ratio), num_heads=4)
        self.fc2 = nn.Linear(int(cin/ratio), cin, bias=False)
        self.act = nn.SiLU()
        self.residual = nn.Sequential(
            nn.Conv2d(cin, cin, 1),
            nn.BatchNorm2d(cin)
        )
        self.dwc = DepthWiseSeparableConv(cin)

    def forward(self, x):
        identity = x
        x = self.mspool(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x, _ = self.attention(x.unsqueeze(0), x.unsqueeze(0), x.unsqueeze(0))
        x = x.squeeze(0)
        x = self.act(x)
        x = self.fc2(x)
        x = x.view(-1, x.size(1), 1, 1)
        x = torch.sigmoid(x) * identity
        x = self.dwc(x)
        x += self.residual(identity)
        return x
```

