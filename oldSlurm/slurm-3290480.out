class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=False)  # Changed ceil_mode to False
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=True)  # Changed bias to True
        self.bn = nn.BatchNorm2d(cout, momentum=0.05, eps=1e-4)  # Adjusted momentum and eps
        self.relu = nn.ReLU(inplace=True)  # Added ReLU activation

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = self.relu(x)  # Included ReLU in forward pass
        return x
```

