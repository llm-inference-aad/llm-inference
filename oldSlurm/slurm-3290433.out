```python
import torch.nn as nn

def pad_num_y(k_s):
    pad_per_side = (k_s - 1) // 2
    return pad_per_side

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super(DW, self).__init__()
        self.dw = nn.Conv2d(
            cin, cin, dw_s, 
            stride=1, 
            padding=pad_num_y(dw_s),
            groups=cin,
            bias=False
        )
        # Initialize weights using He initialization
        nn.init.kaiming_normal_(self.dw.weight, mode='fan_out')
        self.act = nn.Hardsigmoid()  # More memory-efficient alternative

    def forward(self, x):
        x = self.dw(x)
        x = self.act(x)
        return x
```

