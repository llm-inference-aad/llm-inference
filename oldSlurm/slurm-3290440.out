import torch.optim as optim
from torch.optim import SGD
from torch.nn import Module, Parameter, BatchNorm2d, LayerNorm

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        param_groups = [
            {'params': [], 'weight_decay': 0},  # No decay for BN and LN weights
            {'params': [], 'weight_decay': weight_decay},  # Decay for other weights
            {'params': []}  # Biases
        ]
        
        for module in model.modules():
            if isinstance(module, (BatchNorm2d, LayerNorm)):
                if module.weight is not None and isinstance(module.weight, Parameter):
                    param_groups[0]['params'].append(module.weight)
            elif hasattr(module, 'weight') and isinstance(module.weight, Parameter):
                param_groups[1]['params'].append(module.weight)
            if hasattr(module, 'bias') and isinstance(module.bias, Parameter):
                param_groups[2]['params'].append(module.bias)
        
        opt = SGD(param_groups, lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt
```

