import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        self.act1 = nn.Mish()  # Using Mish instead of ReLU
        self.dropout = nn.Dropout(0.2)  # Adding dropout for regularization
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.bn = nn.BatchNorm2d(cin)  # Adding batch normalization
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout(x)  # Applying dropout
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        x = self.bn(x)  # Applying batch norm before scaling
        return x * y

