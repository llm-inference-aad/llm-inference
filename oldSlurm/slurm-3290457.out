import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to create sliding windows
        x_unfolded = x.unfold(2, self.kernel_size, self.kernel_size).unfold(3, self.kernel_size, self.kernel_size)
        # Reshape to prepare for min operation
        x_reshaped = x_unfolded.contiguous().view(*x_unfolded.size()[:2], -1, x_unfolded.size()[3])
        # Compute min along the last dimension
        min_vals, _ = x_reshaped.min(dim=-1)
        # Reshape back to original dimensions
        output_shape = list(x.shape)
        output_shape[2] = (output_shape[2] // self.kernel_size) + (1 if self.ceil_mode and output_shape[2] % self.kernel_size!=0 else 0)
        output_shape[3] = (output_shape[3] // self.kernel_size) + (1 if self.ceil_mode and output_shape[3] % self.kernel_size!=0 else 0)
        min_vals = min_vals.view(*output_shape)
       

