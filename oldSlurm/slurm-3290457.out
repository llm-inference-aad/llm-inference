import torch
import torch.nn as nn
from torch.nn import functional as F

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Adding depth-wise separable convolution for efficiency
        self.depthwise = nn.Conv2d(cin, cin, 3, padding=1, groups=cin, bias=False)
        self.pointwise = nn.Conv2d(cin, cout, 1, bias=False)
        self.bn_depth = nn.BatchNorm2d(cin)
        self.bn_point = nn.BatchNorm2d(cout)
        
        # Attention mechanism for better feature selection
        self.attention = nn.Sequential(
            nn.Conv2d(cin, cin//8, 1),
            nn.ReLU(),
            nn.Conv2d(cin//8, cin, 1),
            nn.Sigmoid()
        )
        
        #残差连接
        if cin!= cout:
            self.shortcut = nn.Sequential(
                nn.Conv2d(cin, cout, 1, bias=False),
                nn.BatchNorm2d(cout)
            )
        else:
            self.shortcut = None
            
        # DropPath for regularization
        self.drop_path = DropPath(drop_prob=0.1)

    def forward(self, x):
        identity = x
        
        # Depth-wise separable convolution branch
        x_d = self.depthwise(x)
        x_d = self.bn_depth(x_d)
        x_d = F.relu(x_d)
        x_d = self.pointwise(x_d)
        x_d = self.bn_point(x_d)
        
        # Original maxpool branch
        x_p = self.maxpool(x)
        x_p = self.pw(x_p)
        x_p = self.bn(x_p)
        
        # Combine features from both branches
        x_combined = torch.cat([x_d, x_p], dim=1)
        
        # Apply attention
        att = self.attention(x_combined)
        x_att = x_combined * att
        
        # Residual connection
        if self.shortcut is not None:
            identity = self.shortcut(identity)
            
        out = x_att + identity
        out = self.drop_path(out)
        return F.relu(out)

# Helper function for DropPath
class DropPath(nn.Module):
    def __init__(self, drop_prob=0.):
        super(DropPath, self).__init__()
        self.drop_prob = drop_prob
        
    def forward(self, x):
        if self.training:
            keep_prob = 1 - self.drop_prob
            mask = torch.cuda.FloatTensor(x.size(0), 1, 1, 1).bernoulli_(keep_prob)
            x.div_(keep_prob)
            x.mul_(mask)
        return x

