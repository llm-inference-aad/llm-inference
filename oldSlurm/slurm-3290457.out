import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return F.max_pool2d(-x, self.kernel_size, ceil_mode=self.ceil_mode) * (-1)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super(FCT, self).__init__()
        self.dw = nn.Conv2d(cin, cin, kernel_size=5, stride=2, padding=2, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(kernel_size=2, ceil_mode=True)
        self.minpool = MinPool2d(kernel_size=2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, kernel_size=1, stride=1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout(p=0.2)
        
    def forward(self, x):
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_dw = self.dw(x)
        x_concat = torch.cat((x_max, x_min, x_dw), dim=1)
        x_pw = self.pw(x_concat)
        x_bn = self.bn(x_pw)
        x_dropout = self.dropout(x_bn)
        return F.relu(x_dropout)

