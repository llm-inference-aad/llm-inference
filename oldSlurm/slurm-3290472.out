                g1.append(module.weight)
        
        opt = SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], 
                  lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt
