import torch.optim.lr_scheduler as lr_scheduler
import torch.nn as nn

def get_optimizer(model, lr, weight_decay=0, nesterov=True, num_warmup_steps=0, num_training_steps=0):
    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)

        opt = SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = SGD(model.parameters(), lr, momentum=0.9, nesterov=nesterov)

    if num_training_steps > 0:
        lr_scheduler_fn = lr_scheduler.OneCycleLR(opt, max_lr=lr, total_steps=num_training_steps, epochs=num_training_steps/len(train_loader), pct_start=0.3, anneal_strategy='cos', cycle_momentum=True, base_momentum=0.85, max_momentum=0.95, div_factor=25.0, final_div_factor=10000.0, last_epoch=-1)
    else:
        lr_scheduler_fn = None

    if num_warmup_steps > 0:
        opt = lr_scheduler.WarmupLinearSchedule(opt, num_warmup_steps=num_warmup_steps, num_training_steps=num_training_steps)

    return opt, lr_scheduler_fn
```

This function now accepts two additional arguments: `num_warmup_steps` and `num_training_steps`. It includes learning rate scheduling using `OneCycleLR` and warmup with `WarmupLinearSchedule`. The function also applies gradient clipping by adding the following line before returning the optimizer:

```python
nn.utils.clip_grad_norm_(model.parameters(), 1.0)
```

