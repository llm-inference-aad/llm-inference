import torch
import torch.nn as nn
import torch.nn.functional as F

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)
        
        # Add attention mechanism
        self.attention = nn.Sequential(
            nn.Conv2d(384, 128, kernel_size=1),
            nn.ReLU(),
            nn.Conv2d(128, 384, kernel_size=1),
            nn.Sigmoid()
        )
        
        # Add residual connections
        self.residual_blocks = nn.ModuleList([
            ResidualBlock(12, 12),
            ResidualBlock(48, 48),
            ResidualBlock(96, 96),
            ResidualBlock(192, 192),
            ResidualBlock(384, 384)
        ])
        
        # Initialize weights
        self.apply(self._initialize_weights)

    def _initialize_weights(self, layer):
        if isinstance(layer, nn.Conv2d):
            nn.init.kaiming_normal_(layer.weight, mode='fan_out', nonlinearity='relu')
            if layer.bias is not None:
                nn.init.constant_(layer.bias, 0)
        elif isinstance(layer, nn.BatchNorm2d):
            nn.init.constant_(layer.weight, 1)
            nn.init.constant_(layer.bias, 0)
        elif isinstance(layer, nn.Linear):
            nn.init.normal_(layer.weight, 0, 0.01)
            nn.init.constant_(layer.bias, 0)

    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x)
        x = self.residual_blocks[0](x)
        x = self.EVE(x)
        x = self.DFSEB2(x)
        x = self.ME3(x)
        x = self.residual_blocks[1](x)
        x = self.DFSEB3(x)
        x = self.ME4(x)
        x = self.residual_blocks[2](x)
        x = self.DFSEB4(x)
        x = self.ME5(x)
        x = self.residual_blocks[3](x)
        x = self.DFSEB5(x)
        x = self.DW(x)
        x = self.attention(x) * x
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

