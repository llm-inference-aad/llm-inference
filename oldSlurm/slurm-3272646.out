import math
import torch.nn as nn

def pad_num_y(k_s):
    pad_per_side = math.ceil((k_s - 1) / 2)
    return pad_per_side
    
class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin)
        self.bn = nn.BatchNorm2d(cin)
        self.act = nn.LeakyReLU()

    def forward(self, x):
        x = self.dw(x)
        x = self.bn(x)
        x = self.act(x)
        return x
