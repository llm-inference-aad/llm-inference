import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Efficient minimum pooling without value inversion
        return F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode, return_indices=False)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, 2*cout, 1, 1, bias=False)  # Increased output channels
        self.bn = nn.BatchNorm2d(2*cout)
        self.relu = nn.ReLU(inplace=True)  # Added activation function

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x)
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        x = self.relu(x)  # Applied activation
        return x
```

