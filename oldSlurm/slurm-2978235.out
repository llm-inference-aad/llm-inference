                         step_size_down=2000., mode='triangular', gamma=1.,
                         scale_fn=None, scale_mode='cycle', base_momentum=0.85,
                         max_momentum=0.95, last_epoch=-1):
                super(CyclicLR, self).__init__(optimizer, last_epoch)
                self.base_lr = base_lr
                self.max_lr = max_lr
                self.step_size_up = step_size_up
