# -- NOTE --
# Note: The classes SE_LN and SE used in this architecture are pre-existing and fully implemented elsewhere. 
# It is not necessary to create new implementations or modify these classes for this architecture. They should be used as-is.
# -- NOTE --

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, padding=dw_s//2, groups=cin)
        if is_LN:
            self.seln = SE_LN(cin)
        else:
            self.seln = SE(cin, 3)
        
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, padding=dw_s//2, groups=cin)
        self.pad_val = dw_s // 2

        # Memoize pad_num_x
        self.pad_num_x = dw_s // 2 if dw_s % 2 == 0 else dw_s // 2 + 1

    def forward(self, x):
        # Reduce redundant calculations
        y = x
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += y

        # Use in-place operations
        x = self.pw2(x, inplace=True)
        x = self.bn2(x, inplace=True)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        return x
