class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.ln = nn.LayerNorm(cin)
        self.se = nn.Sequential(
            nn.Linear(cin, cin // 16),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(cin // 16, cin),
            nn.Sigmoid()
        )
        self.act = nn.Sigmoid()

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.se(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

