import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.ln = nn.LayerNorm(cin, elementwise_affine=True)
        self.act = nn.Sigmoid()
        self.gamma = nn.Parameter(torch.ones(1, cin, 1, 1))
        self.beta = nn.Parameter(torch.zeros(1, cin, 1, 1))

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x, _ = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return self.gamma * x * y + self.beta

