import torch.nn as nn
class MemoryEfficientBatchNorm2d(nn.Module):
    def __init__(self, num_features, eps=1e-5, momentum=0.1, affine=True, track_running_stats=True):
        super().__init__()
        self.num_features = num_features
        self.eps = eps
        self.momentum = momentum
        self.affine = affine
        self.track_running_stats = track_running_stats
        self.register_buffer("running_mean", torch.zeros(num_features))
        self.register_buffer("running_var", torch.ones(num_features))
        self.register_parameter("weight", None)
        self.register_parameter("bias", None)
        
    def forward(self, x):
        if self.training and self.track_running_stats:
            mean = x.mean([0, 2, 3], keepdim=True)
            var = x.var([0, 2, 3], keepdim=True)
            with torch.no_grad():
                self.running_mean = self.momentum * self.running_mean + (1 - self.momentum) * mean
                self.running_var = self.momentum * self.running_var + (1 - self.momentum) * var
        else:
            mean = self.running_mean
            var = self.running_var
        x = (x - mean) / (var + self.eps).sqrt()
        if self.affine:
            x = x * self.weight.to(x.device) + self.bias.to(x.device)
        return x
class EfficientSEBlock(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.avg_pool = nn.AdaptiveAvgPool2d(1)
        self.fc1 = nn.Conv2d(cin, cin // 16, 1, bias=False)
        self.act = nn.SiLU()
        self.fc2 = nn.Conv2d(cin // 16, cin, 1, bias=False)
        self.gamma = nn.Parameter(torch.ones(1, cin, 1, 1))
        
    def forward(self, x):
        y = self.avg_pool(x)
        y = self.fc1(y)
        y = self.act(y)
        y = self.fc2(y)
        return x * self.gamma * y.sigmoid()
class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = MemoryEfficientBatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin, bias=False)
        self.se_block = EfficientSEBlock(cin) if not is_LN else nn.Identity()
        
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = MemoryEfficientBatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin, bias=False)
        
    def forward(self, x):
        y = x
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.se_block(x)
        x += y
        
        x = self.pw2(x)
        x = self.bn2(x)
        x = self.

