import torch.optim as optim
import torch.nn as nn
import torch.nn.functional as F
import torch

def get_optimizer(model, lr=0.01, weight_decay=0.0001, nesterov=True):  
    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)
        
        opt = optim.SGD(g0, lr, momentum=0.9, nesterov=nesterov)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
        opt.add_param_group({'params': g2})  # add g2 (biases)
    else:
        opt = optim.SGD(model.parameters(), lr, momentum=0.9, nesterov=nesterov)
    return opt 

# Example usage
class SimpleModel(nn.Module):
    def __init__(self):
        super(SimpleModel, self).__init__()
        self.fc = nn.Linear(10, 10)

    def forward(self, x):
        x = self.fc(x)
        return x

model = SimpleModel()
optimizer = get_optimizer(model)

# Training loop
for epoch in range(10):
    optimizer.zero_grad()
    output = model(torch.rand(1, 10))
    loss = F.mse_loss(output, torch.rand(1, 10))
    loss.backward()
    optimizer.step()

