import torch
import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Initialize convolution weights using He initialization
        nn.init.kaiming_normal_(self.pw.weight, mode='fan_out', nonlinearity='relu')

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        return x 

# Example usage:
cin = 3
cout = 64
model = ME(cin, cout)
x = torch.randn(1, cin, 32, 32)  # Batch size 1, channels=cin, height=32, width=32
output = model(x)
print(output.size())  # Should print torch.Size([1, cout, 16, 16])
```

