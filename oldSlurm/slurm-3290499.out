import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to create patches, then taking min over each patch
        # This avoids the double negation used previously
        n, c, h, w = x.size()
        kh, kw = self.ks, self.ks
        stride_h = stride_w = 1
        
        # Calculate output size based on ceil_mode
        if self.ceil_mode:
            out_h = (h + stride_h - 1) // stride_h
            out_w = (w + stride_w - 1) // stride_w
        else:
            out_h = (h - kh) // stride_h + 1
            out_w = (w - kw) // stride_w + 1
        
        # Unfold the tensor into patches
        x_unf = x.unfold(2, kh, stride_h).unfold(3, kw, stride_w)
        
        # Reshape for min operation
        x_unf = x_unf.contiguous().view(n, c, out_h, out_w, kh * kw)
        
        # Take min over each patch
        min_vals, _ = x_unf.min(dim=-1)
        
        return min_vals

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()


