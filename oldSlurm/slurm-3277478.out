import torch.nn as nn
import torch.nn.init as init

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin//2)
        self.fc2 = nn.Linear(cin//2, cin)
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Hardsigmoid()
        
        # Initialize new layers
        init.kaiming_normal_(self.fc1.weight, mode='fan_in')
        init.kaiming_normal_(self.fc2.weight, mode='fan_in')
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.fc2(x)
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

