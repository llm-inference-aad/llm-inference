import torch.nn as nn
import torch.nn.functional as F

def dw_conv_block(cin, dw_s):
    return nn.Sequential(
        nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin, bias=False),
        nn.BatchNorm2d(cin),
        nn.Hardswish(inplace=True)
    )

def pad_num_y(k_s):
    return int((k_s-1)*0.5)

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = dw_conv_block(cin, dw_s)
        self.pointwise = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cin)

    def forward(self, x):
        residual = x
        x = self.dw(x)
        x = self.pointwise(x)
        x = self.bn(x)
        x += residual
        x = F.hardswish(x)
        return x
```

This code introduces a residual connection, batch normalization, and a more sophisticated activation function (hardswish). It also includes a helper function for creating the depthwise separable convolution block, making the code more modular and easier to maintain.

