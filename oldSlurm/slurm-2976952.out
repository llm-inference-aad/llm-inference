import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cout)
        self.relu = nn.ReLU()

    def forward(self, x):
        x_dw = self.bn1(self.dw(x))
        x_dw = self.relu(x_dw)
        x_maxpool = self.maxpool(x)
        x_minpool = self.minpool(x)
        x_cat = torch.cat((x_maxpool, x_minpool, x_dw), dim=1)
        x_pw = self.pw(x_cat)
        x_pw = self.bn2(x_pw)
        x_pw = self.relu(x_pw)
        return x + x_pw

class MyModel(nn.Module):
    def __init__(self):
        super().__init__()
        self.conv1 = nn.Conv2d(1, 16, 3, 1, 1)
        self.bn1 = nn.BatchNorm2d(16)
        self.relu1 = nn.ReLU()
        self.fct1 = FCT(16, 32)
        self.fct2 = FCT(32, 64)
        self.fc = nn.Linear(64 * 7 * 7, 10)

    def forward(self, x):
        x = self.conv1(x)
        x = self.bn1(x)
        x = self.relu1(x)
        x = self.fct1(x)
        x = self.fct2(x)
        x = x.view(-1, 64 * 7 * 7)
        x = self.fc(x)
        return x

