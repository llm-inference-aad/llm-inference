import torch
import torch.nn as nn
import torch.nn.functional as F

class DFSEBV2(nn.Module):
    # ... (kept unchanged)

class FCT(nn.Module):
    # ... (kept unchanged)

class EVE(nn.Module):
    # ... (kept unchanged)

class ME(nn.Module):
    # ... (kept unchanged)

class DW(nn.Module):
    # ... (kept unchanged)

def initialize_weights(m):
    if isinstance(m, nn.Conv2d):
        nn.init.uniform_(m.weight, a=-0.1, b=0.1)
        if m.bias is not None:
            nn.init.constant_(m.bias, 0)

def count_parameters(model):
    return sum(p.numel() for p in model.parameters() if p.requires_grad)

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()

        self.DFSEB0 = DFSEBV2(img_channels, 12, use_final_activation=False)
        self.FCT = FCT(12, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1, 1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)

        self.apply(initialize_weights)

    def forward(self, x):
        x = self.DFSEB0(x)
        x = F.relu(self.FCT(x))
        x = self.DFSEB1(x)
        x = F.relu(self.EVE(x))
        x = self.DFSEB2(x)
        x = F.relu(self.ME3(x))
        x = self.DFSEB3(x)
        x = F.relu(self.ME4(x))
        x = self.DFSEB4(x)
        x = F.relu(self.ME5(x))
        x = self.DFSEB5(x)
        x = self.DW(x)
        x = F.relu(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

# Print the total number of learnable parameters
print(f"Total number of learnable parameters: {count_parameters(ExquisiteNetV2(10, 3))}")

