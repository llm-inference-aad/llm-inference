import torch.optim as optim

def get_optimizer(model, lr, weight_decay=0.0001, nesterov=True, momentum=0.95):  
    """
    Get optimizer with custom parameter groups for different decay rates.
    
    Args:
        model (nn.Module): The model to optimize.
        lr (float): The learning rate.
        weight_decay (float, optional): The weight decay. Defaults to 0.0001.
        nesterov (bool, optional): Whether to use Nesterov momentum. Defaults to True.
        momentum (float, optional): The momentum. Defaults to 0.95.
    
    Returns:
        optim.Optimizer: The optimizer with custom parameter groups.
    """
    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, torch.nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (torch.nn.BatchNorm2d, torch.nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, torch.nn.Parameter):  # weight (with decay)
                g1.append(v.weight)
        
        opt = optim.SGD(g0, lr, momentum, nesterov=nesterov, weight_decay=0)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
        opt.add_param_group({'params': g2, 'weight_decay': 0})  # add g2 (biases) with no weight_decay
    else:
        opt = optim.SGD(model.parameters(), lr, momentum, nesterov=nesterov, weight_decay=weight_decay)
    return opt

