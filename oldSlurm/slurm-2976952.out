import torch.nn as nn
import torch.nn.init as init

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()

        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

        # Initialize weights
        init.xavier_uniform_(self.pw.weight)

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        return x

def batch_process(model, inputs):
    """
    Helper function to apply the model to a batch of inputs.
    """
    with torch.no_grad():
        outputs = [model(input_) for input_ in inputs]
    return outputs

