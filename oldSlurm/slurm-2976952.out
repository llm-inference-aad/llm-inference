```python
import torch.nn as nn

# -- NOTE --
# Note: The classes FCT, EVE, ME, and DFSEBV2 used in this architecture are pre-existing and fully implemented elsewhere. 
# It is not necessary to create new implementations or modify these classes for this architecture. They should be used as-is. 
# -- NOTE --

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 32) # Changed number of neurons
        self.DFSEB1 = DFSEBV2(32, 3, True) #
        self.EVE = EVE(32, 64) # Changed number of neurons
        self.DFSEB2 = DFSEBV2(64, 3, True) #
        self.ME3 = ME(64, 128) # Changed number of neurons
        self.DFSEB3 = DFSEBV2(128, 3, True) #
        self.ME4 = ME(128, 256) # Changed number of neurons
        self.DFSEB4 = DFSEBV2(256, 3, True) #
        self.ME5 = ME(256, 512) # Changed number of neurons
        self.DFSEB5 = DFSEBV2(512, 3, True) #
        self.DW = DW(512, 3) # Changed number of neurons
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.2) # Changed dropout rate
        self.fc = nn.Linear(512, class_num) # Changed number of neurons

    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x) #
        x = self.EVE(x)  
        x = self.DFSEB2(x) #
        x = self.ME3(x)  
        x = self.DFSEB3(x) #
        x = self.ME4(x)  
        x = self.DFSEB4(x) #
        x = self.ME5(x)  
        x = self.DFSEB5(x) #
        x = self.DW(x)     #
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x
```
