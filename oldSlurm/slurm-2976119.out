import torch
import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio=16, reduction_activation='relu', gate_activation='sigmoid', use_spectral_norm=False):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))

        reduction_dim = int(cin / ratio)
        self.fc1 = nn.Linear(cin, reduction_dim, bias=False)

        if reduction_activation == 'relu':
            self.act1 = nn.ReLU()
        elif reduction_activation == 'leaky_relu':
            self.act1 = nn.LeakyReLU(negative_slope=0.1) #Experiment with slope
        elif reduction_activation == 'elu':
            self.act1 = nn.ELU(alpha=1.0)  # Experiment with alpha
        else:
            raise ValueError(f"Unsupported reduction activation: {reduction_activation}")


        self.fc2 = nn.Linear(reduction_dim, cin, bias=False)


        if gate_activation == 'sigmoid':
            self.act2 = nn.Sigmoid()
        elif gate_activation == 'hard_sigmoid':
             self.act2 = nn.Hardsigmoid()
        elif gate_activation == 'tanh':
             self.act2 = nn.Tanh()
        else:
            raise ValueError(f"Unsupported gate activation: {gate_activation}")


        self.use_spectral_norm = use_spectral_norm
        if use_spectral_norm:
            self.fc1 = nn.utils.spectral_norm(self.fc1)
            self.fc2 = nn.utils.spectral_norm(self.fc2)


    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = torch.flatten(x, 1) # use torch.flatten for cleaner code
        x = self.fc1(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(x.size(0), x.size(1), 1, 1) #Explicitely size for batch and channel
        return x * y

