```python
import torch
import torch.nn as nn

def pad_num_y(k_s):
    pad_per_side = int((k_s-1)*0.5)
    return pad_per_side
    
class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin, bias=False)  # Explicitly set bias=False
        self.act = nn.Hardswish() # Could experiment with other activations like ReLU or GELU

    def forward(self, x):
