def get_optimizer(model, lr, weight_decay=0, nesterov=True, use_adamw=False, adaptive_lr_layers=False, layerwise_lr_decay=0.9):
    """
    Configures and returns an optimizer for the given model.

    Args:
        model: The PyTorch model to optimize.
        lr: Initial learning rate.
        weight_decay: Weight decay strength.
        nesterov: Whether to use Nesterov momentum (only applies to SGD).
        use_adamw: Whether to use AdamW instead of SGD.
        adaptive_lr_layers: Enables Adaptive learning rate for each layer group.
        layerwise_lr_decay: Per-layer learning rate decay factor (used if adaptive_lr_layers is True).

    Returns:
        A PyTorch optimizer instance.
    """

    if use_adamw:
        # AdamW handles weight decay more directly and effectively.
        optimizer_class = AdamW
        defaults = dict(lr=lr, weight_decay=weight_decay)
    else:
        optimizer_class = partial(SGD, momentum=0.9, nesterov=nesterov)
        defaults = dict(lr=lr, weight_decay=weight_decay)

    grouped_parameters = []

    if adaptive_lr_layers:
        # Adaptive Learning Rate for each layer group.
        def is_no_decay(name):
            return 'bias' in name or 'bn' in name

        grouped_parameters = [
            {"params": [p for n, p in model.named_parameters() if not is_no_decay(n)],
             "weight_decay": weight_decay,
             "lr": lr},
            {"params": [p for n, p in model.named_parameters() if is_no_decay(n)],
             "weight_decay": 0.0,
             "lr": lr}
        ]

        # Add Layer-wise Learning Rate Decay
        current_lr = lr
        for i, group in enumerate(reversed(grouped_parameters)):  # Iterate backwards
            group['lr'] = current_lr
            current_lr *= layerwise_lr_decay
    else:
        #Original Approach: Grouping based on weight decay needs.
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)

        grouped_parameters.append({'params': g0})
        if weight_decay > 0:  # only add weight decay if it's greater than zero
            grouped_parameters.append({'params': g1, 'weight_decay': weight_decay})
        grouped_parameters.append({'params': g2})

    if not grouped_parameters:
        grouped_parameters = model.parameters()  # Use all parameters if no grouping is done.

    optimizer = optimizer_class(grouped_parameters, **defaults)  # Pass defaults to constructor

    return optimizer

