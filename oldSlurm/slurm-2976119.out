import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)


class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.cin = cin
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.avgpool = nn.AvgPool2d(2, ceil_mode=True)  # Adding AvgPool
        self.pw = nn.Conv2d(4*cin, cout, 1, 1, bias=False) #Increased cin
        self.bn = nn.BatchNorm2d(cout)
        self.se = SELayer(cout) #Adding Squeeze and Excite
        self.relu = nn.ReLU(inplace=True) #Adding ReLU
        self.lrelu = nn.LeakyReLU(inplace=True)

    def forward(self, x):
        dw_x = self.dw(x)
        maxpool_x = self.maxpool(x)
        minpool_x = self.minpool(x)
        avgpool_x = self.avgpool(x)

        x = torch.cat((
            maxpool_x,
            minpool_x,
            dw_x,
            avgpool_x #Added avg pool
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        x = self.se(x) #apply squeeze and excite
        x = self.relu(x) #add activation
        x = self.lrelu(x)

        return x

class SELayer(nn.Module):
    def __init__(self, channel, reduction=16):
        super().__init__()
        self.avg_pool = nn.AdaptiveAvgPool2d(1)
        self.fc = nn.Sequential(
            nn.Linear(channel, channel // reduction, bias=False),
            nn.ReLU(inplace=True),
            nn.Linear(channel // reduction, channel, bias=False),
            nn.Sigmoid()
        )

    def forward(self, x):
        b, c, _, _ = x.size()
        y = self.avg_pool(x).view(b, c)
        y = self.fc(y).view(b, c, 1, 1)
        return x * y.expand_as(x)
```

Key improvements and explanations:

*   **Added Average Pooling:** Incorporating average pooling alongside max and min pooling provides a more comprehensive view of the input feature maps.  This can help capture different types of information within the feature maps.
*   **Increased Input Channels to PW Conv2d:**  The `pw` conv2d now needs to handle 4\*cin input channels instead of 3\*cin because of the added average pooling.
*   **Squeeze-and-Excitation (SE) Block:** This is a channel attention mechanism that adaptively recalibrates channel-wise feature responses.  The `SELayer` is inserted after the batch normalization to refine the features based on their importance.  This helps the network focus on the most informative channels.
*   **ReLU and LReLU Activation:** Added ReLU and LReLU activation functions after the batch norm and squeeze and excite block to encourage non-linearity.
*   **Clearer Variable Names:** Added `dw_x`, `maxpool_x`, `minpool_x` and `avgpool_x` to make code more readable.

The `SELayer` code implements the squeeze-and-excitation block. It performs global average pooling on each channel, then uses two fully connected layers with a reduction factor to learn channel-wise attention weights. These weights are then applied to the original feature maps to rescale the channel responses.

This approach is more sophisticated than the original code and could potentially lead to significant performance improvements.


