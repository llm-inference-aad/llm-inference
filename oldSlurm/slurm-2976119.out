import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.activation = nn.ReLU(inplace=True)  # Added activation

        # Optional: Squeeze-and-Excitation
        self.se = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(2*cin, cin // 4, 1, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(cin // 4, 2*cin, 1, bias=False),
            nn.Sigmoid()
        )

    def forward(self, x):
        max_pooled = self.maxpool(x)
        min_pooled = self.minpool(x)
        
        # Optional: Squeeze-and-Excitation application
        se_weights = self.se(torch.cat((max_pooled, min_pooled), 1))
        x = torch.cat((max_pooled, min_pooled), 1) * se_weights # Corrected operation to element-wise multiplication

        x = self.pw(x)
        x = self.bn(x)
        x = self.activation(x) # Added activation

        return x
