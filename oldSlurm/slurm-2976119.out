```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.pool_ks = 2
        self.pool_ceil_mode = True

    def forward(self, x):
        # Efficient Max and Min Pooling using a single max_pool2d operation
        max_pooled = F.max_pool2d(x, self.pool_ks, ceil_mode=self.pool_ceil_mode)
        min_pooled = -F.max_pool2d(-x, self.pool_ks, ceil_mode=self.pool_ceil_mode) # Equivalent to min pooling

        x = torch.cat((
            max_pooled,
            min_pooled,
            self.dw(x),
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        return x
```

