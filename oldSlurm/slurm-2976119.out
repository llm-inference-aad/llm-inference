        self.minpool_op = nn.Conv2d(1, 1, kernel_size=ks, stride=ks, padding=0, bias=False)
        nn.init.constant_(self.minpool_op.weight, -1.0/(ks*ks)) #Initialize to average pooling

    def forward(self, x):
        b, c, h, w = x.shape
        x_unfolded = F.unfold(x, kernel_size=self.ks, stride=self.ks)
        x_unfolded = x_unfolded.view(b, c, self.ks*self.ks, h//self.ks, w//self.ks)
        x_unfolded = x_unfolded.mean(dim=2, keepdim=False)
        x_pooled = x_unfolded.view(b, c, h//self.ks, w//self.ks)
        return x_pooled

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 3, 2, 1, groups=cin, bias=False)  # Changed kernel size to 3 for efficiency
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x),
            self.dw(x),
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        return x

