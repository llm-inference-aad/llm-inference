import torch
import torch.nn as nn
import torch.nn.functional as F

def calculate_adaptive_padding(input_size, kernel_size, stride, dilation):
    """
    Calculates padding required to maintain the same output size.
    """
    effective_kernel_size = (kernel_size - 1) * dilation + 1
    padding_needed = max(0, (input_size - 1) * stride + effective_kernel_size - input_size)
    padding_top = padding_needed // 2
    padding_bottom = padding_needed - padding_top
    return padding_top, padding_bottom

class LearnablePadding(nn.Module):
    def __init__(self, max_pad):
        super().__init__()
        self.padding_top = nn.Parameter(torch.zeros(1))
        self.padding_bottom = nn.Parameter(torch.zeros(1))
        self.max_pad = max_pad

    def forward(self, x, pad_top, pad_bottom):
        # Clamp padding values to be within a reasonable range
        pad_top = torch.clamp(self.padding_top, 0, self.max_pad).round().int()
        pad_bottom = torch.clamp(self.padding_bottom, 0, self.max_pad).round().int()


        padding = (0, 0, pad_top.item(), pad_bottom.item())  # left, right, top, bottom
        x = F.pad(x, padding, mode='reflect')  # or 'replicate'

        return x


def adaptive_activation(cin):
    """
    Chooses activation function based on channel depth.
    """
    if cin <= 32:
        return nn.ReLU()
    elif cin <= 64:
        return nn.LeakyReLU(0.1)
    else:
        return nn.Hardswish()

class SqueezeAndExcitation(nn.Module):
    def __init__(self, cin, reduction_ratio=16):
        super().__init__()
        self.avg_pool = nn.AdaptiveAvgPool2d(1)
        self.fc = nn.Sequential(
            nn.Linear(cin, cin // reduction_ratio, bias=False),
            nn.ReLU(inplace=True),
            nn.Linear(cin // reduction_ratio, cin, bias=False),
            nn.Sigmoid()
        )

    def forward(self, x):
        b, c, _, _ = x.size()
        y = self.avg_pool(x).view(b, c)
        y = self.fc(y).view(b, c, 1, 1)
        return x * y

def pad_num_y(k_s):
    pad_per_side = int((k_s-1)*0.5)
    return pad_per_side

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.padding_calculator = lambda input_size, kernel_size, stride, dilation: int(((input_size - 1) * (stride - 1) + dilation * (kernel_size - 1)) / 2)
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, padding=pad_num_y(dw_s), groups=cin)
        self.act = adaptive_activation(cin)  # Adaptive activation
        self.se = SqueezeAndExcitation(cin)  # Squeeze-and-Excitation

    def forward(self, x):
        x = self.dw(x)
        x = self.act(x)
        x = self.se(x)
        return x

