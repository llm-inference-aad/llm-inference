```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        max_pooled = self.maxpool(x)
        min_pooled = self.minpool(x)

        # 1. Gating Mechanism: Adaptively weigh max and min pooled features
        gate = torch.sigmoid(self.pw(torch.cat((max_pooled, min_pooled), 1)))
        x = gate * max_pooled + (1 - gate) * min_pooled

        # 2. Depthwise Separable Convolution:  Potentially more efficient than pointwise convolution.
        # Only apply depthwise separable conv if cin equals cout. Otherwise, skip.
        if x.shape[1] == self.pw.out_channels:
            x = F.conv2d(x, weight=self.pw.weight, bias=None, stride=1, padding=0, groups=x.shape[1])
        else:
            x = self.pw(torch.cat((max_pooled, min_pooled), 1))

        # 3. Squeeze-and-Excitation: Channel-wise attention.
        b, c, _, _ = x.size()
        y = F.adaptive_avg_pool2d(x, (1, 1)).view(b, c)
        y = torch.relu(self.bn(y)) # Ensure BN on Squeeze part of Squeeze-and-Excitation
        y = torch.sigmoid(y).view(b, c, 1, 1)
        x = x * y.expand_as(x)

        x = self.bn(x)
        return x
```

