import torch
import torch.nn as nn
from torch.optim import SGD

def group_parameters(model, weight_decay):
    """
    Groups model parameters into three categories:
    - Batchnorm/Layernorm weights (no decay)
    - Other weights (with decay)
    - Biases (no decay)

    Args:
        model (nn.Module): The neural network model.
        weight_decay (float): The weight decay value.

    Returns:
        Tuple[List[nn.Parameter], List[nn.Parameter], List[nn.Parameter]]: 
        A tuple containing three lists:
        - g0: BatchNorm and LayerNorm weights
        - g1: Other weights
        - g2: Biases
    """
    g0, g1, g2 = [], [], []
    for v in model.modules():
        if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
            g2.append(v.bias)
        if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
            g0.append(v.weight)
        elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
            g1.append(v.weight)
    return g0, g1, g2


def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    """
    Creates an SGD optimizer with parameter grouping for weight decay.

    Args:
        model (nn.Module): The neural network model.
        lr (float): The learning rate.
        weight_decay (float, optional): The weight decay value. Defaults to 0.
        nesterov (bool, optional): Whether to use Nesterov momentum. Defaults to True.

    Returns:
        torch.optim.Optimizer: The configured SGD optimizer.
    """
    if weight_decay != 0:
        g0, g1, g2 = group_parameters(model, weight_decay)
        
        opt = SGD(g0, lr, 0.9, nesterov=nesterov)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})
        opt.add_param_group({'params': g2})
    else:
        opt = SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
    return opt

