import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout, reduction_ratio=4):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        
        self.bottleneck_channels = max(1, 2*cin // reduction_ratio)  # Ensure at least 1 channel
        self.pw_reduce = nn.Conv2d(2*cin, self.bottleneck_channels, 1, 1, bias=False)
        self.pw_expand = nn.Conv2d(self.bottleneck_channels, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x)
        ), 1)
        
        x = self.pw_reduce(x)
        x = self.pw_expand(x)
        x = self.bn(x)
        return x

