        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)

        # Optimization: Fuse Conv+BN+Act into a single operation (if possible)
        # This can reduce kernel launch overhead and improve memory access patterns.
        self.fuse_pw1_bn_act1 = nn.Sequential(
            nn.Conv2d(cin, cin, 1, 1, bias=False), # Bias is false since BN will remove the need for it
            nn.BatchNorm2d(cin),
            nn.SiLU()
        )

        self.fuse_pw2_bn_act2 = nn.Sequential(
            nn.Conv2d(cin, cin, 1, 1, bias=False),
            nn.BatchNorm2d(cin),
            nn.Hardswish()
        )

