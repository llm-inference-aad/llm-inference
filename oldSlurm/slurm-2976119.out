import torch
import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.scale = nn.Parameter(torch.ones(cout))
        self.bias = nn.Parameter(torch.zeros(cout))
        self.silu = nn.SiLU()  # Changed ReLU to SiLU

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = self.silu(x)  # Activation after BN
        # Learnable scale and bias
        x = x * self.scale.view(1, -1, 1, 1) + self.bias.view(1, -1, 1, 1)
        return x

