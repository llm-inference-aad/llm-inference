import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Sigmoid()
        self.cin = cin  # Store channel dimension for later use
        self.channel_shuffle_groups = max(1, cin // 4)  # Example: Divide into at most 4 groups or at least 1 group
        self.channel_shuffle = ChannelShuffle(self.channel_shuffle_groups)
        self.sparse_gate = SparseGate(cin)


    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)

        # Sparse Gating: Apply sparsity to the learned channel weights
        x = self.sparse_gate(x)

        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)

        # Channel shuffling BEFORE scaling by SE weights
        y = self.channel_shuffle(y)

        return x*y


class ChannelShuffle(nn.Module):
    def __init__(self, groups):
        super().__init__()
        self.groups = groups

    def forward(self, x):
        batchsize, num_channels, height, width = x.data.size()
        channels_per_group = num_channels // self.groups

        # reshape
        x = x.view(batchsize, self.groups,
                   channels_per_group, height, width)

        # transpose
        # - contiguous() required if transpose() is used before view().
        #   See https://github.com/pytorch/pytorch/issues/764
        x = torch.transpose(x, 1, 2).contiguous()

        # flatten
        x = x.view(batchsize, -1, height, width)

        return x

class SparseGate(nn.Module):
    def __init__(self, num_features, sparsity_level=0.5):  #sparsity_level can be adjusted
        super().__init__()
        self.num_features = num_features
        self.sparsity_level = sparsity_level
        self.mask = self._create_mask()
        self.mask = nn.Parameter(self.mask, requires_grad=False)  # Store mask as a parameter

    def _create_mask(self):
        mask = torch.ones(self.num_features)
        num_zeros = int(self.sparsity_level * self.num_features)
        indices = torch.randperm(self.num_features)[:num_zeros]
        mask[indices] = 0
        return mask

    def forward(self, x):
        return x * self.mask

