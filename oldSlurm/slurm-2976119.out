import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.scale = nn.Parameter(torch.ones(cin))
        self.bias = nn.Parameter(torch.zeros(cin))
        self.act = nn.Sigmoid()

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.act(self.scale * x + self.bias)
        x = x.view(-1, x.size(1), 1, 1)
        return x*y
```


