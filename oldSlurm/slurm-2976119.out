        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin, bias=False) # Added bias=False
        self.bn = nn.BatchNorm2d(cin) # Added Batch Norm
        self.act = nn.Hardswish()

