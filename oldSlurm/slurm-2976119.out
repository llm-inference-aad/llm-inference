        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        # Modified MaxPool2d: Stride slightly different from kernel size
        # Could encourage more diverse feature extraction
        self.maxpool = nn.MaxPool2d(kernel_size=2, stride=1, padding=1, ceil_mode=True)

        # MinPool2d remains largely the same, for now
        self.minpool = MinPool2d_x(ks=2, ceil_mode=True)

        # Pointwise convolution: keep it standard for now
        self.pw = nn.Conv2d(2*cin, cout, kernel_size=1, stride=1, bias=False)

        # BatchNorm2d:  Momentum tweaked slightly - could aid in faster convergence/stability
        # and Epsilon adjusted to a smaller number for numerical stability
        self.bn = nn.BatchNorm2d(cout, momentum=0.05, eps=1e-03)  # Lower momentum

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x)
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        return x

