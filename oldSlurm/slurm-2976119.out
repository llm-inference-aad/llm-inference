import torch
from torch import nn
from torch.optim import SGD
import random

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    def estimate_smoothness(param_group):
        # In a real implementation, this would involve some computation
        # based on the gradients and potentially higher-order derivatives.
        # For now, let's just return a random value.
        return random.uniform(0, 1)

    def scale_lr(param_group, gradients):
        # Simple example: scale LR inversely proportional to the L2 norm of gradients
        grad_norm = torch.linalg.norm(torch.cat([g.flatten() for g in gradients if g is not None])).item()
        if grad_norm > 0:
            return 1.0 / (grad_norm + 1e-8) # Adding a small constant for numerical stability
        else:
            return 1.0

    def freeze_parameters(param_group, freeze_prob=0.01):
        for param in param_group['params']:
            if random.random() < freeze_prob:
                param.requires_grad = False
            else:
                param.requires_grad = True


    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)
        
        opt = SGD(g0, lr, 0.9, nesterov=nesterov)
        opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
        opt.add_param_group({'params': g2})  # add g2 (biases)

        # Apply unconventional modifications per group
        for group in opt.param_groups:
            # Adaptive Nesterov (simulated)
            group['nesterov'] = nesterov * estimate_smoothness(group)

            # Learning Rate Scaling (simulated)
            # We need to access the gradients here. Since they're only available during the backward pass,
            # this would ideally be done within a custom optimizer step.  For simplicity here, we simulate it.
            simulated_gradients = [torch.randn_like(p) for p in group['params']]  #replace with real gradients during training
            group['lr'] = lr * scale_lr(group, simulated_gradients)

            # Weight Undecay for BatchNorm (g0 group)
            if group['params'] == g0:
                group['weight_decay'] = -0.01  # Example negative weight decay

            # Parameter Freezing
            freeze_parameters(group)



    else:
        opt = SGD(model.parameters(), lr, 0.9, nesterov=nesterov)

    return opt
```

