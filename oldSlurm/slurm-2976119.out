import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.depthwise = nn.Conv2d(cin, cin, kernel_size=1, groups=cin, bias=False)  # Depthwise
        self.pointwise = nn.Conv2d(cin, cout, kernel_size=1, bias=False) # Pointwise
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        x = self.maxpool(x)
        x = self.depthwise(x)
        x = self.pointwise(x)
        x = self.bn(x)
        return x

