import torch
import torch.nn as nn
import torch.nn.functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        self.act1 = nn.ReLU()
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.act2 = nn.Sigmoid()

        # Adaptive scaling factor initialization.  Helps with initial gradient flow.
        self.scale_factor = nn.Parameter(torch.zeros(1))

        #Optional GroupNorm.  Can sometimes improve stability and performance, especially with smaller batch sizes.
        self.group_norm = nn.GroupNorm(num_groups=min(32, cin // 4), num_channels=cin) if cin > 4 else None

        # Squeeze Excitation Recalibration Block (SERB)
        self.serb = SERB(cin, int(cin/ratio))

    def forward(self, x):
        y = x

        if self.group_norm is not None:
            x = self.group_norm(x)

        x = self.gavg(x)
        x = x.view(-1,x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)

        #SERB recalibration
        x = self.serb(x)

        x = x.view(-1,x.size()[1],1,1)

        #Applying adaptive scaling
        return (1 + self.scale_factor) * x * y

class SERB(nn.Module):
    def __init__(self, channels, reduced_channels):
        super().__init__()

        self.fc1_a = nn.Linear(channels, reduced_channels)
        self.act1_a = nn.ReLU()

        self.fc1_b = nn.Linear(reduced_channels, reduced_channels // 2) #Further reduce
        self.act1_b = nn.ReLU()

        self.fc2 = nn.Linear(reduced_channels // 2, channels)
        self.act2 = nn.Sigmoid()

    def forward(self, x):
        shortcut = x
        x = self.fc1_a(x)
        x = self.act1_a(x)
        x = self.fc1_b(x)
        x = self.act1_b(x)
        x = self.fc2(x)
        x = self.act2(x)

        #Residual connection within SERB
        return shortcut * x

