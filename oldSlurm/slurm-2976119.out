```python
import torch
import torch.nn as nn

# -- NOTE --
# Note: The classes SE_LN and SE used in this architecture are pre-existing and fully implemented elsewhere. 
# It is not necessary to create new implementations or modify these classes for this architecture. They should be used as-is. 
# -- NOTE --

def pad_num_x(k_s):
    pad_per_side = int((k_s-1)*0.5)
    return pad_per_side
    
class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.cin = cin
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        if is_LN:
            self.seln = SE_LN(cin)
        else:
            self.seln = SE(cin,3)
        
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)

        self.residual_scale1 = nn.Parameter(torch.ones(1))
        self.residual_scale2 = nn.Parameter(torch.ones(1))
        self.scale1 = nn.Parameter(torch.ones(1))
        self.scale2 = nn.Parameter(torch.ones(1))

    def forward(self, x):
        y = x
        x = self.pw1(x)
        x = self.bn1(x)
        x = x * self.scale1
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x = x * self.residual_scale1 + y
        
        y = x # residual for the second part
        x = self.pw2(x)
        x = self.bn2(x)
        x = x * self.scale2
        x = self.act2(x)
        x = self.dw2(x)
        x = x * self.residual_scale2 + y # second residual connection.
        return x
```

Key changes and rationale:

*   **Learnable Residual Scaling:**  Each residual connection now has a learnable scaling factor (`residual_scale1`, `residual_scale2`). This allows the network to learn the optimal contribution of the residual connections, potentially preventing them from overwhelming the learned features in the main branch.

*   **Learnable Layer Scaling**: Similar to the residual scaling, `scale1` and `scale2` are learnable parameters that scale the output of the BatchNorm before the activations. This adds another degree of freedom for the network to learn optimal feature scaling.

*   **Retained Original Architecture:** The core structure of the original `DFSEBV2` block is preserved, ensuring that the intended operations (pointwise convolutions, depthwise convolutions, SE/SE\_LN) are still performed.


