import torch
import torch.nn as nn

def pad_num_y(k_s):
    """Calculates padding based on kernel size.

    Args:
        k_s (int): Kernel size.

    Returns:
        int: Padding size.
    """
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        """Depthwise Convolutional Layer.

        Args:
            cin (int): Number of input channels.
            dw_s (int): Kernel size of the depthwise convolution.
        """
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin, bias=False)  # Remove bias for potential speedup
        self.bn = nn.BatchNorm2d(cin) # Batchnorm after conv
        self.act = nn.Hardswish()


    def forward(self, x):
        """Forward pass.

        Args:
            x (torch.Tensor): Input tensor.

        Returns:
            torch.Tensor: Output tensor.
        """
        x = self.dw(x)
        x = self.bn(x)
        x = self.act(x)
        return x

