        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)

        self.layer_list = [self.DFSEB1, self.EVE, self.DFSEB2, self.ME3, self.DFSEB3, self.ME4, self.DFSEB4, self.ME5, self.DFSEB5, self.DW]

    def stochastic_depth(self, x, layer, prob):
        """Implements stochastic depth for a given layer."""
        if not self.training or prob == 0.0:  # Only apply during training
            return layer(x)

        if torch.rand(1) > prob:
            return layer(x) # Apply the layer
        else:
            return x  # Skip the layer, keep the input the same

    def forward(self, x):
        x1 = self.FCT(x)
        x2 = self.DFSEB1(x1) #
        x3 = self.EVE(x2)
        x4 = self.DFSEB2(x3) #
        x5 = self.ME3(x4)
        x6 = self.DFSEB3(x5) #
        x7 = self.ME4(x6)
        x8 = self.DFSEB4(x7) #
        x9 = self.ME5(x8)
        x10 = self.DFSEB5(x9) #

        x11 = self.DW(x10)  #
        x = self.gavg(x11)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

