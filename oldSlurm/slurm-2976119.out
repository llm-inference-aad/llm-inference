import torch
import torch.nn as nn
from torch.optim import SGD, AdamW

def get_optimizer(model, lr, weight_decay=0, nesterov=True, optimizer_type='SGD', beta1=0.9, beta2=0.999, adamw_weight_decay=0.01):  
    """
    Configures and returns an optimizer for the given model.

    Args:
        model: The PyTorch model to optimize.
        lr: Learning rate.
        weight_decay:  L2 regularization strength for SGD (applied to relevant weights).
        nesterov:  Whether to use Nesterov momentum for SGD.
        optimizer_type:  The type of optimizer to use ('SGD' or 'AdamW'). Defaults to 'SGD'.
        beta1: Beta1 parameter for AdamW. Defaults to 0.9.
        beta2: Beta2 parameter for AdamW. Defaults to 0.999.
        adamw_weight_decay: Weight decay for AdamW optimizer. Defaults to 0.01.

    Returns:
        A configured optimizer.
    """
    if optimizer_type == 'SGD':
        if weight_decay != 0:
            g0, g1, g2 = [], [], []  # optimizer parameter groups
            for v in model.modules():
                if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                    g2.append(v.bias)
                if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                    g0.append(v.weight)
                elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                    g1.append(v.weight)
            
            opt = SGD(g0, lr, momentum=beta1, nesterov=nesterov) # Using beta1 for momentum
            opt.add_param_group({'params': g1, 'weight_decay': weight_decay})  # add g1 with weight_decay
            opt.add_param_group({'params': g2})  # add g2 (biases)
        else:
            opt = SGD(model.parameters(), lr, momentum=beta1, nesterov=nesterov) # Using beta1 for momentum
    elif optimizer_type == 'AdamW':
        opt = AdamW(model.parameters(), lr=lr, weight_decay=adamw_weight_decay, betas=(beta1, beta2)) # Using AdamW with weight decay
    else:
        raise ValueError(f"Unsupported optimizer type: {optimizer_type}")
    return opt

