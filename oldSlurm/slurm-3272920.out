class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))  
        self.scale = nn.Parameter(torch.ones(cin))
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = x * self.scale
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x*y

