class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.gmax = nn.AdaptiveMaxPool2d((1,1))
        self.fc1 = nn.Linear(2*cin, int(2*cin/ratio), bias=False)
        self.act1 = nn.ReLU()
        self.fc2 = nn.Linear(self.fc1.out_features, 2*cin, bias=False)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        avg_x = self.gavg(x)
        max_x = self.gmax(x)
        x = torch.cat([avg_x, max_x], dim=1)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, 2*cin, 1, 1)
        x = x.split	cin, dim=1)
        x = (x[0] + x[1]) * y
        return x
