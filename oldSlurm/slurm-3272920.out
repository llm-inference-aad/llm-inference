import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Optimized implementation using unfold and reshape
        n, c, h, w = x.size()
        stride = self.ks
        padding = 0
        
        # Calculate output dimensions based on ceil_mode
        if self.ceil_mode:
            out_h = (h + stride - 1) // stride
            out_w = (w + stride - 1) // stride
        else:
            out_h = (h - stride) // stride + 1
            out_w = (w - stride) // stride + 1
            
        # Reshape input for efficient min calculation
        x_reshaped = x.view(n * c, 1, h, w)
        
        # Use unfold to extract patches
        patches = x_reshaped.unfold(2, self.ks, self.ks).unfold(3, self.ks, self.ks)
        
        # Reshape patches for min calculation
        patches = patches.contiguous().view(n * c, -1, self.ks * self.ks)
        
        # Compute min over each patch
        min_vals, _ = patches.min(dim=-1)
        
        # Reshape back to original dimensions
        min_output = min_vals.view(n, c, out_h, out_w)
        
        return min_output

