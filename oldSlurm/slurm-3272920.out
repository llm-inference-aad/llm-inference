import torch
import torch.nn as nn
from torch.nn import functional as F

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.cin = cin
        self.dw_s = dw_s
        self.is_LN = is_LN
        
        # Fused Conv-BN layers
        self.fused_pw1_bn1 = nn.utils.fusion.fuse_conv_bn_eval(
            nn.Conv2d(cin, cin, 1, 1, bias=False),
            nn.BatchNorm2d(cin)
        )
        
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, (dw_s-1)//2, groups=cin)
        
        # Select SE variant based on is_LN
        self.seln = SE_LN(cin) if is_LN else SE(cin, 3)
        
        # Second set of fused layers
        self.fused_pw2_bn2 = nn.utils.fusion.fuse_conv_bn_eval(
            nn.Conv2d(cin, cin, 1, 1, bias=False),
            nn.BatchNorm2d(cin)
        )
        
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, (dw_s-1)//2, groups=cin)
        
        # Register buffer for residual addition
        self.register_buffer('residual_weight', torch.ones(1))

    def forward(self, x):
        y = x * self.residual_weight
        x = self.fused_pw1_bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += y
        
        x = self.fused_pw2_bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        return x
