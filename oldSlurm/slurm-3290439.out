import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode
        
    def forward(self, x):
        # Apply min pooling via max pooling on negated input
        # Add noise to prevent gradient issues when all elements are equal
        noise = torch.randn_like(x) * 1e-8
        return -F.max_pool2d(-(x + noise), self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Initialize weights using He initialization for better convergence
        nn.init.kaiming_normal_(self.pw.weight, mode='fan_in', nonlinearity='relu')
        
    def forward(self, x):
        # Concatenate max and min pooled features
        x_pooled = torch.cat((self.maxpool(x), self.minpool(x)), dim=1)
        
        # Point-wise convolution followed by batch normalization
        x = self.pw(x_pooled)
        x = self.bn(x)
        
        # Apply activation function (ReLU) after batch norm
        x = F.relu(x)
        
        return x
```

