import torch
import torch.nn as nn
import torch.nn.functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio=16):
        super(SE, self).__init__()
        self.cin = cin
        self.ratio = ratio
        
        # Global average pooling layer
        self.gavg = nn.AdaptiveAvgPool2d(1)
        
        # First fully connected layer
        self.fc1 = nn.Linear(cin, max(1, int(cin / ratio)), bias=False)
        
        # Activation after first FC layer
        self.act1 = nn.ReLU(inplace=True)
        
        # Second fully connected layer
        self.fc2 = nn.Linear(max(1, int(cin / ratio)), cin, bias=False)
        
        # Sigmoid activation for attention weights
        self.act2 = nn.Sigmoid()

        # Initialize weights using He initialization for ReLU
        self._initialize_weights()

    def _initialize_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.kaiming_normal_(m.weight.data, mode='fan_in', nonlinearity='relu')
    
    def forward(self, x):
        # Store input tensor for later multiplication
        y = x
        
        # Apply global average pooling
        x = self.gavg(x)
        
        # Flatten the tensor
        x = x.view(-1, self.cin)
        
        # First linear transformation
        x = self.fc1(x)
        
        # Apply ReLU activation
        x = self.act1(x)
        
        # Second linear transformation
        x = self.fc2(x)
        
        # Apply sigmoid to get attention weights
        x = self.act2(x)
        
        # Reshape the attention weights
        x = x.view(-1, self.cin, 1, 1)
        
        # Multiply attention weights with original input
        return x * y
```

