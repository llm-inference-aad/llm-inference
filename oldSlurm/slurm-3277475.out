import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 3, 2, 1, groups=cin, bias=False)  # Kernel size reduced from 4 to 3
        self.maxpool = nn.MaxPool2d(3, ceil_mode=True)                  # Kernel size increased from 2 to 3
        self.minpool = MinPool2d_y(3, ceil_mode=True)                   # Kernel size increased from 2 to 3
        self.bottleneck = nn.Conv2d(3 * cin, cin, 1, 1, bias=False)     # Added bottleneck layer
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout, momentum=0.9, eps=1e-5)          # Adjusted BN parameters

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x),
            self.dw(x),
        ), 1)
        x = self.bottleneck(x)  # Reduced dimensions before pointwise conv
        x = self.pw(x)
        x = self.bn(x)
        return x

