import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.LayerNorm(cout)  # Changed from BatchNorm to LayerNorm
        self.dropout = nn.Dropout(0.2)  # Added dropout layer
        self.relu = nn.ReLU(inplace=True)  # Added ReLU activation
        # Initialize weights using He initialization
        nn.init.kaiming_normal_(self.pw.weight, mode='fan_out', nonlinearity='relu')

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = self.dropout(x)
        x = self.relu(x)
        return x

