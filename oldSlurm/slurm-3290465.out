import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio=8):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin//ratio), bias=True)
        self.act1 = nn.SiLU()
        self.fc2 = nn.Linear(int(cin//ratio), cin, bias=True)
        self.act2 = nn.Sigmoid()
        self.dropout = nn.Dropout(0.2)
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
