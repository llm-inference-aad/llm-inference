import torch.nn as nn
import math

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.depthwise_conv = nn.Conv2d(cin, cin, kernel_size=1, groups=cin)
        self.pointwise_conv1 = nn.Conv2d(cin, int(cin/ratio), kernel_size=1)
        self.act1 = nn.SiLU()  # Improved activation
        self.dropout1 = nn.Dropout(0.2)
        self.pointwise_conv2 = nn.Conv2d(int(cin/ratio), cin, kernel_size=1)
        self.act2 = nn.Sigmoid()
        self.dropout2 = nn.Dropout(0.2)
        
        # Initialize weights using He initialization
        for m in self.modules():
            if isinstance(m, nn.Conv2d):
                n = m.kernel_size[0] * m.kernel_size[1] * m.out_channels
                m.weight.data.normal_(0, math.sqrt(2. / n))
                
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = self.depthwise_conv(x)
        x = self.pointwise_conv1(x)
        x = self.act1(x)
        x = self.dropout1(x)
        x = self.pointwise_conv2(x)
        x = self.act2(x)
        x = self.dropout2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y

