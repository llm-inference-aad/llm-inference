import torch
from torch import optim as optim
import torch.nn as nn

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        opt = optim.SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = optim.SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt

