import torch.nn as nn

def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.SyncBatchNorm(cin)  # Using SyncBN for better performance in distributed training
        self.act1 = nn.Mish()  # Changed from SiLU to Mish for potentially better non-linearity
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        if is_LN:
            self.seln = SE_LN(cin)
        else:
            self.seln = SE(cin, 3)
            
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.SyncBatchNorm(cin)
        self.act2 = nn.ReLU(inplace=True)  # Changed from Hardswish to ReLU for faster computation
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        # Fusing bn and act for efficiency
        self.fused_bn_act1 = nn.Sequential(self.bn1, self.act1)
        self.fused_bn_act2 = nn.Sequential(self.bn2, self.act2)

    def forward(self, x):
       

