        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.reduction(x)
        x = self.ln(x)
        x = self.act(x)
        x = self.expansion(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

