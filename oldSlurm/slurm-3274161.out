class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to create windows, then taking min
        *dims, h, w = x.shape
        kh, kw = self.kernel_size, self.kernel_size
        stride_h, stride_w = 1, 1
        
        # Calculate output dimensions
        out_h = (h - kh) // stride_h + 1
        if self.ceil_mode and (h % stride_h!= 0):
            out_h += 1
        out_w = (w - kw) // stride_w + 1
        if self.ceil_mode and (w % stride_w!= 0):
            out_w += 1
            
        # Unfold the tensor into patches
        patches = x.unfold(2, kh, stride_h).unfold(3, kw, stride_w)
        patches = patches.contiguous().view(*dims, -1, kh*kw)
        
        # Compute min over each patch
        min_vals, _ = patches.min(dim=-1)
        min_vals = min_vals.view(*dims, out_h, out_w)
        return min_vals

class FCT_Optimized(nn.Module):
    def __init__(self, cin, cout):
        super(FCT_Optimized, self).__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d(2, ceil_mode=True)
