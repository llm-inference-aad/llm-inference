import torch
import torch.nn as nn
import math

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.global_avg = nn.AdaptiveAvgPool2d((1,1))
        self.global_max = nn.AdaptiveMaxPool2d((1,1))
        
        mid_channels = int(cin / ratio)
        self.fc1 = nn.Sequential(
            nn.Conv2d(cin * 2, mid_channels, kernel_size=1, bias=False),
            nn.BatchNorm2d(mid_channels),
            nn.SiLU()
        )
        
        self.conv_dw = nn.Conv2d(mid_channels, mid_channels, kernel_size=3, padding=1, groups=mid_channels, bias=False)
        self.bn_dw = nn.BatchNorm2d(mid_channels)
        self.act_dw = nn.SiLU()
        
        self.fc2 = nn.Conv2d(mid_channels, cin, kernel_size=1, bias=False)
        self.sigmoid = nn.Sigmoid()
        
        # Initialize weights
        for m in self.modules():
            if isinstance(m, nn.Conv2d):
                n = m.kernel_size[0] * m.kernel_size[1] * m.out_channels
                m.weight.data.normal_(0, math.sqrt(2. / n))
            elif isinstance(m, nn.BatchNorm2d):
                m.weight.data.fill_(1)
                m.bias.data.zero_()
                
    def forward(self, x):
        avg = self.global_avg(x)
        max_ = self.global_max(x)
        y = torch.cat([avg, max_], dim=1)
        
        y = self.fc1(y)
        y = self.conv_dw(y)
        y = self.bn_dw(y)
        y = self.act_dw(y)
        
        y = self.fc2(y)
        y = self.sigmoid(y)
        
        return x * y

