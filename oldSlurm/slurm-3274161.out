import torch
import torch.nn as nn
from torch.nn import functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.cin = cin
        self.ratio = ratio
        
        # Dynamic channel compression based on input size
        self.channels = [cin]
        while max(self.channels) > 1:
            next_channel = max(1, min(int(max(self.channels)/ratio), cin))
            if next_channel == self.channels[-1]:
                break
            self.channels.append(next_channel)
            
        layers = []
        prev_ch = cin
        for ch in self.channels[1:]:
            layers.extend([
                nn.Linear(prev_ch, ch, bias=False),
                nn.LayerNorm(ch),
                nn.GELU(),
                nn.Dropout(0.1)
            ])
            prev_ch = ch
            
        layers.append(nn.Linear(prev_ch, cin, bias=False))
        self.fc = nn.Sequential(*layers)
        
        # Adaptive activation scaling
        self.gamma = nn.Parameter(torch.zeros(1))
        
        # Spatial attention enhancement
        self.conv_attn = nn.Conv2d(cin, 1, kernel_size=3, padding=1, bias=False)
        self.norm_attn = nn.BatchNorm2d(1)
        
    def forward(self, x):
        b, c, h, w = x.size()
        
        # Enhanced global average pooling with noise injection
        x_gap = self.global_avg_pool_with_noise(x)
        x_gap = x_gap.view(b, -1)
        
        # Channel-wise transformation with dynamic routing
        x_trans = self.channel_transform(x_gap)
        
        # Spatial attention mechanism
        spatial_attn = self.conv_attn(x)
        spatial_attn = self.norm_attn(spatial_attn).sigmoid()
        
        # Combine transformations with adaptive scaling
        x_se = (x * x_trans.unsqueeze(2).unsqueeze(3)) * spatial_attn
        x_se = x_se * (1 + self.gamma)
        
        return x + x_se
    
    def global_avg_pool_with_noise(self, x):
        x_pooled = F.avg_pool2d(x, kernel_size=(h,w))
        noise = torch.randn_like(x_pooled) * 1e-5
        return x_pooled + noise
    
    def channel_transform(self, x_gap):
        x_gap = self.fc(x_gap)
        x_gap = x_gap * torch.sigmoid(F.layer_norm(x_gap, (self.cin,), weight=None, bias=None))
        return x_gap
```

