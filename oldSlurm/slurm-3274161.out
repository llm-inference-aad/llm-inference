import torch.nn as nn
from torch.nn.utils.fusion import fuse_conv_bn_eval

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Fuse pw and bn during initialization for eval mode
        if not self.training:
            self.fused_pw_bn = fuse_conv_bn_eval(self.pw, self.bn)
        else:
            self.fused_pw_bn = None

    def forward(self, x):
        x = self.maxpool(x)
        if self.fused_pw_bn is not None:
            x = self.fused_pw_bn(x)
        else:
            x = self.pw(x)
            x = self.bn(x)
        return x
