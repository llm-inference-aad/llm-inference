import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks=2, ceil_mode=True, learnable_ks=False):
        super().__init__()
        self.ks = ks if not learnable_ks else nn.Parameter(torch.tensor(ks, dtype=torch.float))
        self.ceil_mode = ceil_mode
        self.learnable_ks = learnable_ks

    def forward(self, x):
        if self.learnable_ks:
            ks = int(round(self.ks.data)) if self.ks.data >=1 else 1
        else:
            ks = self.ks
        return -F.max_pool2d(-x, ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout, pool_ks=2, learnable_ks=False):
        super().__init__()
        self.maxpool = nn.MaxPool2d(pool_ks, ceil_mode=True)
        self.minpool = MinPool2d_x(pool_ks, ceil_mode=True, learnable_ks=learnable_ks)
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=True)
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout2d(p=0.1)

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x)
        ), 1)
        x = self.dropout(x)
        x = self.pw(x)
        x = self.bn(x)
        return x 
```

