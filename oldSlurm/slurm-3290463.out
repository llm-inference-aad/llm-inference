        self.act1 = nn.SiLU()
        self.fc2 = nn.Linear(hidden_dim, cin, bias=False)
        self.dropout = nn.Dropout(0.2)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        avg_x = self.gavg(x)
        max_x = self.gmax(x)
        x = torch.cat([avg_x, max_x], dim=1)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        x = self.depth_conv(x)
        return x * y

