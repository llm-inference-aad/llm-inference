        x = self.DFSEB1(x) 
        # Apply residual connection here
        x = x + self.residual1(x)
        x = self.EVE(x)  
        x = self.DFSEB2(x) 
        x = self.ME3(x)  
        x = self.DFSEB3(x) 
        x = self.ME4(x)  
        x = self.DFSEB4(x) 
        x = self.ME5(x)  
        x = self.DFSEB5(x) 
        x = self.DW(x)    
        x = self.gavg(x)
        x = self.drop(x)
        # Apply second residual connection before FC
        x = x + self.residual2(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

