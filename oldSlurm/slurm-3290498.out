import torch.nn as nn
import torch.nn.init as init

class SE(nn.Module):
    def __init__(self, cin, ratio=8):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin//ratio), bias=False)
        init.kaiming_normal_(self.fc1.weight.data, mode='fan_in', nonlinearity='relu')
        self.act1 = nn.ReLU()
        self.dropout = nn.Dropout(0.2)
        self.fc2 = nn.Linear(int(cin//ratio), cin, bias=False)
        init.kaiming_normal_(self.fc2.weight.data, mode='fan_in', nonlinearity='sigmoid')
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
