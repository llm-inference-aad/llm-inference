import torch
import torch.nn as nn
from torch.nn import functional as F

def pad_num_y(k_s):
    pad_per_side = (k_s - 1) // 2
    return pad_per_side

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.depthwise = nn.Conv2d(
            cin, cin, kernel_size=dw_s,
            stride=1, padding=pad_num_y(dw_s),
            groups=cin, bias=False
        )
        self.pointwise = nn.Conv2d(
            cin, cin, kernel_size=1,
            stride=1, padding=0, bias=True
        )
        self.act = nn.Hardswish()
        
        # Initialize weights using He initialization
        for m in [self.depthwise, self.pointwise]:
            if isinstance(m, nn.Conv2d):
                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='hardswish')
                if m.bias is not None:
                    fan_in, _ = nn.init._calculate_fan_in_and_fan_out(m.weight)
                    bound = 1 / (fan_in ** 0.5)
                    nn.init.uniform_(m.bias, -bound, bound)

    def forward(self, x):
        x = self.depthwise(x)
        x = self.pointwise(x)
        x = self.act(x)
        return x

    def fuse_model(self):
        # Fuse depthwise and pointwise convolutions
        fused_conv = nn.Conv2d(
            self.depthwise.in_channels, self.pointwise.out_channels,
            kernel_size=self.depthwise.kernel_size,
            stride=self.depthwise.stride,
            padding=self.depthwise.padding,
            dilation=self.depthwise.dilation,
            bias=self.pointwise.bias is not None
        )
        
        # Copy depthwise weights
        fused_conv.weight.data.copy_(
            self.depthwise.weight.data.view(fused_conv.weight.size())
        )
        
        # Apply pointwise weights
        if self.pointwise.bias is not None:
            fused_conv.bias.data.copy_(self.pointwise.bias.data)
            
        self.depthwise = fused_conv
        self.pointwise = nn.Identity()
```

