import torch.optim as optim
from torch.optim.lr_scheduler import CosineAnnealingWarmRestarts

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        
        optimizer = optim.AdamW([
            {'params': g0, 'lr': lr * 1.0, 'weight_decay': 0},
            {'params': g1, 'lr': lr * 0.8, 'weight_decay': weight_decay},
            {'params': g2, 'lr': lr * 2.0, 'weight_decay': 0}
        ], lr=lr, betas=(0.9, 0.999), eps=1e-8, weight_decay=weight_decay)
    else:
        optimizer = optim.SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    
    scheduler = CosineAnnealingWarmRestarts(optimizer, T_0=5, T_mult=1, eta_min=lr*0.

