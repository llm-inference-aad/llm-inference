import torch.nn as nn

def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.Mish()  # Changed from SiLU to Mish
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        if is_LN:
            self.seln = SE_LN(cin)
        else:
            self.seln = SE(cin, 3)
            
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.ReLU(inplace=True)  # Changed from Hardswish to ReLU
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        # Added dropout for regularization
        self.dropout = nn.Dropout(0.2)

    def forward(self, x):
        y = x
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x = self.dropout(x)
        x += y
        
        x = self.pw2(x)
        x = self.bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        return x
```

