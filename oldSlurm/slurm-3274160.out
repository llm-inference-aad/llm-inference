import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to compute min pool without negative operations
        x_shape = x.size()
        x_unfolded = x.unfold(2, self.ks, self.ks).unfold(3, self.ks, self.ks)
        min_pooled = x_unfolded.min(dim=-1)[0].min(dim=-1)[0]
        if self.ceil_mode:
            pad_h = (x_shape[2] + self.ks - 1) // self.ks * self.ks - x_shape[2]
            pad_w = (x_shape[3] + self.ks - 1) // self.ks * self.ks - x_shape[3]
            if pad_h > 0 or pad_w > 0:
                padding = (pad_w // 2, pad_w - pad_w//2, pad_h // 2, pad_h - pad_h//2)
                min_pooled = min_pooled[:, :, :-pad_h//2, :-pad_w//2] if pad_h>0 and pad_w>0 else min_pooled
        return min_pooled

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
