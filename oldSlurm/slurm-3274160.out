import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin//2)
        self.bn = nn.BatchNorm1d(cin//2)
        self.fc2 = nn.Linear(cin//2, cin)
        self.ln = nn.LayerNorm(cin)
        self.act = nn.ReLU()  # Changed from Sigmoid
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.fc1(x)
        x = self.bn(x)
        x = self.act(x)
        x = self.fc2(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
