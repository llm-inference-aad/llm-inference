import torch
import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super(SE, self).__init__()
        self.channels = cin
        self.ratio = ratio
        
        # Global average pooling
        self.gavg = nn.AdaptiveAvgPool2d(1)
        
        # First fully connected layer
        self.fc1 = nn.Linear(cin, int(cin / ratio), bias=False)
        self.relu = nn.ReLU(inplace=True)
        
        # Second fully connected layer
        self.fc2 = nn.Linear(int(cin / ratio), cin, bias=False)
        self.sigmoid = nn.Sigmoid()

    def _channel_attention(self, x):
        """Helper function for computing channel attention."""
        # Global average pooling
        x_pooled = self.gavg(x).view(-1, self.channels)
        
        # First FC layer followed by ReLU
        x_fc1 = self.relu(self.fc1(x_pooled))
        
        # Second FC layer followed by Sigmoid
        x_att = self.sigmoid(self.fc2(x_fc1)).view(-1, self.channels, 1, 1)
        
        return x_att

    def forward(self, x):
        # Compute channel attention
        att = self._channel_attention(x)
        
        # Apply attention weights
        out = x * att
        
        return out

