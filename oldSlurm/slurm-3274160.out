import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        # Bottleneck structure for reduced computation
        self.fc1 = nn.Linear(cin, cin // 16)
        self.fc2 = nn.Linear(cin // 16, cin)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))  
        self.ln = nn.LayerNorm(cin)
        self.act1 = nn.Swish()  # Using Swish instead of Sigmoid
        self.act2 = nn.Swish()
        self.gamma = nn.Parameter(torch.zeros(1))  # Learnable parameter for weighted sum
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.act1(x)
        x = self.fc1(x)
        x = self.act2(x)
        x = self.fc2(x)
        x = x.view(-1, x.size(1), 1, 1)
        # Weighted sum instead of direct multiplication
        return self.gamma * x * y + (1 - self.gamma) * y

