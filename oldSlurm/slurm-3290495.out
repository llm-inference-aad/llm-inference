import torch
import torch.nn as nn
from torch.nn import functional as F

def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        if is_LN:
            self.seln = SE_LN(cin)
        else:
            self.seln = SE(cin, 3)
        
        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        
        # Adding depth-wise separable convolution for better feature extraction
        self.expansion_conv = nn.Sequential(
            nn.Conv2d(cin, 2*cin, 1, 1, 0),
            nn.BatchNorm2d(2*cin),
            nn.ReLU(),
            nn.Conv2d(2*cin, 2*cin, dw_s, 1, pad_num_x(dw_s), groups=2*cin),
            nn.BatchNorm2d(2*cin),
            nn.ReLU(),
            nn.Conv2d(2*cin, cin, 1, 1, 0),
            nn.BatchNorm2d(cin)
        )
        
        # Adding attention mechanism for improved context-aware processing
        self.attention = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(cin, cin // 8, 1),
            nn.ReLU(),
            nn.Conv2d(cin // 8, cin, 1),
            nn.Sigmoid()
        )

    def forward(self, x):
        y = x
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += y
        
        x = self.pw2(x)
        x = self.bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        
        # Applying expansion and attention
        expanded = self.expansion_conv(x)
        attention = self.attention(expanded)
        x = expanded * attention + x
        return x

