import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return F.avg_pool2d(x, self.ks, ceil_mode=self.ceil_mode)  # Changed from max-based min pool to avg pool

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.relu = nn.ReLU(inplace=True)  # Added ReLU activation
        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout, momentum=0.9, eps=1e-5)  # Adjusted BN params
        self.dropout = nn.Dropout2d(p=0.2)  # Added dropout

    def forward(self, x):
        max_out = self.maxpool(x)
        min_out = self.minpool(x)
        x = torch.cat((max_out, min_out), 1)
        x = self.relu(x)  # Applied ReLU after concatenation
        x = self.pw(x)
        x = self.bn(x)
        x = self.dropout(x)  # Applied dropout
        return x
