import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d(nn.Module):
    def __init__(self, kernel_size, ceil_mode=False):
        super(MinPool2d, self).__init__()
        self.kernel_size = kernel_size
        self.ceil_mode = ceil_mode

    def forward(self, x):
        # Using unfold to create patches, then taking min
        *dims, c, h, w = x.size()
        k = self.kernel_size
        stride = k
        pad = 0
        
        # Calculate output size based on ceil_mode
        if self.ceil_mode:
            out_h = (h + stride - 1) // stride
            out_w = (w + stride - 1) // stride
        else:
            out_h = (h - k) // stride + 1
            out_w = (w - k) // stride + 1
        
        # Unfold the tensor into patches
        patches = x.unfold(2, k, stride).unfold(3, k, stride)
        patches = patches.contiguous().view(*dims, c, -1, k*k)
        
        # Compute min across each patch
        min_vals, _ = patches.min(dim=-1)
        min_vals = min_vals.view(*dims, c, out_h, out_w)
        
       

