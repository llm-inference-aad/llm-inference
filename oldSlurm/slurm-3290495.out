import torch.nn as nn
import torch

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 3, 2, 1, groups=cin, bias=False)  # Smaller kernel size
        self.maxpool = nn.MaxPool2d(3, ceil_mode=True)                  # Larger kernel size
        self.minpool = MinPool2d_y(3, ceil_mode=True)                   # Larger kernel size
        self.pw = nn.Conv2d(3*cin, cout*2, 1, 1, bias=False)           # Increased output channels
        self.bn = nn.BatchNorm2d(cout*2)
        self.relu = nn.ReLU(inplace=True)                              # Added ReLU activation

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x),
            self.dw(x),
        ), 1)
        x = self.pw(x)
        x = self.bn(x)
        x = self.relu(x)                                              # Applied ReLU
        return x 
