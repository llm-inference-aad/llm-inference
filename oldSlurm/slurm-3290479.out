import torch.nn as nn
import torch.nn.functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.avgpool = nn.AdaptiveAvgPool2d((1,1))
        self.maxpool = nn.AdaptiveMaxPool2d((1,1))
        
        # Depth-wise separable convolution
        self.depth_conv = nn.Sequential(
            nn.Conv2d(cin, cin, kernel_size=3, padding=1, groups=cin),
            nn.BatchNorm2d(cin),
            nn.SiLU()  # Using SiLU instead of ReLU
        )
        
        self.fc1 = nn.Linear(2*cin, int(2*cin/ratio), bias=False)
        self.dropout = nn.Dropout(0.2)
        self.swish = nn.SiLU()
        self.fc2 = nn.Linear(int(2*cin/ratio), cin, bias=False)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        y = x
        
        # Apply depth-wise separable convolution
        x = self.depth_conv(x)
        
        # Multi-scale pooling
        avg = self.avgpool(x)
        mx = self.maxpool(x)
        pooled = torch.cat([avg, mx], dim=1)
        
        # Flatten and pass through FC layers
        x = pooled.view(-1, pooled.size()[1])
        x = self.fc1(x)
        x = self.dropout(x)
        x = self.swish(x)
        x = self.fc2(x)
        x = self.sigmoid(x)
        x = x.view(-1, x.size()[1], 1, 1)
        
        return x * y

