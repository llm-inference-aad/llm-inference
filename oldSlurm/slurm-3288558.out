import torch.nn as nn

def pad_num_y(k_s):
    return (k_s - 1) // 2

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super(DW, self).__init__()
        padding = (dw_s - 1) // 2
        self.layers = nn.Sequential(
            nn.Conv2d(cin, cin, dw_s, 1, padding, groups=cin),
            nn.Hardswish()
        )

    def forward(self, x):
        return self.layers(x)
