def pad_num_x(k_s):
    pad_per_side = int((k_s-1)*0.5)
    return pad_per_side
    
class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        # First expansion
        self.pw1 = nn.Conv2d(cin, cin*2, 1, 1, bias=False)
        self.ln1 = nn.LayerNorm([cin*2, 1, 1])
        self.act1 = nn.Mish()
        self.dw1 = nn.Conv2d(cin*2, cin*2, dw_s, 1, pad_num_x(dw_s), groups=cin*2)
        if is_LN:
            self.seln = SE_LN(cin*2)
        else:
            self.seln = SE(cin*2,3)
        self.dropout1 = nn.Dropout(0.2)
        
        # Second expansion
        self.pw2 = nn.Conv2d(cin*2, cin, 1, 1, bias=False)
        self.ln2 = nn.LayerNorm([cin, 1, 1])
        self.act2 = nn.Mish()
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        self.dropout2 = nn.Dropout(0.2)
        
        # Residual connection
        self.shortcut = nn.Sequential(
            nn.Conv2d(cin, cin, 1, 1, bias=False),
            nn.LayerNorm([cin, 1, 1])
        )

