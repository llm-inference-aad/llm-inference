import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(3, stride=2, ceil_mode=True, padding=1)
        self.minpool = MinPool2d_x(3, ceil_mode=True)
        self.expansion = nn.Conv2d(cin, 2*cin, 1, 1, bias=False)
        self.pw = nn.Conv2d(4*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout, momentum=0.9, eps=1e-5)
        self.relu = nn.ReLU(inplace=True)

    def forward(self, x):
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_expanded = self.expansion(torch.cat((x_max, x_min), 1))
        x = self.pw(x_expanded)
        x = self.bn(x)
        x = self.relu(x)
        return x
