import torch
import torch.nn as nn
from torch.nn import functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.cin = cin
        self.ratio = ratio
        
        # Create adaptive average pooling layer
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        
        # First fully connected layer with batch normalization
        self.fc1 = nn.Linear(cin, int(cin / ratio), bias=False)
        self.bn1 = nn.BatchNorm1d(int(cin / ratio))
        
        # Second fully connected layer with batch normalization
        self.fc2 = nn.Linear(int(cin / ratio), cin, bias=False)
        self.bn2 = nn.BatchNorm1d(cin)
        
        # Activation layers
        self.act1 = nn.ReLU(inplace=True)
        self.act2 = nn.Sigmoid()
    
    def forward(self, x):
        # Store input for later multiplication
        y = x
        
        # Global average pooling
        x = self.gavg(x)
        
        # Flatten the tensor
        x = x.view(-1, self.cin)
        
        # First linear transformation with BN and activation
        x = self.fc1(x)
        x = self.bn1(x)
        x = self.act1(x)
        
        # Second linear transformation with BN
        x = self.fc2(x)
        x = self.bn2(x)
        
        # Sigmoid activation
        x = self.act2(x)
        
        # Reshape and multiply with original input
        x = x.view(-1, self.cin, 1, 1)
        return x * y
    
    def _initialize_weights(self):
        for m in self.modules():
            if isinstance(m, nn.Linear):
                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')
            elif isinstance(m, (nn.BatchNorm1d, nn.BatchNorm2d)):
                nn.init.constant_(m.weight, 1)
                nn.init.constant_(m.bias, 0)
                
    def reset_parameters(self):
        self._initialize_weights()

