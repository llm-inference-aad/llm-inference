import torch
import torch.nn as nn

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)

    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x)
        x = self.EVE(x)
        x = self.DFSEB2(x)
        x = self.ME3(x)
        x = self.DFSEB3(x)
        x = self.ME4(x)
        x = self.DFSEB4(x)
        x = self.ME5(x)
        x = self.DFSEB5(x)
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x
