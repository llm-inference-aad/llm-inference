import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        # Modified depthwise convolution parameters
        self.dw = nn.Conv2d(cin, cin, 3, 1, 1, groups=cin, bias=False)
        # Different kernel sizes for maxpool and minpool
        self.maxpool = nn.MaxPool2d(3, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        # Updated pointwise convolution input channels
        self.pw = nn.Conv2d(2*cin + cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.dropout = nn.Dropout(0.2)  # Added dropout for regularization

    def forward(self, x):
        x_max = self.maxpool(x)
        x_min = self.minpool(x)
        x_dw = self.dw(x)
        x_concat = torch.cat((x_max, x_min, x_dw), 1)
        x_pw = self.pw(x_concat)
        x_bn = self.bn(x_pw)
        x_dropout = self.dropout(x_bn)
        return x_dropout
