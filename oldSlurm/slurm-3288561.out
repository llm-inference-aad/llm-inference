import torch
import torch.nn as nn
from torch.nn import functional as F

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Adding depth-wise separable convolution for better feature extraction
        self.depthwise = nn.Conv2d(cin, cin, 3, padding=1, groups=cin, bias=False)
        self.pointwise = nn.Conv2d(cin, cout, 1, bias=False)
        self.bn_depth = nn.BatchNorm2d(cin)
        self.bn_point = nn.BatchNorm2d(cout)
        
        # Introduce attention mechanism
        self.attention = nn.Sequential(
            nn.Conv2d(cout, cout//8, 1),
            nn.ReLU(),
            nn.Conv2d(cout//8, cout, 1),
            nn.Sigmoid()
        )
        
        # Initialize weights using He initialization
        for m in self.modules():
            if isinstance(m, nn.Conv2d):
                nn.init.kaiming_normal_(m.weight, mode='fan_out', nonlinearity='relu')
            elif isinstance(m, (nn.BatchNorm2d)):
                nn.init.constant_(m.weight, 1)
                nn.init.constant_(m.bias, 0)

    def forward(self, x):
        # Original path
        x_orig = self.maxpool(x)
        x_orig = self.pw(x_orig)
        x_orig = self.bn(x_orig)
        
        # Depth-wise separable path
        x_dw = self.depthwise(x)
        x_dw = self.bn_depth(x_dw)
        x_dw = F.relu(x_dw)
        x_dw = self.pointwise(x_dw)
        x_dw = self.bn_point(x_dw)
        
        # Combine features
        x_combined = x_orig + x_dw
        
        # Apply attention
        attention = self.attention(x_combined)
        x_final = x_combined * attention
        
        return x_final

