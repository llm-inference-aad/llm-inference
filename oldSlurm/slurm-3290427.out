import torch.nn as nn
import torch.nn.init as init

class SE(nn.Module):
    def __init__(self, cin, ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
        self.bn = nn.BatchNorm1d(int(cin/ratio))
        self.act1 = nn.Mish()
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.act2 = nn.Sigmoid()
        
        # Weight initialization
        init.kaiming_normal_(self.fc1.weight, mode='fan_in')
        init.kaiming_normal_(self.fc2.weight, mode='fan_in')
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.bn(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
