from torch import optim as optim
import torch.nn as nn

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    def group_parameters(module):
        g0, g1, g2 = [], [], []
        for v in module.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        return [{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}]
    
    if weight_decay!= 0:
        grouped_params = group_parameters(model)
        opt = optim.SGD(grouped_params[0]['params'], lr, 0.9, nesterov=nesterov)
        opt.add_param_group(grouped_params[1])
        opt.add_param_group(grouped_params[2])
    else:
        opt = optim.SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
    return opt

