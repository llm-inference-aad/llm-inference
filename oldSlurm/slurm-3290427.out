import torch
from torch import nn
from torch.optim import SGD
from torch.optim.lr_scheduler import CosineAnnealingLR
from torch.nn.utils import clip_grad_norm_

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    def create_groups(module):
        g0, g1, g2 = [], [], []
        for v in module.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        return g0, g1, g2
    
    g0, g1, g2 = create_groups(model)
    
    opt = SGD([
        {'params': g0, 'lr': lr},
        {'params': g1, 'lr': lr, 'weight_decay': weight_decay},
        {'params': g2, 'lr': lr*2}
    ], momentum=0.9, nesterov=nesterov)
    
    scheduler = CosineAnnealingLR(opt, T_max=100, eta_min=lr/100)
    
    def optimize_step(loss, scaler=None):
        opt.zero_grad()
        loss.backward()
        if scaler is not None:
            scaler.step(opt)
            scaler.update()
        else:
            clip_grad_norm_(model.parameters(), max_norm=1.0)
            opt.step()
        scheduler.step()
    
    model.optimize_step = optimize_step
    return opt

