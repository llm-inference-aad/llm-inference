import torch
import torch.nn as nn
from torch.utils.cpp_extension import load

# Load custom C++ extensions for optimized convolutions
custom_conv = load(
    name="custom_conv",
    sources=["custom_convolution.cpp"],
    verbose=True
)

class OptimizedDFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        # Fused Conv+BN layers
        self.fused_pw1_bn1 = custom_conv.FusedConvBn2d(cin, cin, 1, 1)
        self.act1 = nn.SiLU()
        
        # Optimized depthwise convolution
        self.dw1 = custom_conv.OptimizedDepthwiseConv2d(
            cin, cin, dw_s, 1, padding=pad_num_x(dw_s)
        )
        
        # Squeeze-Excitation block
        self.seln = SE_LN(cin) if is_LN else SE(cin, 3)
        
        # Second set of fused layers
        self.fused_pw2_bn2 = custom_conv.FusedConvBn2d(cin, cin, 1, 1)
        self.act2 = nn.Hardswish()
        self.dw2 = custom_conv.OptimizedDepthwiseConv2d(
            cin, cin, dw_s, 1, padding=pad_num_x(dw_s)
        )

    def forward(self, x):
        y = x
        # First residual block with fused operations
        x = self.fused_pw1_bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += y
        
        # Second residual block with fused operations
        x = self.fused_pw2_bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += y
        return x

