import torch
import torch.nn as nn
from torch.nn.init import kaiming_normal_

class SE(nn.Module):
    def __init__(self, cin, ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin//ratio), bias=False)
        self.bn = nn.BatchNorm1d(int(cin//ratio))
        self.act1 = nn.SiLU()  # Swish-like activation
        self.fc2 = nn.Linear(self.fc1.out_features, cin, bias=False)
        self.dropout1 = nn.Dropout(0.2)
        self.dropout2 = nn.Dropout(0.2)
        self.act2 = nn.Sigmoid()
        
        # Initialize weights using He initialization
        for m in [self.fc1, self.fc2]:
            if isinstance(m, nn.Linear):
                kaiming_normal_(m.weight.data)

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.bn(x)
        x = self.act1(x)
        x = self.dropout1(x)
        x = self.fc2(x)
        x = self.dropout2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
```

