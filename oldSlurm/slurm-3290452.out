class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        layers = [
            ('FCT', FCT(img_channels, 12)),
            ('DFSEB1', DFSEBV2(12, 3, True)),
            ('EVE', EVE(12, 48)),
            ('DFSEB2', DFSEBV2(48, 3, True)),
            ('ME3', ME(48, 96)),
            ('DFSEB3', DFSEBV2(96, 3, True)),
            ('ME4', ME(96, 192)),
            ('DFSEB4', DFSEBV2(192, 3, True)),
            ('ME5', ME(192, 384)),
            ('DFSEB5', DFSEBV2(384, 3, True)),
            ('DW', DW(384, 3)),
            ('gavg', nn.AdaptiveAvgPool2d((1,1))),
            ('drop', nn.Dropout(0.5)),
            ('fc', nn.Linear(384, class_num))
        ]
        self.net = nn.Sequential(OrderedDict(layers))
        
    def forward(self, x):
        x = self.net(x)
        x = x.view(-1, x.size(1))
        return x

