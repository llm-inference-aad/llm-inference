import torch
import torch.nn as nn
from torch.nn import functional as F

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        self.channels = cin
        # Use adaptive average pooling for down-sampling
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        # Layer normalization for channel-wise statistics
        self.ln = nn.LayerNorm(cin)
        # Sigmoid activation for attention weights
        self.act = nn.Sigmoid()
        # Optional depth-wise separable convolution for better feature mixing
        self.depth_conv = nn.Conv2d(
            cin, cin, kernel_size=3, padding=1,
            groups=cin, bias=False
        )
        # Batch normalization after depth-wise conv
        self.bn_depth = nn.BatchNorm2d(cin)
        # Point-wise convolution for dimension reduction/expansion
        self.point_conv = nn.Conv2d(cin, cin//2, kernel_size=1)
        self.bn_point = nn.BatchNorm2d(cin//2)
        # Final expansion back to original channels
        self.expand_conv = nn.Conv2d(cin//2, cin, kernel_size=1)

    def forward(self, x):
        # Store residual connection
        residual = x
        
        # Global average pooling and layer norm
        x = self.gavg(x)
        x = x.view(-1, self.channels)
        x = self.ln(x)
        x = x.view(-1, self.channels, 1, 1)
        
        # Depth-wise separable convolution for feature enrichment
        identity = x
        x = self.depth_conv(x)
        x = self.bn_depth(x)
        x = F.relu(x)
        x += identity  # Skip connection
        
        # Dimension reduction and non-linearity
        x = self.point_conv(x)
        x = self.bn_point(x)
        x = F.relu(x)
        
        # Expand back to original channels
        x = self.expand_conv(x)
        
        # Apply sigmoid activation for attention weights
        x = self.act(x)
        
        # Channel-wise multiplication with residual
        return residual * x

