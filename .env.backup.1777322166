# Configuration: vLLM Only (PagedAttention + Prefix Caching)
# This runs with vLLM backend without constraints or speculation
# Use for vLLM baseline performance

USE_VLLM=true
VLLM_BACKEND=true

# LLM Inference Environment Variables
LLM_INFERENCE_ROOT_DIR=/home/hice1/jgil37/scratch/llm-inference
VENV_PATH=/home/hice1/jgil37/scratch/llm-inference/venv

# Model paths (Llama on cluster)
MODEL_PATH=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct
MODEL_PATH_SIMPLE=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct

# vLLM Configuration
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.95
MAX_MODEL_LEN=32768
VLLM_DTYPE=bfloat16
ENABLE_PREFIX_CACHING=true

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
SERVER_WORKERS=1
BATCH_SIZE=8

# LLM Configuration
LLM_MODEL=local_server
MAX_NEW_TOKENS_DEFAULT=800
MAX_NEW_TOKENS_SERVER=1648

# Disable advanced features
CONSTRAINED_DECODING_ENABLED=false
CONSTRAINT_TYPE=
ENABLE_SPECULATIVE_DECODING=false

# Evolution Parameters
NUM_EOT_ELITES=2
START_POPULATION_SIZE=8
NUM_GENERATIONS=1
PROB_EOT=0.25
PROB_QC=0.0

# API Keys
GEMINI_API_KEY=AIzaSyBFB1dtVV0YHbQhVVVQHBWjNGQ9s4bo6io
DEEPSEEK_API_KEY=sk-904e2c59d6e241afab18c2b2d00d6f20
HF_TOKEN=your_huggingface_token_here
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here
# Added by switch_config.sh
RUN_ID="vllm"
RUN_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/vllm"
RUN_METRICS_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/vllm/metrics"
RUN_LOG_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/vllm/logs"
RUN_ERRORS_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/vllm/errors"
