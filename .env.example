# LLM Inference Environment Variables
# Copy this file to .env and update the values for your environment

LLM_INFERENCE_ROOT_DIR=/home/hice1/rmanimaran8/scratch/llm-inference/llm-inference
VENV_PATH=/home/hice1/rmanimaran8/scratch/llm-inference/llm-inference/.venv

# Model paths
MODEL_PATH=/storage/ice-shared/vip-vvk/llm_storage/deepseek-ai/DeepSeek-R1-Distill-Qwen-32B

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
BATCH_SIZE=8
BATCH_WAIT_TIME=2

# LLM Configuration
LLM_MODEL=local_server
MAX_NEW_TOKENS_DEFAULT=32000
MAX_NEW_TOKENS_SERVER=32000
MIXTRAL_MAX_NEW_TOKENS=32000

# Evolution Parameters
NUM_EOT_ELITES=2
START_POPULATION_SIZE=8
NUM_GENERATIONS=20
PROB_EOT=0.25
PROB_QC=0.0

# API Keys and Tokens
GEMINI_API_KEY=your_gemini_api_key_here
HF_TOKEN=your_huggingface_token_here
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here

# File Paths
HOSTNAME_LOG_FILE=/home/hice1/rmanimaran8/scratch/llm-inference/llm-inference/hostname.log
DATA_PATH=./cifar10

# CUDA Configuration
CUDA_VISIBLE_DEVICES=0
MKL_THREADING_LAYER=GNU
TOKENIZERS_PARALLELISM=false

# LLM Generation Parameters
DEFAULT_TOP_P=0.8
DEFAULT_TEMPERATURE=0.7
SERVER_TOP_P=0.15
SERVER_TEMPERATURE=0.1
SERVER_REPETITION_PENALTY=1.1

# Local/Remote Configuration
LOCAL=true
RUN_COMMAND=bash
DELAYED_CHECK=false

# Device Configuration
DEVICE=auto
MACOS=false

# Cache Configuration
USE_CACHE=0
