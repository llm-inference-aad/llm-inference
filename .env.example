# LLM Inference Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All model checkpoints are pre-staged at the shared cluster path — no download needed.

# ──────────────────────────────────────────────────
# Project paths  (set per-user / per-cluster)
# ──────────────────────────────────────────────────
LLM_INFERENCE_ROOT_DIR=/home/<GATECH_USER>/scratch/llm-inference
RUN_ID=${RUN_ID:-server-only}
RUN_DIR=${RUN_DIR:-${LLM_INFERENCE_ROOT_DIR}/runs/${RUN_ID}}
RUN_LOG_DIR=${RUN_LOG_DIR:-${RUN_DIR}/logs}
RUN_METRICS_DIR=${RUN_METRICS_DIR:-${RUN_DIR}/metrics}
RUN_ERRORS_DIR=${RUN_ERRORS_DIR:-${RUN_DIR}/errors}
SLURM_LOG_DIR=${SLURM_LOG_DIR:-${RUN_LOG_DIR}}
SLURM_ERROR_DIR=${SLURM_ERROR_DIR:-${RUN_ERRORS_DIR}}
METRICS_PATH=${METRICS_PATH:-${RUN_METRICS_DIR}}

# Virtual environment path
VENV_PATH=/home/<GATECH_USER>/scratch/llm-inference/.venv

# ──────────────────────────────────────────────────
# Model selection
# All models are staged at /storage/ice-shared/vip-vvk/llm_storage/
# Uncomment the preset you want; keep the others commented out.
# ──────────────────────────────────────────────────

# ── GLM-4.7-Flash (default — fast, fits 2×A100 or 1×H100 at TP=2) ──
MODEL_PATH=/storage/ice-shared/vip-vvk/llm_storage/zai-org/GLM-4.7-Flash
MODEL_ID=zai-org/GLM-4.7-Flash
MODEL_REVISION=7dd20894a642a0aa287e9827cb1a1f7f91386b67
MODEL_VERSION=4.7
MODEL_QUANTIZATION=bf16

# ── Llama-3.3-70B-Instruct (high quality, requires 2×H100 / TENSOR_PARALLEL_SIZE=2) ──
# MODEL_PATH=/storage/ice-shared/vip-vvk/llm_storage/meta-llama/Llama-3.3-70B-Instruct
# MODEL_ID=meta-llama/Llama-3.3-70B-Instruct
# MODEL_REVISION=6f6073b423013f6a7d4d9f39144961bfbfbc386b
# MODEL_VERSION=3.3
# MODEL_QUANTIZATION=bf16

# ── Nemotron-Super-49B (NVIDIA reasoning model, requires 2×H100) ──
# MODEL_PATH=/storage/ice-shared/vip-vvk/llm_storage/nvidia/Llama-3_3-Nemotron-Super-49B-v1
# MODEL_ID=nvidia/Llama-3_3-Nemotron-Super-49B-v1
# MODEL_REVISION=main
# MODEL_VERSION=1.0
# MODEL_QUANTIZATION=bf16

# ──────────────────────────────────────────────────
# Server configuration
# ──────────────────────────────────────────────────
SERVER_HOST=${SERVER_HOST:-0.0.0.0}
SERVER_PORT=${SERVER_PORT:-8000}
SERVER_WORKERS=${SERVER_WORKERS:-1}
SERVER_BATCH_SIZE=${SERVER_BATCH_SIZE:-1}

# LLM configuration and fallback settings
LOCAL_SERVER_TIMEOUT=14400
LOCAL_SERVER_MAX_RETRIES=3
ENABLE_LLM_REMOTE_FALLBACK=false
LLM_REMOTE_FALLBACK_TARGET=mixtral_hf
LLM_GENERATION_MAX_RETRIES=3
EPOCHS=24

# Log file paths
HOSTNAME_LOG_FILE=${HOSTNAME_LOG_FILE:-${RUN_LOG_DIR}/hostname.log}
LOADBALANCER_LOG_FILE=${LOADBALANCER_LOG_FILE:-${RUN_LOG_DIR}/loadbalancer.log}
SERVER_REGISTRY_FILE=${SERVER_REGISTRY_FILE:-${RUN_LOG_DIR}/servers.json}

# CUDA configuration
# NOTE: Leave CUDA_VISIBLE_DEVICES commented out to allow SLURM to manage GPU visibility.
# Uncomment only for single-GPU local testing.
# CUDA_VISIBLE_DEVICES=0
MKL_THREADING_LAYER=GNU

# ──────────────────────────────────────────────────
# RAG
# ──────────────────────────────────────────────────
RAG_ENABLED=false
# LLM_DIRECT_HTTP=true uses direct HTTP to the running vLLM server (fast).
# LLM_DIRECT_HTTP=false spawns new sbatch jobs per inference call (slow, legacy/deprecated).
LLM_DIRECT_HTTP=true
RAG_RERANKER_ENABLED=true

# Pareto-aware mutation logging policy (PR 5)
# RAG_LOG_POLICY controls which events get is_pareto_eligible=True in the ledger.
#   "pareto"   — per-generation percentile windows (default, recommended).
#   "absolute" — use RAG_MIN_ACCURACY / RAG_MAX_PARAMETERS absolute thresholds.
RAG_LOG_POLICY=pareto
# Top-N% of test_accuracy within the current generation to mark eligible.
# Uses ceil for inclusivity: 10% of 7 events = ceil(0.7) = 1 event eligible.
RAG_LOG_TOP_ACCURACY_PCT=10.0
# Bottom-N% of total_params within the current generation to mark eligible.
RAG_LOG_BOTTOM_PARAMS_PCT=10.0

# ──────────────────────────────────────────────────
# HuggingFace authentication
# ──────────────────────────────────────────────────
HF_TOKEN=

# ──────────────────────────────────────────────────
# vLLM engine configuration
# ──────────────────────────────────────────────────
VLLM_BACKEND=true
TENSOR_PARALLEL_SIZE=2      # 1 for single-GPU models, 2 for 49B+/70B models
GPU_MEMORY_UTILIZATION=0.95 # Fraction of GPU VRAM reserved for KV cache after weights load
MAX_MODEL_LEN=8192          # Max context window (prompt + completion). Tune up if needed.
ENABLE_PREFIX_CACHING=true
VLLM_DTYPE=bfloat16
VLLM_QUANTIZATION=          # Leave blank for bf16; set to 'nvfp4' for quantized variants

# ──────────────────────────────────────────────────
# Legacy HF backend settings (not used with vLLM)
# ──────────────────────────────────────────────────
ENABLE_QUANTIZATION=false
