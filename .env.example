# LLM Inference Environment Variables
# Copy this file to .env and update the values for your environment

# Project root directory (update to your workspace path)
LLM_INFERENCE_ROOT_DIR=/path/to/llm-inference

# Virtual environment path
VENV_PATH=/path/to/llm-inference/.venv

# Model paths (Options: Mixtral-8x7B-Instruct-v0.1, Llama-3.3-70B-Instruct)
# Update to match your cluster's shared storage location
MODEL_PATH=/storage/ice-shared/vip-vvk/llm_storage/meta-llama/Llama-3.3-70B-Instruct

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_BATCH_SIZE=1

# LLM configuration and fallback settings
LOCAL_SERVER_TIMEOUT=14400
LOCAL_SERVER_MAX_RETRIES=3
ENABLE_LLM_REMOTE_FALLBACK=false
LLM_REMOTE_FALLBACK_TARGET=mixtral_hf
LLM_GENERATION_MAX_RETRIES=3
EPOCHS=24

# Log file paths (update to your workspace path)
HOSTNAME_LOG_FILE=/path/to/llm-inference/hostname.log

# CUDA configuration
# NOTE: Leave CUDA_VISIBLE_DEVICES commented out to allow Slurm to manage GPU visibility
# Uncomment only for single-GPU local testing
# CUDA_VISIBLE_DEVICES=0
MKL_THREADING_LAYER=GNU

# RAG Constants
RAG_ENABLED=false
LLM_DIRECT_HTTP=true


# Hugging Face token (set this to your actual token for private models)
# HF_TOKEN=your_token_here
# HUGGING_FACE_HUB_TOKEN=your_token_here

# Quantization Settings
# Set to true for 4-bit quantization (faster, less memory)
# Set to false for native precision (requires more memory but may be more accurate)
ENABLE_QUANTIZATION=false
