# LLM Inference Environment Variables
# Copy this file to .env and update the values for your environment

# Project root directory
LLM_INFERENCE_ROOT_DIR=/home/hice1/satmuri6/scratch/llm-inference

# Virtual environment path
VENV_PATH=/home/hice1/satmuri6/scratch/llm-inference/.venv

# Model paths (Options: Mixtral-8x7B-Instruct-v0.1, Llama-3.3-70B-Instruct)
MODEL_PATH=/storage/ice-shared/vip-vvk/llm_storage/hub/models--google--gemma-3-12b-it/snapshots/96b6f1eccf38110c56df3a15bffe176da04bfd80

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
SERVER_BATCH_SIZE=16

# LLM configuration and fallback settings
LOCAL_SERVER_TIMEOUT=14400
LOCAL_SERVER_MAX_RETRIES=3
ENABLE_LLM_REMOTE_FALLBACK=false
LLM_REMOTE_FALLBACK_TARGET=mixtral_hf
LLM_GENERATION_MAX_RETRIES=3
EPOCHS=24

# Log file paths
HOSTNAME_LOG_FILE=/home/hice1/satmuri6/scratch/llm-inference/hostname.log

# CUDA configuration
CUDA_VISIBLE_DEVICES=0
MKL_THREADING_LAYER=GNU

# RAG Constants
RAG_ENABLED=false
LLM_DIRECT_HTTP=true


# Hugging Face token (set this to your actual token)
# HF_TOKEN=your_token_here
# HUGGING_FACE_HUB_TOKEN=your_token_here

# Quantization Settings
ENABLE_QUANTIZATION=true
