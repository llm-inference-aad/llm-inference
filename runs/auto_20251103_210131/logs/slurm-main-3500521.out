import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin // 2)
        self.ln = nn.LayerNorm(cin // 2)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(cin // 2, cin)
        self.act = nn.Sigmoid()
        
        # Spatial attention components
        self.conv1 = nn.Conv2d(cin, cin // 2, kernel_size=1)
        self.conv2 = nn.Conv2d(cin // 2, cin // 2, kernel_size=3, padding=1)
        self.conv3 = nn.Conv2d(cin // 2, cin, kernel_size=1)
        self.sigmoid = nn.Sigmoid()

    def forward(self, x):
        # Channel attention
        y = x
        x_ca = self.gavg(y)
        x_ca = x_ca.view(-1, x_ca.size(1))
        x_ca = self.fc1(x_ca)
        x_ca = self.ln(x_ca)
        x_ca = self.relu(x_ca)
        x_ca = self.fc2(x_ca)
        x_ca = self.act(x_ca)
        x_ca = x_ca.view(-1, x_ca.size(1), 1, 1)

        # Spatial attention
        x_sa = self.conv1(y)
        x_sa = self.relu(x_sa)
        x_sa = self.conv2(x_sa)
        x_sa = self.relu(x_sa)
        x_sa = self.conv3(x_sa)
        x_sa = self.sigmoid(x_sa)

        # Combine attentions
        x_combined = y * x_ca * x_sa
        return x_combined

