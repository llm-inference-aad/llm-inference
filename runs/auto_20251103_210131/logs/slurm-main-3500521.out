import torch.nn as nn
import torch.nn.functional as F

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.gmax = nn.AdaptiveMaxPool2d((1,1))
        self.fc1 = nn.Linear(2 * cin, (2 * cin) // 2)
        self.ln = nn.LayerNorm((2 * cin) // 2)
        self.act1 = nn.Mish()
        self.dropout = nn.Dropout(0.2)
        self.fc2 = nn.Linear((2 * cin) // 2, cin)
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        avg_x = self.gavg(x)
        max_x = self.gmax(x)
        x = torch.cat([avg_x, max_x], dim=1)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.ln(x)
        x = self.act1(x)
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.act(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y 
```

