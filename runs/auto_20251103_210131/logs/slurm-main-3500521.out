Code Snippet 1
```python
import torch.nn as nn
import torch.nn.functional as F

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.gmax = nn.AdaptiveMaxPool2d((1,1))
        self.fc1 = nn.Linear(2 * cin, int(2 * cin / ratio), bias=False)
        self.act1 = nn.Mish()
        self.dropout = nn.Dropout(0.2)
        self.fc2 = nn.Linear(int(2 * cin / ratio), cin, bias=False)
        self.act2 = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        avg_x = self.gavg(x)
        max_x = self.gmax(x)
        x = torch.cat([avg_x, max_x], dim=1)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.act1(x)
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y 
```
Code Snippet 2
```python
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin // 2)
        self.ln = nn.LayerNorm(cin // 2)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(cin // 2, cin)
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.ln(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y 
```

