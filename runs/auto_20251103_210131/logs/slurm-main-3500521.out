import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode
        
    def _min_pool_unfold(self, x, ks=2):
        n, c, h, w = x.size()
        unfold_h = h - ks + 1 if not self.ceil_mode else (h + ks - 1) // ks * ks - h + 1
        unfold_w = w - ks + 1 if not self.ceil_mode else (w + ks - 1) // ks * ks - w + 1
        x_unfold = x.view(n*c, 1, h, w).unfold(2, ks, 1).unfold(3, ks, 1)
        x_min = x_unfold.min(dim=-1)[0].min(dim=-1)[0]
        if self.ceil_mode:
            pad_h = (h + ks - 1) // ks * ks - h
            pad_w = (w + ks - 1) // ks * ks - w
            x_min = F.pad(x_min, (unfold_w//2, unfold_w - unfold_w//2,
                                   unfold_h//2, unfold_h - unfold_h//2))
        return x_min.view(n, c, h - ks + 1 + unfold_h, w - ks + 1 + unfold_w)

    def forward(self, x):
        return self._min_pool_unfold(x, self.ks)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.channel_mixer = nn.Sequential(
            nn.Conv2d(2*cin, cin, 1, 1, bias=False),
            nn.BatchNorm2d(cin),
            nn.ReLU(inplace=True),
            nn.Conv2d(cin, cout, 1, 1, bias=False)
        )
        self.output_bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        max_out = self.maxpool(x)
        min_out = self.minpool(x)
        mixed = torch.cat((max_out, min_out), 1)
        mixed = self.channel_mixer(mixed)
        return self.output_bn(mixed)

