    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, nn.BatchNorm2d):  # Only handle BatchNorm2d now
                g0.append(v.weight)
