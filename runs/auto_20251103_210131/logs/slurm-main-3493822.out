class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True) 
        self.EVE = EVE(12, 48)  
        self.DFSEB2 = DFSEBV2(48, 3, True) 
        self.ME3 = ME(48, 96)  
        self.DFSEB3 = DFSEBV2(96, 3, True) 
        self.ME4 = ME(96, 192)  
        self.DFSEB4 = DFSEBV2(192, 3, True) 
        self.ME5 = ME(192, 384)  
        self.DFSEB5 = DFSEBV2(384, 3, True) 
        self.DW = DW(384, 3)                
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)
        
        # Helper layers for residual connections
        self.res_conv1 = nn.Conv2d(12, 48, kernel_size=1)
        self.res_conv2 = nn.Conv2d(48, 96, kernel_size=1)
        self.res_conv3 = nn.Conv2d(96, 192, kernel_size=1)

    def _residual_connection(self, x, out, conv_layer):
        if conv_layer is not None:
            x = conv_layer(x)
        return out + x

    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x) 
        
        # First residual block
        res_x = x
        x = self.EVE(x)  
        x = self.DFSEB2(x) 
        x = self._residual_connection(res_x, x, self.res_conv1)
        
        x = self.ME3(x)  
        x = self.DFSEB3(x) 
        
        # Second residual block
        res_x = x
        x = self.ME4(x)  
        x = self.DFSEB4(x) 
        x = self._residual_connection(res_x, x, self.res_conv2)
        
        x = self.ME5(x)  
        x = self.DFSEB5(x) 
        
        # Third residual block
        res_x = x
        x = self.DW(x)    
        x = self._residual_connection(res_x, x, self.res_conv3)
        
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

