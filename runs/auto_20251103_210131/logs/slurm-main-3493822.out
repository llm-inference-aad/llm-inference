def pad_num_y(k_s):
    pad_per_side = int((k_s-1)*0.5)
    return pad_per_side
    
class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin)
        self.act = nn.Hardswish()
        # Add squeeze-and-excitation block
        self.se = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(cin, cin//4, 1),
            nn.ReLU(),
            nn.Conv2d(cin//4, cin, 1),
            nn.Sigmoid()
        )

    def forward(self, x):
        identity = x
        x = self.dw(x)
        x = self.act(x)
        # Apply squeeze-and-excitation
        se_weights = self.se(x)
        x = x * se_weights
        return x + identity  # Residual connection

