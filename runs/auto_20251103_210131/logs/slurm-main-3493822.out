```python
import torch
import torch.nn as nn
import torch.nn.functional as F

class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.conv = nn.Conv2d(cin, cin, kernel_size=1)
        self.ln = nn.LayerNorm(cin)
        self.gn = nn.GroupNorm(min(32, cin), cin)
        self.act1 = nn.Sigmoid()
        self.act2 = nn.Swish()
        self.fc = nn.Linear(cin, cin)
        self.dropout = nn.Dropout(0.1)
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = self.conv(x)
        x = x.view(-1, x.size(1))
        ln_out = self.ln(x)
        gn_out = self.gn(x.unsqueeze(-1).unsqueeze(-1)).squeeze(-1).squeeze(-1)
        x = ln_out + gn_out
        x = self.fc(x)
        x = self.dropout(x)
        x = (self.act1(x) * self.act2(x)) / 1.2
        x = x.view(-1, x.size(1), 1, 1)
        return x * y + y * 0.1
```

