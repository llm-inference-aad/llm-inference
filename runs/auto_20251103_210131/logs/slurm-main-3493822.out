```python
class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.dw = nn.Conv2d(cin, cin, 3, 1, 1, groups=cin, bias=False)
        self.bn_dw = nn.BatchNorm2d(cin)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn_pw = nn.BatchNorm2d(cout)
        self.act = nn.ReLU(inplace=True)
        self.dropout = nn.Dropout2d(p=0.2)
        
        # Initialize weights
        nn.init.kaiming_normal_(self.dw.weight, mode='fan_out', nonlinearity='relu')
        nn.init.kaiming_normal_(self.pw.weight, mode='fan_out', nonlinearity='relu')

    def forward(self, x):
        x = self.maxpool(x)
        x = self.dw(x)
        x = self.bn_dw(x)
        x = self.act(x)
        x = self.pw(x)
        x = self.bn_pw(x)
        x = self.act(x)
        x = self.dropout(x)
        return x
```

