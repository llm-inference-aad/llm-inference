import torch.nn.functional as F

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        # Choose number of groups; for simplicity, set G=4
        G = 4
        # Ensure that cin and cout are divisible by G
        assert cin % G == 0 and cout % G == 0, "cin and cout must be divisible by G"
        self.pw1 = nn.Conv2d(cin, cin, 1, groups=G, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.pw2 = nn.Conv2d(cin, cout, 1, groups=G, bias=False)
        self.bn2 = nn.BatchNorm2d(cout)

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw1(x)
        x = self.bn1(x)
        x = F.relu(x)
        # Channel shuffle
        x = self.channel_shuffle(x, 4)
        x = self.pw2(x)
        x = self.bn2(x)
        return x

    @staticmethod
    def channel_shuffle(x, groups):
        """Channel shuffle operation."""
        batchsize, num_channels, height, width = x.size()
        channels_per_group = num_channels // groups
        x = x.view(batchsize, groups, channels_per_group, height, width)
        x = torch.transpose(x, 1, 2).contiguous()
        x = x.view(batchsize, -1, height, width)
        return x

