import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool1 = nn.MaxPool2d(2, ceil_mode=True)
        self.pw1 = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.pw2 = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.maxpool2 = nn.MaxPool2d(2, ceil_mode=True)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        path1 = self.maxpool1(x)
        path1 = self.pw1(path1)
        
        path2 = self.pw2(x)
        path2 = self.maxpool2(path2)
        
        output = path1 + path2
        output = self.bn(output)
        return output
```

