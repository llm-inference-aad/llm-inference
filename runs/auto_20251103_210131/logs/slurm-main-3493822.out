import torch
import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.gmax = nn.AdaptiveMaxPool2d((1,1))
        self.fc1 = nn.Linear(2*cin, int(2*cin/ratio), bias=False)
        self.act1 = nn.ReLU()
        self.fc2 = nn.Linear(int(2*cin/ratio), cin, bias=False)
        self.act2 = nn.Sigmoid()
        self.ln = nn.LayerNorm(int(2*cin/ratio))

    def forward(self, x):
        y = x
        x_avg = self.gavg(x)
        x_max = self.gmax(x)
        x = torch.cat((x_avg, x_max), dim=1)
        x = x.view(-1, x.size()[1])
        x = self.fc1(x)
        x = self.ln(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size()[1], 1, 1)
        return x * y
```

