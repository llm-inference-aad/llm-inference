class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))  
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x*y 
```
Code Snippet 2
```python
class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin // 2)
        self.ln = nn.LayerNorm(cin // 2)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(cin // 2, cin)
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.ln(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y 
```

