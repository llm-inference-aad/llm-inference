import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        # Path A: MaxPool -> PWConv -> BN
        self.path_a = nn.Sequential(
            nn.MaxPool2d(2, ceil_mode=True),
            nn.Conv2d(cin, cout, 1, 1, bias=False),
            nn.BatchNorm2d(cout)
        )
        # Path B: PWConv -> MaxPool -> BN
        self.path_b = nn.Sequential(
            nn.Conv2d(cin, cout, 1, 1, bias=False),
            nn.MaxPool2d(2, ceil_mode=True),
            nn.BatchNorm2d(cout)
        )
        # Final layers to combine outputs
        self.final_pw = nn.Conv2d(2 * cout, cout, 1, 1, bias=False)
        self.final_bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        a = self.path_a(x)
        b = self.path_b(x)
        combined = torch.cat((a, b), dim=1)
        combined = self.final_pw(combined)
        combined = self.final_bn(combined)
        return combined

