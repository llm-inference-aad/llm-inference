        self.bn1 = nn.BatchNorm2d(cout//2)
        
        # Path 2: maxpool -> pw -> bn
        self.mp2 = nn.MaxPool2d(2, ceil_mode=True)
        self.pw2 = nn.Conv2d(cin, cout//2, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cout//2)
        
        # Optional: combine the outputs
