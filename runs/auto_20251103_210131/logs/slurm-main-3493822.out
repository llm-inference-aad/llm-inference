class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Sigmoid()
        self.conv1 = nn.Conv2d(cin, cin//2, kernel_size=1)
        self.relu = nn.ReLU(inplace=True)
        self.conv2 = nn.Conv2d(cin//2, cin, kernel_size=1)
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        
        z = self.conv1(y)
        z = self.relu(z)
        z = self.conv2(z)
        
        return y * x + z

