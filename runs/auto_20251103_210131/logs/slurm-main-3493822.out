import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin, ratio=2):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        mid_channels = cin // ratio
        self.fc1 = nn.Linear(cin, mid_channels)
        self.ln = nn.LayerNorm(mid_channels)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(mid_channels, cin)
        self.act = nn.Sigmoid()
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.ln(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y

