import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode
        self.log_scale = nn.Parameter(torch.zeros(1))

    def forward(self, x):
        scale = torch.exp(self.log_scale)
        return -F.max_pool2d(-(scale * x), self.ks, ceil_mode=self.ceil_mode)

class SqueezeExcitation(nn.Module):
    def __init__(self, channels, reduction_ratio=16):
        super().__init__()
        self.squeeze = nn.AdaptiveAvgPool2d(1)
        self.excite = nn.Sequential(
            nn.Linear(channels, channels // reduction_ratio),
            nn.ReLU(inplace=True),
            nn.Linear(channels // reduction_ratio, channels),
            nn.Sigmoid()
        )

    def forward(self, x):
        s = self.squeeze(x)
        s = s.view(s.size(0), -1)
        s = self.excite(s)
        s = s.unsqueeze(2).unsqueeze(3)
        return x * s

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.se_block = SqueezeExcitation(3*cin)

    def forward(self, x):
        x = torch.cat((
            self.maxpool(x),
            self.minpool(x),
            self.dw(x),
        ), 1)
        x = self.se_block(x)
        x = self.pw(x)
        x = self.bn(x)
        return x
```

