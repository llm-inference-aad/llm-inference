class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        # Bottleneck layers
        k = max(cin, cout) // 2
        self.pw1 = nn.Conv2d(cin, k, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(k)
        self.relu = nn.ReLU(inplace=True)
        self.pw2 = nn.Conv2d(k, cout, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cout)

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.relu(x)
        x = self.pw2(x)
        x = self.bn2(x)
        return x

