```python
import torch.optim as optim
from torch import nn

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, nn.BatchNorm2d):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        optimizer = optim.SGD(g0, lr, 0.9, nesterov=nesterov)
        optimizer.add_param_group({'params': g1, 'weight_decay': weight_decay})
        optimizer.add_param_group({'params': g2})
    else:
        optimizer = optim.SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
    return optimizer
```

