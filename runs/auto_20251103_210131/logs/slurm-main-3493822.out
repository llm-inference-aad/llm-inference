        super().__init__()
        self.pw1 = nn.Conv2d(cin, cout // 2, 1, 1, bias=False)
        self.mp1 = nn.MaxPool2d(2, ceil_mode=True)
        self.bn1 = nn.BatchNorm2d(cout // 2)
        
        self.mp2 = nn.MaxPool2d(2, ceil_mode=True)
        self.pw2 = nn.Conv2d(cin, cout // 2, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cout // 2)
        
        self.combine_bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        x1 = self.pw1(x)
        x1 = self.mp1(x1)
        x1 = self.bn1(x1)
        
        x2 = self.mp2(x)
        x2 = self.pw2(x2)
        x2 = self.bn2(x2)
        
        x_combined = torch.cat([x1, x2], dim=1)
        x_combined = self.combine_bn(x_combined)
        
        return x_combined

