def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    import tensorflow as tf
    
    g0_params = []
    g1_params = []
    g2_params = []
    
    for layer in model.layers:
        for var in layer.trainable_weights:
            if isinstance(layer, tf.keras.layers.BatchNormalization) or \
               isinstance(layer, tf.keras.layers.LayerNormalization):
                # These layers' weights (gamma) go into g0 without decay
                g0_params.append(var)
            elif 'bias' in var.name:
                # Bias terms go into g2
                g2_params.append(var)
            else:
                # Regular weights go into g1 with decay
                g1_params.append(var)
    
    # Now create the optimizer with parameter groups
    if weight_decay!= 0:
        # Define each group with its parameters and settings
        var_groups = [
            {'vars': g0_params},
            {'vars': g1_params, 'weight_decay': weight_decay},
            {'vars': g2_params}
        ]
    else:
        # All params in one group without decay
        var_groups = [{'vars': g0_params + g1_params + g2_params}]
    
    # Create the SGD optimizer
    optimizer = tf.keras.optimizers.SGD(
        learning_rate=lr,
        momentum=0.9,
        nesterov=nesterov,
        var_list=var_groups
    )
    
    return optimizer

