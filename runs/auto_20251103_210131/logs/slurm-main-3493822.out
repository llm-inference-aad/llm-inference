class MinPool2d_x(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class EVE(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_x(2, ceil_mode=True)
        self.expansion_conv = nn.Conv2d(cin, 2*cin, 1, 1, bias=False)
        self.depthwise_conv = nn.Conv2d(2*cin, 2*cin, 3, 1, 1, groups=2*cin, bias=False)
        self.pointwise_conv = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.relu = nn.ReLU(inplace=True)

    def forward(self, x):
        x = self.expansion_conv(x)
        x = self.relu(x)
        x = self.depthwise_conv(x)
        x = self.relu(x)
        pooled = torch.cat((
            self.maxpool(x),
            self.minpool(x)
        ), 1)
        pooled = self.pointwise_conv(pooled)
        pooled = self.bn(pooled)
        return pooled + x
