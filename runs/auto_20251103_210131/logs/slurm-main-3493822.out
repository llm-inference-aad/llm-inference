import torch.nn as nn

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw1 = nn.Conv2d(cin, cout // 2, 1, 1, bias=False)
        self.pw2 = nn.Conv2d(cin, cout // 2, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cout // 2)
        self.bn2 = nn.BatchNorm2d(cout // 2)

    def forward(self, x):
        # Branch 1: pw -> maxpool -> bn
        x1 = self.pw1(x)
        x1 = self.maxpool(x1)
        x1 = self.bn1(x1)

        # Branch 2: maxpool -> pw -> bn
        x2 = self.maxpool(x)
        x2 = self.pw2(x2)
        x2 = self.bn2(x2)

        # Concatenate outputs along channel dimension
        return torch.cat([x1, x2], dim=1)

