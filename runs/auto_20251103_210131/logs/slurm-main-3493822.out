import torch
from torch import nn
from torch.optim import SGD
from torch.optim.lr_scheduler import CosineAnnealingWarmRestarts

def get_optimizer(model, lr, weight_decay=0, nesterov=True, max_epochs=100, warmup_epochs=10, clip_value=1.0):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                g1.append(v.weight)
        
        opt = SGD([{'params': g0}, {'params': g1, 'weight_decay': weight_decay}, {'params': g2}], 
                  lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    
    # Warmup scheduler
    warmup_factor = lr / (warmup_epochs * len(list(opt.param_groups)[0]['params']))
    warmup.scheduler = torch.optim.lr_scheduler.LinearLR(opt, start_factor=warmup_factor, total_iters=warmup_epochs)
    
    # Cosine annealing scheduler
    main_scheduler = CosineAnnealingWarmRestarts(opt, T_0=max_epochs - warmup_epochs, eta_min=lr/10)
    
    # Combine schedulers
    scheduler = torch.optim.lr_scheduler.SequentialLR(opt, schedulers=[warmup.scheduler, main_scheduler], milestones=[warmup_epochs])
    
    # Gradient clipping
    def clip_grads(params):
        torch.nn.utils.clip_grad_norm_(params, clip_value)
    
    opt.step = lambda: (
        clip_grads(opt.param_groups[0]['params']),
        opt.step()
    )
    
    return opt

