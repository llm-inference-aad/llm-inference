```python
class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.res1 = nn.Sequential(nn.Conv2d(12, 12, kernel_size=1), nn.BatchNorm2d(12))
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.res2 = nn.Sequential(nn.Conv2d(48, 48, kernel_size=1), nn.BatchNorm2d(48))
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.res3 = nn.Sequential(nn.Conv2d(96, 96, kernel_size=1), nn.BatchNorm2d(96))
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.res4 = nn.Sequential(nn.Conv2d(192, 192, kernel_size=1), nn.BatchNorm2d(192))
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.res5 = nn.Sequential(nn.Conv2d(384, 384, kernel_size=1), nn.BatchNorm2d(384))
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)

    def forward(self, x):
        x = self.FCT(x)
        identity = x
        x = self.DFSEB1(x)
        x += self.res1(identity)
        x = self.EVE(x)
        identity = x
        x = self.DFSEB2(x)
        x += self.res2(identity)
        x = self.ME3(x)
        identity = x
        x = self.DFSEB3(x)
        x += self.res3(identity)
        x = self.ME4(x)
        identity = x
        x = self.DFSEB4(x)
        x += self.res4(identity)
        x = self.ME5(x)
        identity = x
        x = self.DFSEB5(x)
        x += self.res5(identity)
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x
```

