```python
import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin // 16)
        self.relu = nn.ReLU(inplace=True)
        self.fc2 = nn.Linear(cin // 16, cin)
        self.bn = nn.BatchNorm1d(cin)
        self.act = nn.Sigmoid()

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.bn(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

