```python
def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    if weight_decay!= 0:
        g0, g1, g2 = [], [], []
        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):
                if isinstance(v, nn.Conv2d):
                    g1.append(v.weight)  # Higher weight decay for Conv layers
                else:
                    g1.append(v.weight)
        
        opt = SGD([
            {'params': g0, 'lr': lr,'momentum': 0.9, 'nesterov': nesterov},
            {'params': g1, 'lr': lr,'momentum': 0.9, 'nesterov': nesterov, 'weight_decay': weight_decay},
            {'params': g2, 'lr': lr * 2}  # Separate LR for biases
        ])
    else:
        opt = SGD(model.parameters(), lr, 0.9, nesterov=nesterov)
    return opt
```

