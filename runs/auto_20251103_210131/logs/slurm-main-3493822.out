class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        # Layers for path 1: MaxPool -> PW
        self.maxpool1 = nn.MaxPool2d(2, ceil_mode=True)
        self.pw1 = nn.Conv2d(cin, cout, 1, 1, bias=False)
        # Layers for path 2: PW -> MaxPool
        self.pw2 = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.maxpool2 = nn.MaxPool2d(2, ceil_mode=True)
        # Shared BN layer
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        # Path 1: MaxPool -> PW
        path1 = self.maxpool1(x)
        path1 = self.pw1(path1)
        # Path 2: PW -> MaxPool
        path2 = self.pw2(x)
        path2 = self.maxpool2(path2)
        # Combine paths
        output = path1 + path2
        # Apply BN
        output = self.bn(output)
        return output

Wait, but in this setup, each path produces a tensor of shape [N, cout, H/2, W/2], which can be added together. Then, the combined output is passed through bn.

