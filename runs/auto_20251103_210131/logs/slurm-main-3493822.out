        x_ln = self.ln(x)
        x = self.gavg(x_ln)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.relu(x)
        x = self.fc2(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
