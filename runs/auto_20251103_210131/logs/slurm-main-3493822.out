import torch.nn as nn

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEB1 = DFSEBV2(12, 3, True)
        self.bn1 = nn.BatchNorm2d(12)
        
        self.EVE = EVE(12, 48)
        self.DFSEB2 = DFSEBV2(48, 3, True)
        self.bn2 = nn.BatchNorm2d(48)
        
        self.ME3 = ME(48, 96)
        self.DFSEB3 = DFSEBV2(96, 3, True)
        self.bn3 = nn.BatchNorm2d(96)
        self.res_proj1 = nn.Conv2d(48, 96, kernel_size=1)
        
        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.bn4 = nn.BatchNorm2d(192)
        self.res_proj2 = nn.Conv2d(96, 192, kernel_size=1)
        
        self.ME5 = ME(192, 384)
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.bn5 = nn.BatchNorm2d(384)
        self.res_proj3 = nn.Conv2d(192, 384, kernel_size=1)
        
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)
    
    def _channel_attention(self, x, reduction=16):
        b, c, _, _ = x.size()
        avg_pool = nn.AdaptiveAvgPool2d(1)(x)
        fc1 = nn.Conv2d(c, c // reduction, kernel_size=1, bias=False)(avg_pool)
        relu = nn.ReLU(inplace=True)(fc1)
        fc2 = nn.Conv2d(c // reduction, c, kernel_size=1, bias=False)(relu)
        sigmoid = nn.Sigmoid()(fc2)
        return x * sigmoid
    
    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x)
        x = self.bn1(x)
        
        x = self.EVE(x)
        x = self.DFSEB2(x)
        x = self.bn2(x)
        
        skip1 = x
        x = self.ME3(x)
        x = self.DFSEB3(x)
        x = self.bn3(x)
        x = x + self.res_proj1(skip1)
        x = self._channel_attention(x)
        
        skip2 = x
        x = self.ME4(x)
        x = self.DFSEB4(x)
        x = self.bn4(x)
        x = x + self.res_proj2(skip2)
        x = self._channel_attention(x)
        
        skip3 = x
        x = self.ME5(x)
        x = self.DFSEB5(x)
        x = self.bn5(x)
        x = x + self.res_proj3(skip3)
        x = self._channel_attention(x)
        
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

