```python
class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.FCT = FCT(img_channels, 12)
        self.DFSEBs = nn.ModuleList([
            DFSEBV2(12, 3, True),
            DFSEBV2(48, 3, True),
            DFSEBV2(96, 3, True),
            DFSEBV2(192, 3, True),
            DFSEBV2(384, 3, True)
        ])
        self.EVE = EVE(12, 48)
        self.MEs = nn.ModuleList([
            ME(48, 96),
            ME(96, 192),
            ME(192, 384)
        ])
        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)
    
    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEBs[0](x)
        x = self.EVE(x)
        x = self.DFSEBs[1](x)
        x = self.MEs[0](x)
        x = self.DFSEBs[2](x)
        x = self.MEs[1](x)
        x = self.DFSEBs[3](x)
        x = self.MEs[2](x)
        x = self.DFSEBs[4](x)
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x
```

