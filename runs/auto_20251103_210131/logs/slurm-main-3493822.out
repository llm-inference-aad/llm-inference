import torch.nn as nn

def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side

class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        self.seln = SE_LN(cin) if is_LN else SE(cin, 3)
        
        self.block2 = nn.Sequential(
            nn.Conv2d(cin, cin, 1, 1, bias=False),
            nn.BatchNorm2d(cin),
            nn.Hardswish(),
            nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        )

    def _process_block(self, x, pw, bn, act, dw, se):
        y = x
        x = pw(x)
        x = bn(x)
        x = act(x)
        x = dw(x)
        x = se(x)
        return x + y

    def forward(self, x):
        x = self._process_block(x, self.pw1, self.bn1, self.act1, self.dw1, self.seln)
        x = self._process_block(x, *self.block2.children())
        return x
