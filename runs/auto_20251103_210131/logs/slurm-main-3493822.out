import torch.nn as nn

class ExquisiteNetV2(nn.Module):
    def __init__(self, class_num, img_channels):
        super().__init__()
        self.initial_block = nn.Sequential(
            FCT(img_channels, 12),
            DFSEBV2(12, 3, True),
            EVE(12, 48),
            DFSEBV2(48, 3, True)
        )
        
        self.middle_blocks = nn.Sequential(
            ME(48, 96),
            DFSEBV2(96, 3, True),
            ME(96, 192),
            DFSEBV2(192, 3, True),
            ME(192, 384),
            DFSEBV2(384, 3, True)
        )
        
        self.final_block = nn.Sequential(
            DW(384, 3),
            nn.AdaptiveAvgPool2d((1,1)),
            nn.Dropout(0.5),
            nn.Flatten(),
            nn.Linear(384, class_num)
        )

    def forward(self, x):
        x = self.initial_block(x)
        x = self.middle_blocks(x)
        x = self.final_block(x)
        return x

