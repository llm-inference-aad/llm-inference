import torch
import torch.nn as nn
import torch.nn.functional as F

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, cin//2, bias=False)
        self.fc2 = nn.Linear(cin//2, cin, bias=False)
        self.act = nn.Sigmoid()
        self.norm = nn.LayerNorm(cin)
        self.dropout = nn.Dropout(0.2)

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.norm(x)
        x = F.relu(self.fc1(x))
        x = self.dropout(x)
        x = self.fc2(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y

