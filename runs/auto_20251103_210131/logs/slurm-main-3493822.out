class SE_LN(nn.Module):
    def __init__(self, cin):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))  
        self.ln = nn.LayerNorm(cin)
        self.act = nn.Sigmoid()
        self.gmax_h = nn.AdaptiveMaxPool2d((cin,1))
        self.gmax_w = nn.AdaptiveMaxPool2d((1,cin))
        self.conv = nn.Conv2d	cin*2, cin, kernel_size=1)
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        
        max_h = self.gmax_h(y)
        max_w = self.gmax_w(y).permute(0,1,3,2)
        max_out = torch.cat([max_h, max_w], dim=1)
        max_out = self.conv(max_out)
        max_out = self.act(max_out)
        
        return y * x * max_out
```

