import torch.nn as nn
from torch import Tensor

def pad_num_y(k_s):
    return (k_s - 1) // 2

class DW(nn.Module):
    def __init__(self, cin, dw_s):
        super(DW, self).__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, pad_num_y(dw_s), groups=cin)
        self.act = nn.Hardsigmoid() if hasattr(nn, 'Hardsigmoid') else nn.Hardswish()
    
    def forward(self, x: Tensor) -> Tensor:
        return self.act(self.dw(x))

