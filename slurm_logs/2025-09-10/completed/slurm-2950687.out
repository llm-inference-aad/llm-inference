        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.cin = cin # Retain cin for later use
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        self.relu = nn.ReLU(inplace=True)  # Add ReLU activation

        # Optional: Squeeze-and-Excitation block after the PW conv
        self.se = nn.Sequential(
            nn.AdaptiveAvgPool2d(1),
            nn.Conv2d(cout, cout // 4, 1, bias=False),
            nn.ReLU(inplace=True),
            nn.Conv2d(cout // 4, cout, 1, bias=False),
            nn.Sigmoid()
        )

        # Optional: Add a skip connection with learned scaling
        self.skip_scale = nn.Parameter(torch.zeros(1)) # Initialize to zero

    def forward(self, x):
        dw_x = self.dw(x)
        maxpool_x = self.maxpool(x)
        minpool_x = self.minpool(x)

        x_concat = torch.cat((maxpool_x, minpool_x, dw_x), 1)
        x = self.pw(x_concat)
        x = self.bn(x)
        x = self.relu(x) # Apply ReLU activation

        # Squeeze-and-Excitation
        se_x = self.se(x)
        x = x * se_x # Element-wise multiplication

        # Optional: Skip connection (assuming input and output have compatible spatial dimensions)
        # Can enable this skip connection to improve performance
        # Resizing input x to match output x if necessary to ensure a viable skip connection
        if x.shape[-2:] != x.shape[-2:]:  # Check spatial dimensions
             x_resized = F.interpolate(x, size=(x.shape[-2], x.shape[-1]), mode='nearest')  # Resize, mode can be 'nearest', 'bilinear', etc.
             x = x + self.skip_scale * x_resized
        else:
            x = x + self.skip_scale * x

        return x

