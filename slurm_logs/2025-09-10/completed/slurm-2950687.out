        self.pw = nn.Conv2d(2*cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)

    def forward(self, x):
        max_pooled = self.maxpool(x)
        min_pooled = self.minpool(x)

        # The "Subtle Interaction"
        combined = torch.cat((max_pooled, min_pooled), 1)
        interaction = torch.sin(combined) * combined #Nonlinear interaction
        
        x = self.pw(interaction)
        x = self.bn(x)
        return x

