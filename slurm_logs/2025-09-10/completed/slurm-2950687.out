import torch
import torch.nn as nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True):  
    """
    Configures and returns an SGD optimizer with unconventional modifications.
    """
    # Unconventional Dampening Factor
    dampening_factor = 0.01 # Default dampening
    
    if weight_decay != 0:
        g0, g1, g2 = [], [], []  # optimizer parameter groups
        
        layer_depth = 0 # Track layer depth for momentum adaptation (completely experimental!)

        for v in model.modules():
            if hasattr(v, 'bias') and isinstance(v.bias, nn.Parameter):  # bias
                g2.append(v.bias)
            if isinstance(v, (nn.BatchNorm2d, nn.LayerNorm)):  # weight (no decay)
                g0.append(v.weight)
            elif hasattr(v, 'weight') and isinstance(v.weight, nn.Parameter):  # weight (with decay)
                g1.append(v.weight)

            layer_depth += 1 # Increment layer depth

        # Adaptive Momentum (Depth-Dependent - could be nonsense, but let's try!)
        momentum_base = 0.9
        adaptive_momentum = min(0.99, momentum_base + (layer_depth * 0.001)) #momentum adapation based on layer depth.
        
        opt = SGD(g0, lr, momentum=adaptive_momentum, nesterov=nesterov, dampening=dampening_factor)

        # Add a tiny random perturbation to the weight decay for g1.
        weight_decay_perturbed = weight_decay + (torch.randn(1).item() * 1e-6)
        weight_decay_perturbed = max(0, weight_decay_perturbed) # Ensure it's not negative

        opt.add_param_group({'params': g1, 'weight_decay': weight_decay_perturbed})  # add g1 with weight_decay
        opt.add_param_group({'params': g2})  # add g2 (biases)
    else:
        opt = SGD(model.parameters(), lr, momentum=0.9, nesterov=nesterov, dampening=dampening_factor)
    return opt
```

