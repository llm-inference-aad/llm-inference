    def forward(self, x):
        identity = x

        # First Block
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x)
        x = self.dw1(x)
        x = self.seln(x)
        x += identity
        
        # Second Block
        identity = x # Update identity for second residual connection
        x = self.pw2(x)       
        x = self.bn2(x)
        x = self.act2(x)
        x = self.dw2(x)
        x += identity
        return x

