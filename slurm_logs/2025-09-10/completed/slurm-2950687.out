        self.BN3 = nn.BatchNorm2d(96)
        self.drop2 = nn.Dropout(0.2)
        # Residual Connection around ME4
        self.residual4_in = nn.Conv2d(96, 192, kernel_size=1, stride=1, bias=False) #Match dimensions for skip
        self.BN_residual4_in = nn.BatchNorm2d(192)

        self.ME4 = ME(96, 192)
        self.DFSEB4 = DFSEBV2(192, 3, True)
        self.BN4 = nn.BatchNorm2d(192)

        # Residual Connection around ME4
        self.residual4_out = nn.Conv2d(192, 192, kernel_size=1, stride=1, bias=False)  #Match dimensions for skip
        self.BN_residual4_out = nn.BatchNorm2d(192)

        # Bottleneck before ME5 (Dimensionality Reduction)
        self.bottleneck5 = nn.Conv2d(192, 96, kernel_size=1, stride=1, bias=False)
        self.BN_bottleneck5 = nn.BatchNorm2d(96)

        self.ME5 = ME(96, 384) # ME now takes the reduced dimension
        self.DFSEB5 = DFSEBV2(384, 3, True)
        self.BN5 = nn.BatchNorm2d(384)

        self.DW = DW(384, 3)
        self.BN_DW = nn.BatchNorm2d(384)

        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)

    def forward(self, x):
        x = self.FCT(x)
        x = self.DFSEB1(x)
        x = self.BN1(x)
        x = self.EVE(x)
        x = self.DFSEB2(x)
        x = self.BN2(x)
        x = self.drop1(x)

        # Bottleneck
        x_bottleneck = self.bottleneck3(x)
        x_bottleneck = self.BN_bottleneck3(x_bottleneck)
        x = self.ME3(x_bottleneck)

        x = self.DFSEB3(x)
        x = self.BN3(x)
        x = self.drop2(x)

        #Residual Connection Part 1
        residual = self.residual4_in(x)
        residual = self.BN_residual4_in(residual)

        x = self.ME4(x)
        x = self.DFSEB4(x)
        x = self.BN4(x)

        #Residual Connection Part 2
        x = x + residual
        x = self.residual4_out(x)
        x = self.BN_residual4_out(x)

        # Bottleneck
        x_bottleneck = self.bottleneck5(x)
        x_bottleneck = self.BN_bottleneck5(x_bottleneck)

        x = self.ME5(x_bottleneck)

        x = self.DFSEB5(x)
        x = self.BN5(x)
        x = self.DW(x)
        x = self.BN_DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

