# Example 3: SGD with Lookahead
optimizer = get_optimizer(model, lr=0.01, use_lookahead=True)

# Example 4: AdamW with adaptive learning rates and gradient clipping
optimizer = get_optimizer(model, lr=0.001, weight_decay=0.005, optimizer_type="AdamW",
                          use_adaptive_lr=True, gradient_clip_value=1.0)
