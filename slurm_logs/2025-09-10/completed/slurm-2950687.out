import torch
import torch.nn as nn
import torch.nn.functional as F

class SE_LN(nn.Module):
    def __init__(self, cin, reduction_ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.linear1 = nn.Linear(cin, cin // reduction_ratio, bias=False)
        self.linear2 = nn.Linear(cin // reduction_ratio, cin, bias=False)
        self.ln = nn.LayerNorm(cin)
        self.act = nn.SiLU()  # Swish/SiLU activation
        self.scale = nn.Parameter(torch.ones(1)) # Learnable scaling factor for attention
        self.gate = nn.Parameter(torch.zeros(1)) # Learnable gate for attention

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.linear1(x)
        x = self.act(x)
        x = self.linear2(x)
        x = self.ln(x)
        x = self.act(x)
        x = x.view(-1, x.size(1), 1, 1)
        scaled_x = x * self.scale  # Apply learnable scale
        gated_x = self.gate * scaled_x * y + (1 - self.gate) * y
        return gated_x

