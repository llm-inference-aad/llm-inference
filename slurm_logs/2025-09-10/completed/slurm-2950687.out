import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin, reduction_ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.linear1 = nn.Linear(cin, cin // reduction_ratio, bias=False) # Bottleneck
        self.linear2 = nn.Linear(cin // reduction_ratio, cin, bias=False) # Upscale
        self.act = nn.Sigmoid()
        self.cin = cin

    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, self.cin)
        x = self.linear1(x)
        x = self.linear2(x)
        x = self.act(x)
        x = x.view(-1, self.cin, 1, 1)
        return x*y

