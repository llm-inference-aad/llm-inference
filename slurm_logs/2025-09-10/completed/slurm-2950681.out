import torch
import torch.nn as nn
import hashlib


# -- NOTE --
# Note: The classes SE_LN and SE used in this architecture are pre-existing and fully implemented elsewhere.
# It is not necessary to create new implementations or modify these classes for this architecture. They should be used as-is.
# -- NOTE --

def pad_num_x(k_s):
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side


class DFSEBV2(nn.Module):
    def __init__(self, cin, dw_s, is_LN):
        super().__init__()
        self.pw1 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn1 = nn.BatchNorm2d(cin)
        self.act1 = nn.SiLU()
        self.act1_scale = nn.Parameter(torch.ones(1))  # Learnable activation scaling
        self.dw1 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)
        if is_LN:
            self.seln = SE_LN(cin)
        else:
            self.seln = SE(cin, 3)

        self.pw2 = nn.Conv2d(cin, cin, 1, 1, bias=False)
        self.bn2 = nn.BatchNorm2d(cin)
        self.act2 = nn.Hardswish()
        self.act2_scale = nn.Parameter(torch.ones(1))  # Learnable activation scaling
        self.dw2 = nn.Conv2d(cin, cin, dw_s, 1, pad_num_x(dw_s), groups=cin)

        self.stochastic_depth_prob = 0.5  # Initial probability, will adapt
        self.reverse_gradient_injection_factor = 0.01 # A very small amount by default

    def quantum_channel_shuffle(self, x):
        """
        Shuffles channels based on a hash of the input's spatial dimensions.
        """
        batch_size, num_channels, height, width = x.size()
        hash_input = str(height) + str(width)  # Combine dimensions
        hash_value = int(hashlib.sha256(hash_input.encode('utf-8')).hexdigest(), 16)

        # Generate a permutation based on the hash value
        torch.manual_seed(hash_value)  # Seed the RNG
        permutation = torch.randperm(num_channels)
        torch.seed() #reset seed

        # Apply the permutation
        shuffled_x = x[:, permutation, :, :]
        return shuffled_x


    def forward(self, x):
        y = x.clone() # keep the original input for reverse gradient flow

        # --- First Block ---
        x = self.pw1(x)
        x = self.bn1(x)
        x = self.act1(x) * self.act1_scale # Apply scaling after activation

        # Stochastic Depth Adaptation
        input_norm = torch.norm(x)
        adjusted_prob = self.stochastic_depth_prob * (1 - torch.tanh(input_norm / 10)) # Higher norm -> lower dropout

        if self.training and torch.rand(1) < adjusted_prob:
            x = self.dw1(x)
            x = self.quantum_channel_shuffle(x)
            x = self.seln(x)

        x += y

        # --- Second Block ---
        y_intermediate = x.clone() # Store output of the first block

        x = self.pw2(x)
        x = self.bn2(x)
        x = self.act2(x) * self.act2_scale # Apply scaling after activation
        x = self.dw2(x)

        x += y_intermediate

        # --- Reverse Gradient Injection ---
        if self.training:
            y.register_hook(lambda grad: grad - self.reverse_gradient_injection_factor * x.grad)


        return x

