import torch.nn as nn

class SE(nn.Module):
    def __init__(self, cin, ratio):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))

        # Modification 1: Add Batch Normalization
        self.bn1 = nn.BatchNorm1d(cin)

        self.fc1 = nn.Linear(cin, int(cin/ratio), bias=False)
