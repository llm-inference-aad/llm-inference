```python
import torch
import torch.nn as nn
from torch.optim import SGD

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    """
    Returns an SGD optimizer for the given model, with optional weight decay and Nesterov momentum.

    Args:
        model (nn.Module): The model to optimize.
        lr (float): The learning rate.
        weight_decay (float, optional): The weight decay (L2 regularization) to apply. Defaults to 0.
        nesterov (bool, optional): Whether to use Nesterov momentum. Defaults to True.

    Returns:
        torch.optim.SGD: An SGD optimizer instance.
    """
    if weight_decay > 0:
        # Group parameters for weight decay
        decay, no_decay = [], []
        for n, p in model.named_parameters():
            if not p.requires_grad:
                continue  # frozen weights
            if len(p.shape) == 1 or n.endswith(".bias"):
                no_decay.append(p)
            else:
                decay.append(p)

        optim_groups = [
            {'params': decay, 'weight_decay': weight_decay},
            {'params': no_decay, 'weight_decay': 0.0}
        ]
        return SGD(optim_groups, lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        return SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
