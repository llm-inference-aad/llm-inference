            """
            Applies gradient anchoring to the model's parameters, pulling them back
            towards their initial values.  The strength of the anchoring is inversely
            proportional to the parameter's size.
            """
            with torch.no_grad():
                for name, param in model.named_parameters():
                    if name in initial_params:
                        diff = param.data - initial_params[name]
                        anchor_strength = 0.0001 / (param.numel()**0.5)  # Smaller params anchored more strongly
                        param.data.sub_(diff * anchor_strength)  # Pull back

        # Attach the gradient anchor as a closure to the optimizer. Step needs to be called with closure=gradient_anchor
        opt.gradient_anchor = gradient_anchor



    else:
        opt = SGD(model.parameters(), lr, 0.9, nesterov=nesterov)

    return opt

