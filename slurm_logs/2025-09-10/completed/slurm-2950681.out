        self.DW = DW(384, 3)
        self.gavg = nn.AdaptiveAvgPool2d((1, 1))
        self.drop = nn.Dropout(0.5)
        self.fc = nn.Linear(384, class_num)

        # Attention Mechanism
        self.attention1 = SelfAttention(12) #After FCT
        self.attention2 = SelfAttention(48) #After EVE
        self.attention3 = SelfAttention(96) #After ME3
        self.attention4 = SelfAttention(192) #After ME4
        self.attention5 = SelfAttention(384) #After ME5
        

        # Feature Reuse (Concatenation with learned weights)
        self.W_DFSEB1 = nn.Parameter(torch.randn(2)) #For DFSEB1 output and FCT output
        self.W_DFSEB2 = nn.Parameter(torch.randn(2)) #For DFSEB2 output and EVE output
        self.W_DFSEB3 = nn.Parameter(torch.randn(2)) #For DFSEB3 output and ME3 output
        self.W_DFSEB4 = nn.Parameter(torch.randn(2)) #For DFSEB4 output and ME4 output
        self.W_DFSEB5 = nn.Parameter(torch.randn(2)) #For DFSEB5 output and ME5 output
                        
    def forward(self, x):
        # Initial Feature Extraction
        fct_out = self.FCT(x)
        fct_attn = self.attention1(fct_out)

        # Block 1
        dfseb1_out = self.DFSEB1(fct_attn)
        #Feature Reuse - Weighted Concatenation:
        w = F.softmax(self.W_DFSEB1, dim=0)
        x = w[0] * dfseb1_out + w[1] * fct_attn #Reuse FCT output
        
        # Block 2
        eve_out = self.EVE(x)
        eve_attn = self.attention2(eve_out)

        dfseb2_out = self.DFSEB2(eve_attn)
        #Feature Reuse - Weighted Concatenation:
        w = F.softmax(self.W_DFSEB2, dim=0)
        x = w[0] * dfseb2_out + w[1] * eve_attn #Reuse EVE output

        # Block 3
        me3_out = self.ME3(x)
        me3_attn = self.attention3(me3_out)

        dfseb3_out = self.DFSEB3(me3_attn)
        #Feature Reuse - Weighted Concatenation:
        w = F.softmax(self.W_DFSEB3, dim=0)
        x =  w[0] * dfseb3_out + w[1] * me3_attn #Reuse ME3 output

        # Block 4
        me4_out = self.ME4(x)
        me4_attn = self.attention4(me4_out)

        dfseb4_out = self.DFSEB4(me4_attn)
        #Feature Reuse - Weighted Concatenation:
        w = F.softmax(self.W_DFSEB4, dim=0)
        x = w[0] * dfseb4_out + w[1] * me4_attn  #Reuse ME4 output
        
        # Block 5
        me5_out = self.ME5(x)
        me5_attn = self.attention5(me5_out)

        dfseb5_out = self.DFSEB5(me5_attn)
        #Feature Reuse - Weighted Concatenation:
        w = F.softmax(self.W_DFSEB5, dim=0)
        x = w[0] * dfseb5_out + w[1] * me5_attn  #Reuse ME5 output

        # Final Layers
        x = self.DW(x)
        x = self.gavg(x)
        x = self.drop(x)
        x = x.view(-1, x.size(1))
        x = self.fc(x)
        return x

class SelfAttention(nn.Module):
    def __init__(self, in_channels):
        super().__init__()
        self.query = nn.Conv2d(in_channels, in_channels // 8, kernel_size=1)
        self.key = nn.Conv2d(in_channels, in_channels // 8, kernel_size=1)
        self.value = nn.Conv2d(in_channels, in_channels, kernel_size=1)
        self.scale = nn.Parameter(torch.zeros(1))  # Learnable scale parameter

    def forward(self, x):
        b, c, h, w = x.size()
        q = self.query(x).view(b, -1, h * w).permute(0, 2, 1)
        k = self.key(x).view(b, -1, h * w)
        v = self.value(x).view(b, -1, h * w)

        attn = torch.bmm(q, k)
        attn = F.softmax(attn, dim=-1)

        attn_output = torch.bmm(v, attn.permute(0, 2, 1))
        attn_output = attn_output.view(b, c, h, w)
        return x + self.scale * attn_output
```

Key improvements and explanations:

*   **Self-Attention Modules:**  Self-attention layers (`SelfAttention`) are inserted after the `FCT`, `EVE`, `ME3`, `ME4` and `ME5` layers.  This allows the network to dynamically weigh the importance of different spatial regions within the feature maps. The `scale` parameter allows the network to learn how much of the attention output to add back to the original feature map.

*   **Feature Reuse (with Learnable Weights):**  After each `DFSEBV2` block, the output is combined with the input of the previous layer (e.g., `FCT`, `EVE`, `ME3`, `ME4`, `ME5`) using a *weighted concatenation*.  This encourages feature reuse and allows gradients to flow more easily through the network.  The weights (`self.W_DFSEB1`, `self.W_DFSEB2` etc.) are learnable parameters, enabling the network to adaptively determine the optimal contribution of each feature map.  Softmax is applied to ensure the weights sum to 1.

*   **`SelfAttention` Implementation:**  The `SelfAttention` module performs a standard self-attention operation. Query, Key, and Value projections are computed using 1x1 convolutions.

*   **Parameter Initialization:** The weights `self.W_DFSEB1`, `self.W_DFSEB2` etc. are initialized with `torch.randn(2)`.

This revised architecture, while respecting the core building blocks of the original, introduces mechanisms for attention and feature reuse that could significantly improve the model's learning capacity and overall performance. Further experimentation and tuning of hyperparameters (dropout rate, learning rates, attention scaling) will be critical to fully realize the potential of these modifications.


