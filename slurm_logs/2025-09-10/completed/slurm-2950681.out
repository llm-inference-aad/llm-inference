import torch
import torch.nn as nn
import torch.nn.functional as F

class MinPool2d_y(nn.Module):
    def __init__(self, ks, ceil_mode):
        super().__init__()
        self.ks = ks
        self.ceil_mode = ceil_mode

    def forward(self, x):
        return -F.max_pool2d(-x, self.ks, ceil_mode=self.ceil_mode)

class FCT(nn.Module):
    def __init__(self, cin, cout, l1_lambda=1e-5):
        super().__init__()

        # Depthwise convolution - keeping the standard 4x4 kernel, stride 2, padding 1
        self.dw = nn.Conv2d(cin, cin, 4, 2, 1, groups=cin, bias=False)

        # Adaptive MaxPool - The kernel size is set at the time of first forward pass.
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.minpool = MinPool2d_y(2, ceil_mode=True)

        # Pointwise convolution with L1 regularization
        self.pw = nn.Conv2d(3*cin, cout, 1, 1, bias=False)
        self.l1_lambda = l1_lambda #L1 regularization strength

        # Batch Normalization with learnable affine parameters and momentum adjustment
        self.bn = nn.BatchNorm2d(cout, affine=True, momentum=0.05) # Learnable affine parameters

    def forward(self, x):
        # Adaptive pooling kernel size
        #if not hasattr(self, 'maxpool'): #Moved maxpool to init
        #    kernel_size = min(x.shape[2:]) // 4 # Adjust kernel size adaptively
        #    self.maxpool = nn.MaxPool2d(kernel_size, ceil_mode=True)
        #    self.minpool = MinPool2d_y(kernel_size, ceil_mode=True)

        x = torch.cat((
            self.maxpool(x),
            self.minpool(x),
            self.dw(x),
        ), 1)
        x = self.pw(x)

        # L1 regularization on pointwise convolution weights
        if self.l1_lambda > 0:
            l1_loss = torch.abs(self.pw.weight).sum()
            x = x + self.l1_lambda * l1_loss  # Add L1 loss to output (can also penalize in training loop)

        x = self.bn(x)
        return x

