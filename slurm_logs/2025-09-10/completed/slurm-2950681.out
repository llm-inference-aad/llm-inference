import torch
import torch.nn as nn

def pad_num_y(k_s, padding_mode='reflect'):
    """Calculates padding based on kernel size and padding mode."""
    pad_per_side = int((k_s - 1) * 0.5)
    return pad_per_side


class DW(nn.Module):
    def __init__(self, cin, dw_s, padding_mode='reflect', use_bn=True, activation_type='relu6', init_type='kaiming'):
        super().__init__()
        self.dw = nn.Conv2d(cin, cin, dw_s, 1, padding_num_y(dw_s), groups=cin, padding_mode=padding_mode)  #Explicitly use padding_mode
        self.bn = nn.BatchNorm2d(cin) if use_bn else nn.Identity()

        if activation_type == 'hardswish':
            self.act = nn.Hardswish()
        elif activation_type == 'relu6':
            self.act = nn.ReLU6()
        elif activation_type == 'leaky_relu':
            self.act = nn.LeakyReLU(negative_slope=0.1) # Added Leaky ReLU option
        else:
            self.act = nn.ReLU()  # Default ReLU

        self.init_weights(init_type)  # Initialize weights

    def init_weights(self, init_type='kaiming'):
        """Initializes the weights of the convolution layer."""
        if init_type == 'kaiming':
            nn.init.kaiming_normal_(self.dw.weight, mode='fan_out', nonlinearity='relu')
        elif init_type == 'xavier':
            nn.init.xavier_normal_(self.dw.weight)
        elif init_type == 'normal':
            nn.init.normal_(self.dw.weight, mean=0.0, std=0.02) #Common initialization
        else:
            pass # Use default initialization
        if self.dw.bias is not None:
            nn.init.zeros_(self.dw.bias)


    def forward(self, x):
        x = self.dw(x)
        x = self.bn(x)
        x = self.act(x)
        return x

