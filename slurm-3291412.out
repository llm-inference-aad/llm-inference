import torch
import torch.nn as nn
from torch.utils.checkpoint import checkpoint

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        self.bn = nn.BatchNorm2d(cout)
        
        # Helper function for gradient checkpointing
        def create_checkpointed_module(module):
            def func(x):
                return module(x)
            return func
        
        # Apply checkpointing to memory-intensive layers
        self.checkpointed_pw = create_checkpointed_module(self.pw)
        self.checkpointed_bn = create_checkpointed_module(self.bn)

    def forward(self, x):
        x = self.maxpool(x)
        x = checkpoint(self.checkpointed_pw, x)  # Checkpoint PW layer
        x = checkpoint(self.checkpointed_bn, x)  # Checkpoint BN layer
        return x
```

