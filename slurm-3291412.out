class SE(nn.Module):
    def __init__(self, cin, ratio=16):
        super().__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))
        self.fc1 = nn.Linear(cin, int(cin//ratio), bias=False)
        self.act1 = nn.SiLU()  # Changed from ReLU to SiLU
        self.fc2 = nn.Linear(int(cin//ratio), cin, bias=False)
        self.act2 = nn.Sigmoid()
        self.bn = nn.BatchNorm2d(cin)  # Added BatchNorm
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.fc1(x)
        x = self.act1(x)
        x = self.fc2(x)
        x = self.act2(x)
        x = x.view(-1, x.size(1), 1, 1)
        x = self.bn(x)  # Applied BatchNorm before scaling
        return x * y
