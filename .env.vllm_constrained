# Use to measure impact of constraints on latency and output quality

USE_VLLM=true
VLLM_BACKEND=true

# LLM Inference Environment Variables
LLM_INFERENCE_ROOT_DIR=/home/hice1/jgil37/scratch/llm-inference
VENV_PATH=/home/hice1/jgil37/scratch/llm-inference/venv

# Model paths (Llama on cluster)
MODEL_PATH=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct
MODEL_PATH_SIMPLE=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct

# vLLM Configuration
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.95
MAX_MODEL_LEN=32768
VLLM_DTYPE=bfloat16
