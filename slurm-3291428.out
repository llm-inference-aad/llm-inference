import torch
import torch.nn as nn

class SE_LN(nn.Module):
    def __init__(self, cin):
        super(SE_LN, self).__init__()
        self.gavg = nn.AdaptiveAvgPool2d((1,1))  
        self.ln = nn.LayerNorm(cin, eps=1e-5, elementwise_affine=False)  # Modified epsilon and disabled affine
        self.fc = nn.Linear(cin, cin//16, bias=False)  # Added FC layer for dimension reduction
        self.act = nn.Sigmoid()
        self.fc2 = nn.Linear(cin//16, cin, bias=False)  # Added another FC layer for dimension restoration
        
    def forward(self, x):
        y = x
        x = self.gavg(x)
        x = x.view(-1, x.size(1))
        x = self.ln(x)
        x = self.fc(x)
        x = self.act(x)
        x = self.fc2(x)
        x = x.view(-1, x.size(1), 1, 1)
        return x * y
```

