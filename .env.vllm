
USE_VLLM=true
ENABLE_JSON_CONSTRAINTS=true
CONSTRAINT_TYPE=json


# LLM Inference Environment Variables
# Copy this file to .env and update the values for your environment

# Project Configuration
LLM_INFERENCE_ROOT_DIR=/home/hice1/jgil37/scratch/llm-inference
VENV_PATH=/home/hice1/jgil37/scratch/llm-inference/venv

# Model paths (Llama on cluster)
MODEL_PATH=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct
MODEL_PATH_SIMPLE=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct
VLLM_TENSOR_PARALLEL_SIZE=1
# Lower max context so server fits on 80GB GPUs (e.g. H100). Use 0 for model default when only using H200+.
VLLM_MAX_MODEL_LEN=32768
# VLLM_GPU_MEMORY_UTILIZATION=0.9

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
SERVER_WORKERS=1
BATCH_SIZE=8

#BATCH_WAIT_TIME=2
BATCH_WAIT_TIME=0.01

# LLM Configuration
LLM_MODEL=local_server
MAX_NEW_TOKENS_DEFAULT=800
MAX_NEW_TOKENS_SERVER=1648
MIXTRAL_MAX_NEW_TOKENS=2048

# Evolution Parameters
NUM_EOT_ELITES=2
START_POPULATION_SIZE=8
NUM_GENERATIONS=1
PROB_EOT=0.25
PROB_QC=0.0

# API Keys and Tokens
GEMINI_API_KEY=AIzaSyBFB1dtVV0YHbQhVVVQHBWjNGQ9s4bo6io
DEEPSEEK_API_KEY=sk-904e2c59d6e241afab18c2b2d00d6f20
HF_TOKEN=your_huggingface_token_here
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here

# File Paths
HOSTNAME_LOG_FILE=/home/hice1/jgil37/scratch/llm-inference/hostname_vllm.log
DATA_PATH=./cifar10

# CUDA Configuration
# For 8B model, single GPU is typically sufficient.
CUDA_VISIBLE_DEVICES=0
MKL_THREADING_LAYER=GNU
TOKENIZERS_PARALLELISM=false

# LLM Generation Parameters
DEFAULT_TOP_P=0.8
DEFAULT_TEMPERATURE=0.7
SERVER_TOP_P=0.15
SERVER_TEMPERATURE=0.1
SERVER_REPETITION_PENALTY=1.1

# Local/Remote Configuration
# Set LOCAL=false for SLURM cluster mode (parallel execution)
# Set LOCAL=true only for testing on local machine
LOCAL=false

# Timeout for server requests (increase if using HuggingFace backend without vLLM)
LOCAL_SERVER_TIMEOUT=3600

# Server worker threads (only matters when USE_VLLM=false)
SERVER_MAX_WORKERS=4

# Device Configuration
DEVICE=auto
MACOS=false

# Cache Configuration
USE_CACHE=0

