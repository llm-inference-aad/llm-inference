# LLM Inference Environment Configuration
# Copy this file to .env and update with your actual values

# ===================================
# Project Paths
# ===================================
LLM_INFERENCE_ROOT_DIR=/path/to/your/llm-inference/llm-inference
VENV_PATH=/path/to/your/llm-inference/llm-inference/.venv

# ===================================
# Model Configuration
# ===================================
MODEL_PATH=/path/to/your/model
MODEL_PATH_SIMPLE=/path/to/your/model/snapshots/specific-version

# ===================================
# Single Server Configuration
# ===================================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=1
HOSTNAME_LOG_FILE=/path/to/your/hostname.log

# ===================================
# Load Balancer Configuration
# ===================================
# Set USE_LOAD_BALANCER=true to enable load-balanced mode
# Set USE_LOAD_BALANCER=false for single-server mode (backward compatible)
USE_LOAD_BALANCER=false
LOAD_BALANCER_PORT=9000
LOADBALANCER_LOG_FILE=/path/to/your/loadbalancer.log
SERVER_REGISTRY_FILE=/path/to/your/servers.json

# ===================================
# Server Cluster Configuration
# ===================================
# Number of inference servers to spawn (used by start_cluster.sh)
NUM_SERVERS=3
# Base port for servers (servers will use BASE_PORT, BASE_PORT+1, BASE_PORT+2, etc.)
SERVER_BASE_PORT=8000

# ===================================
# CUDA Configuration
# ===================================
CUDA_VISIBLE_DEVICES=0
MKL_THREADING_LAYER=GNU

# ===================================
# API Keys (Optional)
# ===================================
# Uncomment and set your actual tokens if needed
# GEMINI_API_KEY=your_actual_gemini_api_key_here
# HF_TOKEN=your_actual_hf_token_here
# HUGGING_FACE_HUB_TOKEN=your_actual_hf_token_here

# ===================================
# System Prompt (Optional)
# ===================================
# Custom system prompt for LLM requests
# SYSTEM_PROMPT="Output a single fenced code block with runnable Python code and nothing else."

