import torch.nn as nn
import torch.nn.functional as F
from torch.nn import init

class ME(nn.Module):
    def __init__(self, cin, cout):
        super().__init__()
        self.maxpool = nn.MaxPool2d(2, ceil_mode=True)
        self.pw = nn.Conv2d(cin, cout, 1, 1, bias=False)
        init.kaiming_normal_(self.pw.weight, mode='fan_out', nonlinearity='relu')
        self.bn = nn.BatchNorm2d(cout, momentum=0.9)

    def forward(self, x):
        x = self.maxpool(x)
        x = self.pw(x)
        x = self.bn(x)
        x = F.relu(x)
        return x

