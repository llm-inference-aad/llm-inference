# Configuration: vLLM + Speculative Decoding + Constrained Decoding
# This runs with BOTH speculative decoding AND constrained decoding enabled
# Temperature/top_p will be automatically capped to improve acceptance rates
# Use to measure combined impact of constraints + speculation

USE_VLLM=true
VLLM_BACKEND=true

# LLM Inference Environment Variables
LLM_INFERENCE_ROOT_DIR=/home/hice1/jgil37/scratch/llm-inference
VENV_PATH=/home/hice1/jgil37/scratch/llm-inference/venv

# Model paths (Llama on cluster)
MODEL_PATH=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct
MODEL_PATH_SIMPLE=/home/hice1/jgil37/scratch/llm_models/meta-llama/Llama-3.1-8B-Instruct

# vLLM Configuration
TENSOR_PARALLEL_SIZE=1
GPU_MEMORY_UTILIZATION=0.95
MAX_MODEL_LEN=32768
VLLM_DTYPE=bfloat16
ENABLE_PREFIX_CACHING=true

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
SERVER_WORKERS=1
BATCH_SIZE=8

# LLM Configuration
LLM_MODEL=local_server
MAX_NEW_TOKENS_DEFAULT=800
MAX_NEW_TOKENS_SERVER=1648

# ========================================
# CONSTRAINED DECODING: JSON
# ========================================
CONSTRAINED_DECODING_ENABLED=true
CONSTRAINT_TYPE=json
DEFAULT_CONSTRAINT_TYPE=json

# Default JSON schema for all requests (optional)
DEFAULT_JSON_SCHEMA=

# Constraint configuration
CONSTRAINT_VALIDATION_TIMEOUT=30
CONSTRAINT_LOGGING_ENABLED=true

# ========================================
# SPECULATIVE DECODING: Suffix Method
# ========================================
ENABLE_SPECULATIVE_DECODING=true

# Suffix speculation (recommended, uses adaptive tree depth)
VLLM_SPECULATIVE_METHOD=draft_model
VLLM_SPECULATIVE_MODEL=meta-llama/Llama-2-1b
VLLM_ADAPTIVE_SPECULATION=true
VLLM_NUM_SPECULATIVE_TOKENS=5
VLLM_SUFFIX_DECODING_MAX_TREE_DEPTH=24
VLLM_SUFFIX_DECODING_MAX_SPEC_FACTOR=1.0
VLLM_SUFFIX_DECODING_MIN_TOKEN_PROB=0.1

# ========================================
# COMBINED CONSTRAINTS + SPECULATION
# ========================================
# These settings automatically trigger when using both constraints + speculation
# Temperature and top_p are auto-capped for better acceptance rates
SPECULATIVE_CONSTRAINED_TEMPERATURE_CAP=0.25
SPECULATIVE_CONSTRAINED_TOP_P_CAP=0.9
ENABLE_PROFILED_BATCH_GROUPING=true

# Evolution Parameters
NUM_EOT_ELITES=2
START_POPULATION_SIZE=8
NUM_GENERATIONS=1
PROB_EOT=0.25
PROB_QC=0.0

# API Keys
GEMINI_API_KEY=AIzaSyBFB1dtVV0YHbQhVVVQHBWjNGQ9s4bo6io
DEEPSEEK_API_KEY=sk-904e2c59d6e241afab18c2b2d00d6f20
HF_TOKEN=your_huggingface_token_here
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here
# Added by switch_config.sh
RUN_ID="all"
RUN_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/all"
RUN_METRICS_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/all/metrics"
RUN_LOG_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/all/logs"
RUN_ERRORS_DIR="/home/hice1/jgil37/scratch/llm-inference/switch_config_results/all/errors"
