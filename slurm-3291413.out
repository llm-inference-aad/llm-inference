import torch
from torch import optim as optim
import torch.nn as nn

def get_optimizer(model, lr, weight_decay=0, nesterov=True):
    def group_parameters(module, weight_decay, no_weight_decay_types=('bn', 'ln')):
        param_groups = []
        memo = set()
        for name, p in module.named_parameters():
            if p is None or p in memo:
                continue
            memo.add(p)
            if not p.requires_grad:
                continue
            
            if any(nd in name for nd in no_weight_decay_types) or 'bias' in name:
                group = {'params': [p]}
                if 'bias' in name:
                    group['lr'] = lr * 2.0
                param_groups.append(group)
            else:
                group = {'params': [p], 'weight_decay': weight_decay}
                param_groups.append(group)
        return param_groups
    
    if weight_decay!= 0:
        grouped_params = group_parameters(model, weight_decay)
        opt = optim.SGD(grouped_params, lr=lr, momentum=0.9, nesterov=nesterov)
    else:
        opt = optim.SGD(model.parameters(), lr=lr, momentum=0.9, nesterov=nesterov)
    return opt
